{% extends "base.njk" %}

{% block title %}{{ status_code }} — {{ shop_name }}{% endblock %}

{% block content %}
<div class="card card-pad max-w-lg mx-auto text-center py-14">
  <div class="font-display text-5xl font-semibold text-ink-faint">{{ status_code }}</div>
  <p class="mt-3 text-ink-soft">{{ message }}</p>
  <a href="/" class="btn btn-primary mt-6">{{ t('web.back_home', lang) }}</a>
</div>
{% endblock %}
