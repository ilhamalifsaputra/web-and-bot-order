{# Shared "Clean Modern" theme — included from the <head> of BOTH web-admin and
   the storefront base.njk so the two webs stay one visual family. Source of
   truth for every design token (colours, fonts, radius, shadows) and the
   component @layer. Change a token here → both webs change.
   Extracted from apps/web-admin/views/base.njk (plan.md §6, decision B). #}

{# Clean Modern type system: Outfit (headings) + Manrope (body) +
   JetBrains Mono (order codes / ids). The colour tokens keep their names
   (paper/card/ink/pine/amberx/rust) so every view re-skins from here. #}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script>
  // Clean Modern palette — cool off-white background, confident blue accent.
  // ("pine" token now carries the blue so views need no edits.)
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          paper: "#f6f8fb",
          card:  "#ffffff",
          sand:  "#eef1f6",
          line:  "#e3e8ef",
          ink:   { DEFAULT: "#1b2330", soft: "#5a6473", faint: "#97a1b1" },
          pine:  { DEFAULT: "#2563eb", dark: "#1d4ed8", tint: "#e6effe" },
          grass: { DEFAULT: "#16a34a", dark: "#15803d", tint: "#e7f6ec" },
          amberx:{ DEFAULT: "#b45c0a", tint: "#fdedcf" },
          rust:  { DEFAULT: "#dc2626", dark: "#b91c1c", tint: "#fde7e7" },
        },
        fontFamily: {
          display: ['Outfit', 'system-ui', 'sans-serif'],
          sans: ['Manrope', 'system-ui', 'sans-serif'],
          mono: ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
        },
        boxShadow: {
          soft: "0 1px 2px rgba(16,24,40,.04), 0 8px 24px -14px rgba(16,24,40,.12)",
          lift: "0 2px 4px rgba(16,24,40,.06), 0 16px 36px -18px rgba(16,24,40,.18)",
        },
        borderRadius: { xl2: "1.25rem" },
      },
    },
  };
</script>

<style type="text/tailwindcss">
  @layer base {
    body { @apply font-sans bg-paper text-ink antialiased; }
    h1, h2, h3 { @apply font-display; }
  }
  @layer components {
    /* Surfaces */
    .card        { @apply bg-card rounded-2xl border border-line shadow-soft; }
    .card-pad    { @apply p-5 sm:p-6; }

    /* Headings */
    .page-title  { @apply font-display text-3xl font-semibold tracking-tight text-ink; }
    .page-lead   { @apply text-sm text-ink-soft mt-1; }
    .section-title { @apply font-display text-lg font-semibold text-ink; }

    /* Buttons */
    .btn         { @apply inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-pine/30; }
    .btn-primary { @apply bg-pine text-white hover:bg-pine-dark shadow-soft; }
    .btn-soft    { @apply bg-pine-tint text-pine-dark hover:bg-pine/15; }
    .btn-ghost   { @apply text-ink-soft hover:bg-sand hover:text-ink; }
    .btn-danger  { @apply bg-rust text-white hover:bg-rust-dark; }
    .btn-sm      { @apply px-3 py-1.5 text-xs rounded-lg; }

    /* Forms */
    .field-label { @apply block text-xs font-semibold uppercase tracking-wide text-ink-soft mb-1.5; }
    .field       { @apply w-full rounded-xl border border-line bg-white px-3 py-2 text-sm text-ink placeholder:text-ink-faint transition focus:outline-none focus:border-pine focus:ring-2 focus:ring-pine/25; }

    /* Stats */
    .stat-label  { @apply text-[0.7rem] font-semibold uppercase tracking-wider text-ink-soft; }
    .stat-value  { @apply font-display text-3xl font-semibold text-ink mt-2 leading-none; }
    .stat-sub    { @apply text-xs text-ink-soft mt-2; }

    /* Tables */
    .data-table  { @apply min-w-full text-sm; }
    .data-table thead th { @apply px-4 py-3 text-left text-[0.7rem] font-semibold uppercase tracking-wider text-ink-soft bg-sand/50; }
    .data-table tbody td { @apply px-4 py-3 align-middle; }
    .data-table tbody tr { @apply border-t border-line; }
    .data-table tbody tr:hover { @apply bg-sand/30; }

    /* Misc */
    .link        { @apply text-pine font-semibold hover:text-pine-dark hover:underline underline-offset-2; }
    .codeish     { @apply font-mono text-xs bg-sand/60 rounded px-1.5 py-0.5 text-ink; }
    .chip        { @apply inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold; }
  }
</style>

<script src="https://unpkg.com/htmx.org@2.0.3" defer></script>
{# Lucide — free open-source icons (https://lucide.dev). Stroke icons inherit
   currentColor, so a text-* class tints them. #}
<script src="https://unpkg.com/lucide@latest"></script>
<link rel="stylesheet" href="/static/app.css">
<style>
  /* Icons sit on the text baseline and never shrink in flex rows. */
  [data-lucide], svg.lucide { display: inline-block; vertical-align: -0.125em; flex-shrink: 0; }
</style>
