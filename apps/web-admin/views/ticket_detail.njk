{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Ticket #{{ ticket.id }} · Support{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="/support" class="link text-sm">← Support</a>
  <h1 class="page-title mt-1 flex items-center gap-3"><i data-lucide="life-buoy" class="w-7 h-7 text-sky-500"></i> Ticket #{{ ticket.id }} {{ ui.status_badge(ticket.status) }}</h1>
  {% if ticket_user %}
  <p class="page-lead">from
    <a class="link font-normal" href="/users/{{ ticket_user.id }}">{{ ticket_user.fullName or ticket_user.username or (ticket_user.telegramId and ('Telegram ' + (ticket_user.telegramId | string))) or ticket_user.email or '—' }}</a>
  </p>
  {% endif %}
</div>
{{ ui.flash(msg, kind) }}

<div class="card card-pad mb-6">
  <div class="text-xs text-ink-faint mb-1">First message · {{ ticket.createdAt | localdt }}</div>
  <p class="whitespace-pre-wrap text-sm">{{ ticket.message }}</p>
  {% if ticket.photoFileIds %}<p class="text-xs text-ink-faint mt-2">Includes photo attachment(s).</p>{% endif %}
</div>

<div class="space-y-3 mb-6">
  {% for m in messages %}
  <div class="flex {% if (m.senderType | lower) == 'admin' %}justify-end{% endif %}">
    <div class="max-w-lg rounded-2xl px-4 py-2.5 text-sm
      {% if (m.senderType | lower) == 'admin' %}bg-pine text-white{% else %}card{% endif %}">
      <div class="text-xs opacity-70 mb-1">{{ 'You / team' if (m.senderType | lower) == 'admin' else 'Customer' }} · {{ m.createdAt | localdt }}</div>
      <p class="whitespace-pre-wrap">{{ m.content }}</p>
    </div>
  </div>
  {% else %}
  <p class="text-ink-faint text-sm">No replies yet.</p>
  {% endfor %}
</div>

{% if (ticket.status | lower) != 'closed' %}
<div class="card card-pad">
  <h2 class="section-title mb-2">Reply</h2>
  <p class="text-xs text-amberx mb-3">This is saved to the conversation as a note. It does <b>not</b> message the customer automatically — reply to them in Telegram too.</p>
  <form method="post" action="/support/{{ ticket.id }}/reply" class="space-y-2">
    {{ ui.csrf_field(admin) }}
    <textarea name="content" rows="3" required class="field"></textarea>
    <div class="flex gap-3">
      <button class="btn btn-primary">Save reply</button>
    </div>
  </form>
  <form method="post" action="/support/{{ ticket.id }}/close" class="mt-3"
        data-confirm="Close this ticket?">
    {{ ui.csrf_field(admin) }}
    {{ ui.btn('Close ticket', 'x-circle', 'danger', cls='btn-sm') }}
  </form>
</div>
{% endif %}
{% endblock %}
