# Copy to .env and fill in real values. NEVER commit .env.
# The Node services read DATABASE_URL_PRISMA; the legacy Python stack reads DATABASE_URL.

# ---------------------------------------------------------------------
# DEPLOY (Docker) — banyak toko dalam satu VPS
# ---------------------------------------------------------------------
# Aplikasi ini single-tenant (satu deploy = satu bot = satu toko = satu DB).
# Untuk menjalankan BEBERAPA toko independen di satu VPS, jalankan tiap toko dari
# direktori repo sendiri dengan .env + ./data sendiri. Yang WAJIB beda per toko:
#   COMPOSE_PROJECT_NAME, WEB_PORT, STOREFRONT_PORT, WEB_COOKIE_SECRET,
#   SHOP_PUBLIC_URL (cari tag "[multi]" di bawah), dan bot_token (Settings —
#   lihat blok TELEGRAM di bawah).
# Aturan emas: JANGAN pakai satu bot token di dua instance (bentrok 409 Telegram).
# Panduan lengkap: DOCS.md §11 "Banyak toko dalam satu VPS".
#
# Nama container Docker diturunkan dari COMPOSE_PROJECT_NAME (default = nama
# folder). Set eksplisit + unik kalau menjalankan >1 instance di host yang sama.
# COMPOSE_PROJECT_NAME=shopa                  # [multi] unik per toko

# ---------------------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------------------
ADMIN_IDS=11111111,22222222
# SUPPORT_GROUP_ID=-1001234567890

# Bot token, Binance/Bybit UID + API key/secret, notifier token, and the
# public channel ID are NOT set here — fill them once via the Setup Wizard
# (first run) or web-admin → Settings, which is the ONLY normal way to
# configure them (DB always wins over env). The matching env vars
# (BOT_TOKEN, BOT_USERNAME, NOTIF_BOT_TOKEN, PUBLIC_CHANNEL_ID,
# BINANCE_RECEIVE_UID/BINANCE_API_KEY/BINANCE_API_SECRET,
# BYBIT_UID/BYBIT_API_KEY/BYBIT_API_SECRET) still work as an emergency
# recovery fallback if you ever get locked out of web-admin — they are not
# part of a normal deploy and should stay unset. See DOCS.md §6.

# ---------------------------------------------------------------------
# PAYMENT — tuning (gateway credentials live in web-admin Settings)
# ---------------------------------------------------------------------
CURRENCY=USDT
PAYMENT_WINDOW_MINUTES=30
USE_UNIQUE_CENTS=1
# Binance Internal Transfer (UID-based, auto-confirmed) poll tuning. The
# receive UID + read-only API key/secret are set in Settings — see above.
BINANCE_API_BASE=https://api.binance.com
POLL_INTERVAL_SECONDS=10
INTERNAL_PAYMENT_WINDOW_MINUTES=15
# Optional: show an IDR equivalent on the instructions (USDT * rate).
# USDT_IDR_RATE=16300

# Bybit Internal Transfer (UID-based, instant, off-chain, auto-confirmed) poll
# tuning. The UID + Wallet-read-only API key/secret are set in Settings — see
# above. Matching is by the order's unique amount — keep USE_UNIQUE_CENTS=1
# and have buyers send exact amount. Probe first: pnpm bybit-probe
BYBIT_API_BASE=https://api.bytick.com
BYBIT_PAYMENT_WINDOW_MINUTES=30
BYBIT_POLL_INTERVAL_SECONDS=5

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------
# Prisma (file: URL; in Docker use an absolute path file:/app/data/bot.db).
# [multi] nilai SAMA di semua instance — isolasi via ./data per direktori (Docker)
# atau path file berbeda (non-Docker).
DATABASE_URL_PRISMA=file:../data/bot.db

# ---------------------------------------------------------------------
# BEHAVIOUR / TUNING
# ---------------------------------------------------------------------
DEFAULT_LANGUAGE=en
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3
REFERRAL_COMMISSION_PERCENT=10
DEFAULT_WARRANTY_DAYS=30
LOW_STOCK_THRESHOLD=3
TIMEZONE=Asia/Jakarta

# ---------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------
# debug | info | warn | error  (lowercase)
LOG_LEVEL=info

# ---------------------------------------------------------------------
# WEB ADMIN
# ---------------------------------------------------------------------
# WAJIB: minimal 32 karakter acak. Bikin nilai acak:
#   - Linux/Mac/Git-Bash: openssl rand -hex 32
#   - Atau ketik asal-asalan >32 huruf/angka. Jangan pernah dibagikan.
WEB_COOKIE_SECRET=change-me-to-a-random-string-of-at-least-32-characters  # [multi] WAJIB beda tiap toko
WEB_COOKIE_NAME=stockweb_session
WEB_SESSION_TTL_HOURS=12
WEB_HOST=127.0.0.1
WEB_PORT=8000                           # [multi] WAJIB beda tiap toko (8001, 8002, …)
# Anti-bruteforce login panel admin: maks percobaan gagal per IP/akun dalam
# WINDOW_SECONDS sebelum diblokir sementara.
WEB_LOGIN_RATE_LIMIT_MAX=5
WEB_LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
# Set true di PRODUKSI (di balik HTTPS) supaya cookie sesi tidak bocor lewat
# koneksi http biasa. Biarkan false saat tes lokal di http://127.0.0.1.
WEB_COOKIE_SECURE=false

# ---------------------------------------------------------------------
# STOREFRONT (toko web pelanggan)
# ---------------------------------------------------------------------
# Dua cara menyajikan toko + admin:
#  (a) Satu domain, pisah per-subdomain (satu listener/port):
#      isi SHOP_HOST = host toko. Request ke host itu -> toko; selain itu -> admin.
#  (b) Tanpa SHOP_HOST: toko jalan di port terpisah STOREFRONT_PORT (dev/VPS).
# SHOP_HOST=shop.domainkamu.com
# SHOP_PUBLIC_URL=https://shop.domainkamu.com   # [multi] domain toko ini (link DM + callback gateway)
STOREFRONT_PORT=8100                            # [multi] WAJIB beda tiap toko (8101, 8102, …)

# ---------------------------------------------------------------------
# SERVER GABUNGAN (apps/server) — transport bot
# ---------------------------------------------------------------------
# polling (default) = bot long-polling, TIDAK butuh domain/HTTPS untuk bot.
# webhook           = bot jadi route di Fastify yang sama (butuh PUBLIC_URL +
#                     WEBHOOK_SECRET + domain HTTPS / reverse proxy).
BOT_MODE=polling
# PUBLIC_URL=https://app.domainkamu.com    # WAJIB jika BOT_MODE=webhook (tanpa / di akhir)
# WEBHOOK_SECRET=string-acak-panjang        # WAJIB jika BOT_MODE=webhook; jangan dibagikan

# ---------------------------------------------------------------------
# NOTIFIER (channel testimoni publik)
# ---------------------------------------------------------------------
# NOTIF_BOT_TOKEN & PUBLIC_CHANNEL_ID diisi di web admin → Settings → Bot &
# notifications (lihat blok TELEGRAM di atas) — tempel link t.me/… atau
# @username untuk channel, otomatis di-resolve jadi ID numerik. Token notifier
# opsional: kosong = pakai bot utama (harus jadi admin channel).
NOTIF_POLL_INTERVAL_SECONDS=10
NOTIF_MAX_ATTEMPTS=5

# ---------------------------------------------------------------------
# EMAIL / SMTP — hanya untuk fitur "lupa password" di toko (storefront)
# ---------------------------------------------------------------------
# Aktif hanya bila SMTP_HOST dan SMTP_FROM terisi. Kalau kosong, fitur lupa
# password lewat email mati (admin tetap bisa reset lewat Telegram/CLI).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=akun@gmail.com
# SMTP_PASS=app-password-16-digit
# SMTP_FROM=Toko Kamu <akun@gmail.com>
# SMTP_SECURE=false

# ---------------------------------------------------------------------
# DIATUR DARI WEB-ADMIN (Settings), BUKAN di sini:
#   - Bot token & username, notifier token, public channel ID (lihat blok
#     TELEGRAM di atas)
#   - Binance/Bybit Internal Transfer: UID + API key/secret (lihat blok
#     PAYMENT di atas)
#   - TokoPay (QRIS Rupiah): tokopay_merchant_id, tokopay_secret, tokopay_enabled
#   - PayDisini (QRIS/e-wallet Rupiah): paydisini_userkey, paydisini_apikey, paydisini_enabled
#   - NOWPayments (USDT hosted invoice): nowpayments_api_key, nowpayments_ipn_secret,
#     nowpayments_pay_currency, nowpayments_enabled
#   - Kurs USDT->IDR: usd_idr_rate (+ auto-update), usd_idr_rate_rounding
# Lihat DOCS.md §6 untuk detail resolusi Settings-vs-env per field.
# ---------------------------------------------------------------------
