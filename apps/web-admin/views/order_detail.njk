{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}{{ order.orderCode }} · Orders{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="/orders" class="link text-sm">← All orders</a>
  <h1 class="page-title mt-1 flex items-center gap-3">
    <i data-lucide="receipt" class="w-7 h-7 text-blue-500"></i>
    <span class="font-mono text-2xl">{{ order.orderCode }}</span>
    {{ ui.status_badge(order.status) }}
  </h1>
</div>
{{ ui.flash(msg, kind) }}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <section class="lg:col-span-2 space-y-6">
    <div class="card card-pad">
      <h2 class="section-title mb-3">What they bought</h2>
      <table class="data-table">
        <thead>
          <tr><th>Product</th><th class="text-right">Qty</th><th class="text-right">Price each</th><th>Warranty</th></tr>
        </thead>
        <tbody>
          {% for it in order.items %}
          <tr>
            <td>{{ it.product.name }}</td>
            <td class="text-right tabular">{{ it.quantity }}</td>
            <td class="text-right tabular">{{ it.unitPrice | money }} {{ currency }}</td>
            <td class="text-ink-soft">{{ it.warrantyDaysSnapshot }} days</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if is_delivered %}
    <div class="card card-pad border-l-4 border-grass">
      <h2 class="section-title mb-1">Delivered account details</h2>
      <p class="text-xs text-ink-soft mb-3">Only you can see this. Never paste it into chats or screenshots.</p>
      <ul class="space-y-1 font-mono text-xs">
        {% for it in order.items %}
        {% if it.stockItem %}
        <li class="bg-sand/60 rounded px-2 py-1 break-all">{{ it.stockItem.credentials }}</li>
        {% endif %}
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if can_act %}
    <div class="card card-pad">
      <h2 class="section-title mb-3">Check this payment</h2>
      <div class="flex flex-wrap gap-4 items-start">
        <form method="post" action="/orders/{{ order.id }}/approve"
              onsubmit="return confirm('Approve this payment and send the order to the customer?');">
          {{ ui.csrf_field(admin) }}
          <button class="btn btn-primary"><i data-lucide="check" class="w-4 h-4"></i> Approve &amp; deliver</button>
        </form>
        <form method="post" action="/orders/{{ order.id }}/reject" class="flex gap-2 items-center">
          {{ ui.csrf_field(admin) }}
          <input type="text" name="reason" required placeholder="Why are you rejecting it?" class="field w-64">
          <button class="btn btn-danger"><i data-lucide="x" class="w-4 h-4"></i> Reject</button>
        </form>
      </div>
    </div>
    {% endif %}

    {% if order.adminNote %}
    <div class="card card-pad">
      <h2 class="section-title mb-2">Notes</h2>
      <pre class="text-xs text-ink-soft whitespace-pre-wrap font-sans">{{ order.adminNote }}</pre>
    </div>
    {% endif %}
  </section>

  <aside class="space-y-6">
    <div class="card card-pad text-sm">
      <h2 class="section-title mb-3">Customer</h2>
      <dl class="space-y-1.5">
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Name</dt><dd>{{ order.user.fullName or '—' }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Username</dt><dd>{{ order.user.username or '—' }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Telegram</dt><dd>{{ order.user.telegramId }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Language</dt><dd>{{ order.user.language }}</dd></div>
      </dl>
      <a href="/users/{{ order.user.id }}" class="link text-xs mt-3 inline-block">View customer →</a>
    </div>

    <div class="card card-pad text-sm">
      <h2 class="section-title mb-3">Money</h2>
      <dl class="space-y-1.5 tabular">
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Items total</dt><dd>{{ order.subtotalAmount | money }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Quantity discount</dt><dd>−{{ order.bulkDiscountAmount | money }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Discount code</dt><dd>−{{ order.discountAmount | money }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Wallet credit used</dt><dd>−{{ order.walletUsed | money }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft" title="Tiny amount added so the transfer can be matched automatically">Amount marker</dt><dd>{{ order.uniqueCents | money }}</dd></div>
        <div class="flex justify-between gap-3 font-semibold border-t border-line pt-1.5 mt-1.5"><dt>Total to pay</dt><dd>{{ order.totalAmount | money }} {{ currency }}</dd></div>
      </dl>
    </div>

    <div class="card card-pad text-sm">
      <h2 class="section-title mb-3">Payment</h2>
      <dl class="space-y-1.5">
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Reference</dt><dd class="font-mono text-xs break-all text-right">{{ order.binanceTxid or '—' }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Proof</dt><dd>{{ 'Provided' if order.paymentProofFileId else 'None' }}</dd></div>
      </dl>
      <div class="text-ink-soft text-xs mt-3 space-y-1">
        <div>Placed: {{ order.createdAt | localdt }}</div>
        <div>Paid: {{ order.paidAt | localdt }}</div>
        <div>Delivered: {{ order.deliveredAt | localdt }}</div>
      </div>
    </div>
  </aside>
</div>
{% endblock %}
