node-linker=isolated
strict-peer-dependencies=false
# Hosting (Hostinger) menjalankan pnpm lewat corepack dgn versi berbeda dari
# pin "packageManager" (9.15.9), dan corepack tidak mau auto-switch. Jadikan
# ketidakcocokan versi sebagai peringatan, bukan error fatal, agar install
# di server tetap lanjut. Lihat README/RUN.md.
pm-on-fail=warn
  