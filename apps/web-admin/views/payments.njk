{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Payments · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Automatic Payments', 'Payments that come in through Binance are matched to orders and delivered for you.', 'wallet', 'sales') }}

{{ ui.flash(msg, kind) }}

{% if not enabled %}
<div class="rounded-xl px-4 py-3 mb-6 text-sm bg-sand text-ink-soft border border-line">
  Automatic payments are <b>turned off</b> (no Binance keys set). Nothing is being checked automatically —
  the history below is just a record of the past.
</div>
{% endif %}

{# ---- Auto-check status + result summary ---- #}
<section class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-8 gap-4 mb-8">
  <div class="card card-pad col-span-2">
    <div class="stat-label">Auto-check status</div>
    <div class="text-sm mt-2 text-ink">
      Last checked:
      <span class="font-medium" title="{{ tzname }}">{{ health.lastRun | localdt('yyyy-LL-dd HH:mm:ss') if health.lastRun else 'never' }}</span>
    </div>
    <div class="text-xs text-ink-soft mt-1">
      {{ health.lastTxCount if health.lastTxCount is not none else '—' }} payment(s) seen last check
      {% if health.backoffUntil %}· <span class="text-amberx">paused until {{ health.backoffUntil | localdt('HH:mm:ss') }}</span>{% endif %}
    </div>
  </div>
  {% set cards = [['matched','Confirmed','text-grass'], ['underpaid','Paid too little','text-amberx'], ['unmatched','Couldn’t match','text-pine'], ['delivery_failed','Delivery failed','text-rust'], ['credited_to_balance','Added to credit balance','text-grass'], ['dismissed','Dismissed','text-ink-soft']] %}
  {% for c in cards %}
  <div class="card card-pad">
    <div class="stat-label">{{ c[1] }}</div>
    <div class="stat-value tabular {% if counts[c[0]] %}{{ c[2] }}{% endif %}">{{ counts[c[0]] or 0 }}</div>
  </div>
  {% endfor %}
</section>

{# ---- Underpaid resolution ---- #}
<section class="card card-pad mb-8">
  <h2 class="section-title mb-3">Customers who paid too little <span class="text-ink-faint font-normal">({{ underpaid|length }})</span></h2>
  {% if underpaid|length == 0 %}
  <p class="text-sm text-ink-faint">Nothing waiting here. 🎉</p>
  {% else %}
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Order</th><th>Customer</th>
          <th>Should have paid</th><th>Note</th>
          <th class="text-right">What to do</th>
        </tr>
      </thead>
      <tbody>
        {% for o in underpaid %}
        <tr class="align-top">
          <td><a class="link font-mono text-xs" href="/orders/{{ o.id }}">{{ o.orderCode }}</a></td>
          <td class="text-ink-soft">{{ o.user.username or o.user.fullName or o.user.id }}</td>
          <td class="tabular">{{ o.totalAmount | idr }}</td>
          <td class="text-ink-soft break-all max-w-xs">{{ o.adminNote or '—' }}</td>
          <td>
            <div class="flex gap-2 justify-end">
              <form method="post" action="/payments/order/{{ o.id }}/deliver">
                {{ ui.csrf_field(admin) }}
                <button class="btn btn-primary btn-sm"
                        onclick="return confirm('Send {{ o.orderCode }} to the customer even though they paid less?')">Deliver anyway</button>
              </form>
              <form method="post" action="/payments/order/{{ o.id }}/refund">
                {{ ui.csrf_field(admin) }}
                <button class="btn btn-soft btn-sm"
                        onclick="return confirm('Put the amount they paid back into {{ o.orderCode }}\'s wallet and mark it refunded?')">Refund to wallet</button>
              </form>
              <form method="post" action="/payments/order/{{ o.id }}/cancel">
                {{ ui.csrf_field(admin) }}
                <button class="btn btn-danger btn-sm"
                        onclick="return confirm('Cancel {{ o.orderCode }} (no refund)?')">Cancel</button>
              </form>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</section>

{# ---- Manual match of an unmatched transfer ---- #}
<section class="card card-pad mb-8">
  <h2 class="section-title mb-1">Match a payment by hand</h2>
  <p class="text-xs text-ink-soft mb-4">If a customer's payment couldn't be matched automatically (they forgot the order note), link it to their order here and we'll deliver it.</p>
  <form method="post" action="/payments/match" class="flex flex-wrap gap-3 items-end">
    {{ ui.csrf_field(admin) }}
    <div>
      <label class="field-label">Payment reference</label>
      <input name="binance_tx_id" required class="field font-mono w-56" placeholder="Payment reference">
    </div>
    <div>
      <label class="field-label">Order code</label>
      <input name="order_code" required list="pending-internal" class="field font-mono w-40" placeholder="ABC123">
      <datalist id="pending-internal">
        {% for o in pending_internal %}<option value="{{ o.orderCode }}">{{ o.totalAmount | idr }}</option>{% endfor %}
      </datalist>
    </div>
    <button class="btn btn-primary">Match &amp; deliver</button>
  </form>
  {% if pending_internal|length %}
  <p class="text-xs text-ink-faint mt-3">{{ pending_internal|length }} order(s) are waiting to be matched.</p>
  {% endif %}
</section>

{# ---- Add an unmatched payment to a buyer's credit balance ---- #}
<section class="card card-pad mb-8">
  <h2 class="section-title mb-1">Add to a buyer's credit balance</h2>
  <p class="text-xs text-ink-soft mb-4">If a payment came in for an order you can no longer fulfil (it expired or the stock is gone), add it to that buyer's credit balance instead. The amount lands in the order's currency for them to spend on a future purchase — the order is then closed.</p>
  <form method="post" action="/payments/credit" class="flex flex-wrap gap-3 items-end"
        onsubmit="return confirm('Add this payment to the buyer\'s credit balance and close the order?')">
    {{ ui.csrf_field(admin) }}
    <div>
      <label class="field-label">Payment reference</label>
      <input name="binance_tx_id" required class="field font-mono w-56" placeholder="Payment reference">
    </div>
    <div>
      <label class="field-label">Order code</label>
      <input name="order_code" required class="field font-mono w-40" placeholder="ABC123">
    </div>
    <button class="btn btn-primary">Add to credit balance</button>
  </form>
</section>

{# ---- History ---- #}
<div class="rounded-xl px-4 py-3 mb-4 text-xs bg-sand/60 text-ink-soft border border-line leading-relaxed">
  <b>Reference</b> is the payment's ID at Binance — we match it to an order
  automatically by the <b>exact amount received</b>, so it is <b>not</b> an order
  code and won't be found in your sales orders.
  <b>“Couldn’t match”</b> means money arrived that didn’t line up with any waiting
  order. If a customer simply forgot the order note, link it with
  <a href="#" onclick="document.querySelector('input[name=binance_tx_id]').focus();return false" class="link">Match a payment by hand</a> above.
  If it belongs to no order at all (e.g. a <b>test deposit</b>), use
  <b>Dismiss</b> to clear it from the list.
</div>
<div class="flex items-center justify-between mb-3">
  <h2 class="section-title">Payment history</h2>
  <form method="get" action="/payments" class="flex gap-2 items-center text-sm">
    <select name="outcome" class="field" onchange="this.form.submit()">
      <option value="">All results</option>
      {% for o in outcomes %}<option value="{{ o }}" {% if f.outcome == o %}selected{% endif %}>{{ o | replace('_',' ') | title }}</option>{% endfor %}
    </select>
    <noscript><button class="btn btn-primary btn-sm">Filter</button></noscript>
  </form>
</div>

<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr>
        <th>When</th><th>Reference</th><th>Result</th>
        <th>Amount received (USDT)</th><th>Order</th>
      </tr>
    </thead>
    <tbody>
      {% for r in ledger %}
      <tr>
        <td class="text-ink-soft whitespace-nowrap" title="{{ tzname }}">{{ r.createdAt | localdt('yyyy-LL-dd HH:mm:ss') }}</td>
        <td class="font-mono text-xs break-all max-w-xs">{{ r.binanceTxId }}</td>
        <td>{{ ui.status_badge(r.outcome) }}</td>
        {# Binance transfers are a genuine USDT crypto rail — labelled explicitly,
           independent of the IDR shop money shown elsewhere. #}
        <td class="tabular">{{ r.amount | money }}{% if r.amount is not none %} USDT{% endif %}</td>
        <td>
          {% if r.order %}<a class="link font-mono text-xs" href="/orders/{{ r.order.id }}">{{ r.order.orderCode }}</a>
          {% elif r.outcome == 'unmatched' %}
          <div class="flex gap-2 items-center">
            <button type="button" class="btn btn-ghost btn-sm"
                    onclick="document.querySelector('input[name=binance_tx_id]:not([type=hidden])').value='{{ r.binanceTxId }}';document.querySelector('input[name=order_code]').focus();window.scrollTo(0,0);return false">Add to buyer's credit balance</button>
            <form method="post" action="/payments/dismiss" class="inline">
              {{ ui.csrf_field(admin) }}
              <input type="hidden" name="binance_tx_id" value="{{ r.binanceTxId }}">
              <button class="btn btn-ghost btn-sm"
                      onclick="return confirm('Dismiss this payment? Use this only when it belongs to no order (e.g. a test deposit). It will be marked “dismissed” and kept in the history.')">Dismiss</button>
            </form>
          </div>
          {% else %}<span class="text-ink-faint">—</span>{% endif %}
        </td>
      </tr>
      {% else %}
      {{ ui.empty_row(5, 'No payments match.') }}
      {% endfor %}
    </tbody>
  </table>
</div>

{% set qbase = '/payments?outcome=' + f.outcome %}
{{ ui.pager(qbase, page, has_next, total, 'payment(s)') }}
{% endblock %}
