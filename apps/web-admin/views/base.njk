<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Shop Admin{% endblock %}</title>
  <link rel="icon" href="/static/favicon.svg">

  {# Design tokens + component classes live in the SHARED theme partial
     (packages/web-ui/views/_theme.njk) so admin & storefront stay one family. #}
  {% include "_theme.njk" %}

  {# Admin-only sidebar skin (Inter + slate surfaces). Loaded AFTER the shared
     theme so it wins the cascade; the storefront never links it, so its look
     is untouched. #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/admin-theme.css">
</head>
<body class="h-full"
      {% if admin %}hx-headers='{"x-csrf-token": "{{ admin.csrf }}"}'{% endif %}>

{% if admin %}
{# ── Navigation data ── single source for the sidebar (_sidebar.njk) AND the
   topbar breadcrumb (_topbar.njk). Each group's `match` lists the paths that
   mark it active/expanded. `super` items show only to owners; `soon` items are
   non-clickable previews. Labels avoid jargon (Outbox→Customer notifications,
   Vouchers→Discount codes, Broadcast→Announcements, Audit→Activity log). #}
{% set nav_sections = [
  { single: true, href: '/', label: 'Dashboard', icon: 'layout-dashboard' },
  { label: 'Sales', icon: 'shopping-cart', match: ['/orders', '/payments', '/outbox'], items: [
      { href: '/orders', label: 'Orders', icon: 'shopping-cart' },
      { href: '/payments', label: 'Automatic payments', icon: 'wallet' },
      { href: '/outbox', label: 'Customer notifications', icon: 'bell' } ] },
  { label: 'Products', icon: 'package', match: ['/catalog', '/stock', '/vouchers'], items: [
      { href: '/stock', label: 'Stock', icon: 'boxes' },
      { href: '/catalog', label: 'Products & categories', icon: 'package' },
      { href: '/vouchers', label: 'Discount codes', icon: 'ticket-percent' } ] },
  { label: 'Customers', icon: 'users', match: ['/users', '/reviews', '/support', '/broadcast'], items: [
      { href: '/users', label: 'Customers', icon: 'users' },
      { href: '/broadcast', label: 'Announcements', icon: 'megaphone' },
      { href: '/support', label: 'Support', icon: 'life-buoy' },
      { href: '/reviews', label: 'Reviews', icon: 'star' } ] },
  { label: 'Reports', icon: 'bar-chart-3', match: ['/reports', '/audit', '/search'], items: [
      { href: '/reports', label: 'Reports', icon: 'trending-up' },
      { href: '/audit', label: 'Activity log', icon: 'history' },
      { href: '/search', label: 'Search', icon: 'search' } ] },
  { label: 'Settings', icon: 'settings', match: ['/settings', '/branding', '/admins'], items: [
      { href: '/settings', label: 'Settings', icon: 'sliders-horizontal' },
      { href: '/branding', label: 'Branding', icon: 'image' },
      { href: '/admins', label: 'Team', icon: 'users-round', super: true } ] }
] %}
{% set nav_integrations = { heading: 'Integrasi', label: 'Providers', icon: 'plug-zap', items: [
      { label: 'Top up game', icon: 'gamepad-2', soon: true },
      { label: 'Layanan SMM', icon: 'share-2', soon: true } ] } %}
{% set role_label = { 'super': 'Owner', 'support': 'Support', 'readonly': 'View only' } %}
{% endif %}

<div class="{% if admin %}flex min-h-full{% endif %}">
  {% if admin %}
    {% include "_sidebar.njk" %}
    <div id="overlay" class="fixed inset-0 z-30 hidden bg-slate-900/40 lg:hidden"></div>
  {% endif %}

  <div class="{% if admin %}flex min-w-0 flex-1 flex-col lg:pl-64{% endif %}">
    {% if admin %}{% include "_topbar.njk" %}{% endif %}

    <main class="{% if admin %}mx-auto w-full max-w-6xl flex-1 px-4 py-6 lg:px-8{% else %}max-w-6xl mx-auto px-4 py-8 sm:py-10{% endif %}">
      {% block content %}{% endblock %}
    </main>
  </div>
</div>

{# Shared AlertDialog target for any [data-confirm] action (admin-ui.js). One
   per page; replaces window.confirm() across the admin. #}
{% if admin %}
<dialog id="alert-dialog" class="alert" aria-labelledby="alert-dialog-title">
  <div class="card-pad">
    <h2 id="alert-dialog-title" class="section-title flex items-center gap-2">
      <i data-lucide="alert-triangle" class="w-5 h-5 text-amberx"></i> Please confirm
    </h2>
    <p data-alert-message class="text-sm text-ink-soft mt-2">Are you sure?</p>
    <div class="mt-5 flex justify-end gap-2">
      <button type="button" class="btn btn-ghost btn-sm" onclick="this.closest('dialog').close()">Cancel</button>
      <button type="button" data-alert-confirm class="btn btn-danger btn-sm">Confirm</button>
    </div>
  </div>
</dialog>
{% endif %}

<script defer src="/static/admin-ui.js"></script>
<script>
  // Render Lucide icons on load, and again after HTMX swaps content so
  // swapped-in <i> tags become SVGs.
  function renderIcons() { if (window.lucide) window.lucide.createIcons(); }
  renderIcons();
  document.addEventListener('htmx:afterSettle', renderIcons);
</script>

</body>
</html>
