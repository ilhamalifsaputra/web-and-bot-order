# Keep the build context small and reproducible.

# Reinstalled fresh in the builder from the lockfile.
node_modules
**/node_modules

# The legacy Python services (incl. their .venv) are not part of the Node image.
telegram-order-bot/
telegram-stock-web/
telegram-testimoni-bot/
**/.venv

# Runtime data is a mounted volume — never bake the dev DB / logs into the image.
data/
**/*.db
**/*.db-wal
**/*.db-shm
.tmp/

# VCS / tooling / local secrets.
.git
.gitignore
**/*.log
.env
.env.*
!.env.example

# Editor / OS noise.
.vscode
.idea
**/.DS_Store
