{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Import preview · Products{% endblock %}

{% block content %}
<div class="mb-5">
  <a href="/catalog" class="link text-sm">← Products</a>
  <h1 class="page-title mt-1 flex items-center gap-2.5"><i data-lucide="file-search" class="w-7 h-7 text-violet-500"></i> Preview before adding</h1>
  <p class="page-lead">
    <span class="text-grass font-medium">{{ valid_count }} ready to add</span>
    {% if invalid_count %}· <span class="text-rust font-medium">{{ invalid_count }} have a problem (will be skipped)</span>{% endif %}.
    Nothing has been saved yet.
  </p>
</div>

<div class="card overflow-x-auto mb-4">
  <table class="data-table">
    <thead>
      <tr>
        <th>Line</th>
        <th>Status</th>
        <th>Category</th>
        <th>Name</th>
        <th>Kind</th>
        <th>Duration</th>
        <th class="text-right">Price</th>
      </tr>
    </thead>
    <tbody>
      {% for r in rows %}
      <tr class="{% if not r.ok %}bg-rust-tint/50{% endif %}">
        <td class="text-ink-faint tabular">{{ r.line }}</td>
        <td>
          {% if r.ok %}<span class="text-grass">✓ ready</span>
          {% else %}<span class="text-rust">✗ {{ r.error }}</span>{% endif %}
        </td>
        <td>{{ r.category or '—' }}</td>
        <td>{{ r.name or '—' }}</td>
        <td>{{ r.type or '—' }}</td>
        <td>{{ r.durationLabel or '—' }}</td>
        <td class="text-right tabular">{{ r.price or '—' }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="flex gap-3">
  {% if valid_count %}
  <form method="post" action="/catalog/products/import/apply">
    {{ ui.csrf_field(admin) }}
    <input type="hidden" name="csv" value="{{ csv }}">
    <button class="btn btn-primary">Add {{ valid_count }} product(s)</button>
  </form>
  {% endif %}
  <a href="/catalog" class="btn btn-ghost">Cancel</a>
</div>
{% endblock %}
