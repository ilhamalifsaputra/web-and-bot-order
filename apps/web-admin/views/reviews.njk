{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Reviews · Stock Admin{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-6">Reviews</h1>
{{ ui.flash(msg, kind) }}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <aside class="space-y-4">
    <div class="bg-white rounded-lg shadow p-5 text-sm">
      <h2 class="font-semibold mb-3">Per-product rating</h2>
      <p class="text-xs text-slate-400 mb-2">Average excludes hidden reviews.</p>
      <table class="min-w-full text-sm">
        <thead class="text-slate-500 text-left"><tr><th class="py-1">Product</th><th class="py-1 text-right">Avg</th><th class="py-1 text-right">Visible</th><th class="py-1 text-right">Hidden</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          {% for s in summaries %}
          <tr>
            <td class="py-1"><a class="hover:underline" href="/reviews?product={{ s.productId }}">{{ s.productName }}</a></td>
            <td class="py-1 text-right">{% if s.avg %}{{ s.avg | round(1) }}{% else %}—{% endif %}</td>
            <td class="py-1 text-right text-slate-500">{{ s.count }}</td>
            <td class="py-1 text-right {% if s.hiddenCount %}text-red-600{% else %}text-slate-400{% endif %}">{{ s.hiddenCount }}</td>
          </tr>
          {% else %}
          <tr><td colspan="4" class="py-4 text-center text-slate-400">No reviews yet.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </aside>

  <section class="lg:col-span-2 space-y-4">
    <form method="get" action="/reviews" class="bg-white rounded-lg shadow p-4 flex flex-wrap gap-3 items-end text-sm">
      <div>
        <label class="block text-xs text-slate-500 mb-1">Product id</label>
        <input type="text" name="product" value="{{ f.product }}" class="border rounded px-2 py-1 w-28">
      </div>
      <div>
        <label class="block text-xs text-slate-500 mb-1">Visibility</label>
        <select name="hidden" class="border rounded px-2 py-1">
          <option value="" {% if f.hidden == '' %}selected{% endif %}>All</option>
          <option value="0" {% if f.hidden == '0' %}selected{% endif %}>Visible</option>
          <option value="1" {% if f.hidden == '1' %}selected{% endif %}>Hidden</option>
        </select>
      </div>
      <button class="bg-slate-200 px-3 py-1.5 rounded hover:bg-slate-300">Filter</button>
      <a href="/reviews" class="text-slate-500 hover:underline">Reset</a>
    </form>

    <div class="bg-white rounded-lg shadow divide-y divide-slate-100">
      {% for r in reviews %}
      <div class="p-4 {% if r.hidden %}bg-red-50/40{% endif %}">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="text-sm">
              <span class="font-medium text-amber-500">{{ '★' * r.rating }}{{ '☆' * (5 - r.rating) }}</span>
              <span class="text-slate-500">· {{ r.product.name }}</span>
              {% if r.hidden %}<span class="ml-1 text-xs text-red-600">hidden</span>{% endif %}
            </div>
            <p class="text-sm text-slate-700 mt-1">{{ r.comment or '(no comment)' }}</p>
            <p class="text-xs text-slate-400 mt-1">
              <a class="hover:underline" href="/users/{{ r.user.id }}">{{ r.user.fullName or r.user.username or ('tg:' + (r.user.telegramId | string)) }}</a>
              · {{ r.createdAt | localdt }}
            </p>
          </div>
          <form method="post" action="/reviews/{{ r.id }}/hide">
            {{ ui.csrf_field(admin) }}
            <input type="hidden" name="hidden" value="{{ 'false' if r.hidden else 'true' }}">
            {% if r.hidden %}
            <button class="bg-green-100 text-green-700 px-3 py-1.5 rounded hover:bg-green-200 text-sm whitespace-nowrap">Restore</button>
            {% else %}
            <button class="bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200 text-sm whitespace-nowrap">Hide</button>
            {% endif %}
          </form>
        </div>
      </div>
      {% else %}
      <div class="p-6 text-center text-slate-400">No reviews match.</div>
      {% endfor %}
    </div>

    {% if has_next or page > 1 %}
    <div class="flex justify-between text-sm">
      {% if page > 1 %}<a class="text-slate-600 hover:underline" href="/reviews?product={{ f.product }}&hidden={{ f.hidden }}&page={{ page - 1 }}">← Prev</a>{% else %}<span></span>{% endif %}
      {% if has_next %}<a class="text-slate-600 hover:underline" href="/reviews?product={{ f.product }}&hidden={{ f.hidden }}&page={{ page + 1 }}">Next →</a>{% endif %}
    </div>
    {% endif %}
  </section>
</div>
{% endblock %}
