<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Stock Admin{% endblock %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/htmx.org@2.0.3" defer></script>
  <link rel="stylesheet" href="/static/app.css">
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen"
      {% if admin %}hx-headers='{"x-csrf-token": "{{ admin.csrf }}"}'{% endif %}>

{% block nav %}
{% if admin %}
{% set nav_items = [
  ['/', 'Dashboard'],
  ['/stock', 'Stock'],
  ['/orders', 'Orders'],
  ['/catalog', 'Catalog'],
  ['/vouchers', 'Vouchers'],
  ['/users', 'Users'],
  ['/support', 'Support'],
  ['/settings', 'Settings'],
  ['/audit', 'Audit']
] %}
<nav class="bg-slate-900 text-white">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="font-semibold tracking-tight whitespace-nowrap">Stock Admin</a>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
      {% for item in nav_items %}
      <a href="{{ item[0] }}"
         class="hover:text-white {% if active_nav == item[0] %}text-white font-semibold border-b-2 border-white{% else %}text-slate-300{% endif %}">
        {{ item[1] }}
      </a>
      {% endfor %}
    </div>
    <div class="flex items-center gap-3 text-sm whitespace-nowrap">
      <span class="text-slate-400">tg:{{ admin.telegramId }}</span>
      <form method="post" action="/logout" class="inline">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <button type="submit" class="hover:underline">Logout</button>
      </form>
    </div>
  </div>
</nav>
{% endif %}
{% endblock %}

<main class="max-w-6xl mx-auto px-4 py-8">
  {% block content %}{% endblock %}
</main>

</body>
</html>
