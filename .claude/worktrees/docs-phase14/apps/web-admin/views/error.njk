{% extends "base.njk" %}
{% block title %}Something went wrong · Shop Admin{% endblock %}

{% block content %}
<div class="max-w-lg mx-auto mt-16 card card-pad text-center">
  <span class="grid place-items-center w-14 h-14 mx-auto rounded-2xl bg-rose-50 text-rose-600"><i data-lucide="triangle-alert" class="w-7 h-7"></i></span>
  <div class="font-display text-6xl font-semibold text-line mt-4">{{ status_code }}</div>
  <h1 class="page-title text-2xl mt-4">{{ title or "Something went wrong" }}</h1>
  <p class="text-ink-soft mt-2">{{ message or "Sorry, something didn't work. We've made a note of it — please try again." }}</p>
  <a href="/" class="btn btn-primary mt-6"><i data-lucide="arrow-left" class="w-4 h-4"></i> Back to home</a>
</div>
{% endblock %}
