{% extends "base.njk" %}
{% import "_shop.njk" as shop %}

{% block title %}{{ shop_name }}{% endblock %}

{% block meta %}
<meta name="description" content="{{ t('web.hero_sub', lang) }}">
<style>
  /* FAQ open animation */
  details[open] > .faq-body { animation: faq-in .18s ease; }
  @keyframes faq-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Section reveal on scroll */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity .5s ease, transform .5s ease; }
  .reveal.visible { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }

  .counter { font-variant-numeric: tabular-nums; }

  /* Dot-grid pattern for the stats band */
  .dot-grid {
    background-image: radial-gradient(circle, rgba(255,255,255,.18) 1px, transparent 1px);
    background-size: 26px 26px;
  }
</style>
{% endblock %}

{% block content %}

{# ── 1. Hero (design.md §4.8, mockup perbaikan) ── #}
<section class="relative overflow-hidden rounded-3xl bg-ink px-6 py-12 sm:px-10 sm:py-16 mb-12">
  {# Admin-configurable hero image (web_hero_url); when set, the gradient below
     is a semi-transparent tint over the photo so text stays readable. With no
     custom hero uploaded, the section falls back to a plain brand gradient
     instead of a stock photo. #}
  {% if hero_image %}
  <img src="{{ hero_image }}" alt="" aria-hidden="true" loading="eager" decoding="async"
       class="absolute inset-0 h-full w-full object-cover">
  <div class="absolute inset-0 bg-gradient-to-br from-ink/95 via-ink/85 to-pine-dark/80"></div>
  {% else %}
  <div class="absolute inset-0 bg-gradient-to-br from-ink via-pine-dark to-pine"></div>
  {% endif %}
  <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full bg-pine/20 blur-3xl"></div>
  <div class="relative max-w-2xl">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium uppercase tracking-wide text-grass">
      <i data-lucide="shield-check" class="h-3.5 w-3.5"></i>
      {{ t('web.hero_badge', lang) }}
    </span>
    <h1 class="mt-5 text-4xl font-display font-bold leading-tight text-white sm:text-5xl">{{ t('web.hero_title', lang) }}</h1>
    <p class="mt-4 text-lg text-ink-faint">{{ t('web.hero_sub', lang) }}</p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a href="#produk" class="inline-flex items-center gap-2 rounded-xl bg-pine px-5 py-3 font-semibold text-white hover:bg-pine-dark transition-colors shadow-soft">
        <i data-lucide="shopping-bag" class="h-5 w-5"></i>
        {{ t('web.hero_cta', lang) }}
      </a>
      <a href="#kontak" class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-5 py-3 font-semibold text-white hover:bg-white/10 transition-colors">
        <i data-lucide="message-circle" class="h-5 w-5"></i>
        {{ t('web.hero_cta2', lang) }}
      </a>
    </div>
    {# honest trust chips: capabilities/guarantees, no customer-count claims #}
    <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 border-t border-white/10 pt-5 text-sm text-ink-faint">
      <span class="inline-flex items-center gap-1.5"><i data-lucide="zap" class="h-4 w-4 text-amber-400"></i> {{ t('web.badge_instant', lang) }}</span>
      <span class="inline-flex items-center gap-1.5"><i data-lucide="shield" class="h-4 w-4 text-grass"></i> QRIS &amp; USDT</span>
      <span class="inline-flex items-center gap-1.5"><i data-lucide="check-circle" class="h-4 w-4 text-pine-tint"></i> {{ t('web.feat_warranty', lang) }}</span>
      <span class="inline-flex items-center gap-1.5"><i data-lucide="headphones" class="h-4 w-4 text-violet-400"></i> {{ t('web.badge_support', lang) }}</span>
    </div>
  </div>
</section>

{# ── 2. Fitur / keunggulan ── #}
<section class="mt-16 reveal">
  <p class="text-center text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.features_kicker', lang) }}</p>
  <h2 class="mt-1 text-center font-display text-3xl font-bold text-ink">{{ t('web.features_title', lang) }}</h2>
  <p class="mt-2 text-center text-ink-soft">{{ t('web.features_sub', lang) }}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-11 w-11 place-items-center rounded-xl bg-pine-tint text-pine"><i data-lucide="zap" class="h-5 w-5"></i></span>
      <h3 class="mt-4 font-semibold text-ink">{{ t('web.feat_instant', lang) }}</h3>
      <p class="mt-1 text-sm text-ink-soft">{{ t('web.feat_instant_d', lang) }}</p>
    </div>
    <div class="rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-11 w-11 place-items-center rounded-xl bg-grass-tint text-grass-dark"><i data-lucide="shield-check" class="h-5 w-5"></i></span>
      <h3 class="mt-4 font-semibold text-ink">{{ t('web.feat_secure', lang) }}</h3>
      <p class="mt-1 text-sm text-ink-soft">{{ t('web.feat_secure_d', lang) }}</p>
    </div>
    <div class="rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-11 w-11 place-items-center rounded-xl bg-amberx-tint text-amberx"><i data-lucide="check-circle" class="h-5 w-5"></i></span>
      <h3 class="mt-4 font-semibold text-ink">{{ t('web.feat_warranty', lang) }}</h3>
      <p class="mt-1 text-sm text-ink-soft">{{ t('web.feat_warranty_d', lang) }}</p>
    </div>
    <div class="rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-11 w-11 place-items-center rounded-xl bg-violet-50 text-violet-600"><i data-lucide="headphones" class="h-5 w-5"></i></span>
      <h3 class="mt-4 font-semibold text-ink">{{ t('web.feat_support', lang) }}</h3>
      <p class="mt-1 text-sm text-ink-soft">{{ t('web.feat_support_d', lang) }}</p>
    </div>
  </div>
</section>

{# ── 3. Kategori ── #}
{% if categories.length %}
<section class="mt-16 reveal" id="kategori">
  <p class="text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.categories', lang) }}</p>
  <h2 class="mt-1 font-display text-2xl font-bold text-ink">{{ t('web.categories_title', lang) }}</h2>

  <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {% for c in categories %}
    <a href="/c/{{ c.slug }}"
       class="group flex items-center gap-4 rounded-2xl border border-line bg-card p-5 shadow-sm transition hover:border-pine-tint hover:shadow">
      <span class="grid h-14 w-14 shrink-0 place-items-center rounded-xl bg-pine-tint text-2xl group-hover:scale-105 transition-transform">
        {% if c.emoji %}{{ c.emoji }}{% else %}<i data-lucide="box" class="w-6 h-6 text-pine"></i>{% endif %}
      </span>
      <div class="min-w-0">
        <h3 class="font-semibold text-ink truncate">{{ c.name }}</h3>
        <span class="inline-flex items-center gap-1 text-sm font-medium text-pine">
          {{ t('web.view_products', lang) }}
          <i data-lucide="chevron-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5"></i>
        </span>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── 4. Produk unggulan ── #}
<section id="produk" class="mt-16 reveal">
  <div class="flex items-end justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.featured_kicker', lang) }}</p>
      <h2 class="mt-1 font-display text-2xl font-bold text-ink">{{ t('web.new_arrivals', lang) }}</h2>
    </div>
    {% if categories.length %}
    <a href="#kategori" class="inline-flex items-center gap-1 group text-sm font-medium text-pine hover:text-pine-dark">{{ t('web.view_by_category', lang) }} <i data-lucide="chevron-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5"></i></a>
    {% endif %}
  </div>

  {% if products.length %}
  <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {% for p in products %}
    {{ shop.product_card(p, fx, low_threshold, lang) }}
    {% endfor %}
  </div>
  {% else %}
  <div class="rounded-2xl border border-line bg-card p-10 text-center text-ink-faint mt-5">{{ t('web.catalog_empty', lang) }}</div>
  {% endif %}
</section>

{# ── Layanan mendatang (rencana integrasi — statis, tanpa backend) ── #}
<section class="mt-16 reveal">
  <p class="text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.upcoming_kicker', lang) }}</p>
  <h2 class="mt-1 font-display text-2xl font-bold text-ink">{{ t('web.upcoming_title', lang) }}</h2>
  <p class="mt-2 text-ink-soft">{{ t('web.upcoming_sub', lang) }}</p>
  <div class="mt-5 grid gap-4 sm:grid-cols-2">
    <div class="flex items-start gap-4 rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-violet-50 text-violet-600"><i data-lucide="share-2" class="h-6 w-6"></i></span>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="font-semibold text-ink">{{ t('web.sosmed_title', lang) }}</h3>
          <span class="inline-flex items-center gap-1 rounded-full bg-amberx-tint px-2.5 py-1 text-xs font-medium text-amberx"><i data-lucide="clock" class="h-3.5 w-3.5"></i> {{ t('web.coming_soon', lang) }}</span>
        </div>
        <p class="mt-1 text-sm text-ink-soft">{{ t('web.sosmed_desc', lang) }}</p>
      </div>
    </div>
    <div class="flex items-start gap-4 rounded-2xl border border-line bg-card p-6 shadow-sm">
      <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-pine-tint text-pine"><i data-lucide="gamepad-2" class="h-6 w-6"></i></span>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h3 class="font-semibold text-ink">{{ t('web.topup_title', lang) }}</h3>
          <span class="inline-flex items-center gap-1 rounded-full bg-amberx-tint px-2.5 py-1 text-xs font-medium text-amberx"><i data-lucide="clock" class="h-3.5 w-3.5"></i> {{ t('web.coming_soon', lang) }}</span>
        </div>
        <p class="mt-1 text-sm text-ink-soft">{{ t('web.topup_desc', lang) }}</p>
      </div>
    </div>
  </div>
</section>

{# ── 5. Our Promise (replaces vanity numbers) ── #}
<section class="mt-16 overflow-hidden rounded-3xl bg-pine px-6 py-10 text-white sm:px-10 reveal">
  <h2 class="text-center font-display text-2xl font-bold sm:text-3xl">{{ t('web.promise_title', lang) }}</h2>
  <p class="mt-1 text-center text-pine-tint">{{ t('web.promise_sub', lang) }}</p>
  <div class="mt-8 grid gap-6 text-center sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-white/15">
        <i data-lucide="zap" class="h-6 w-6"></i>
      </div>
      <p class="mt-3 font-semibold">{{ t('web.promise_delivery', lang) }}</p>
      <p class="text-sm text-pine-tint">{{ t('web.promise_delivery_d', lang) }}</p>
    </div>
    <div>
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-white/15">
        <i data-lucide="shield-check" class="h-6 w-6"></i>
      </div>
      <p class="mt-3 font-semibold">{{ t('web.promise_payment', lang) }}</p>
      <p class="text-sm text-pine-tint">{{ t('web.promise_payment_d', lang) }}</p>
    </div>
    <div>
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-white/15">
        <i data-lucide="check-circle" class="h-6 w-6"></i>
      </div>
      <p class="mt-3 font-semibold">{{ t('web.promise_warranty', lang) }}</p>
      <p class="text-sm text-pine-tint">{{ t('web.promise_warranty_d', lang) }}</p>
    </div>
    <div>
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-white/15">
        <i data-lucide="headphones" class="h-6 w-6"></i>
      </div>
      <p class="mt-3 font-semibold">{{ t('web.promise_replies', lang) }}</p>
      <p class="text-sm text-pine-tint">{{ t('web.promise_replies_d', lang) }}</p>
    </div>
  </div>
</section>

{# ── 6. Testimoni — ulasan ASLI dari pesanan yang sudah terkirim (≥4★ dengan
      komentar). Section disembunyikan saat belum ada ulasan, supaya tidak ada
      testimoni karangan di halaman. ── #}
{% if testimonials.length %}
<section class="mb-12 reveal">
  <div class="text-center mb-8">
    <p class="text-xs font-semibold tracking-widest uppercase text-pine mb-2">{{ t('web.testi_kicker', lang) }}</p>
    <h2 class="font-display text-2xl sm:text-3xl font-bold text-ink tracking-tight">{{ t('web.testi_title', lang) }}</h2>
    <p class="mt-2 text-sm text-ink-soft">{{ t('web.testi_sub', lang) }}</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    {% for review in testimonials %}
    <div class="card card-pad flex flex-col gap-3">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-full bg-pine flex items-center justify-center
                    text-white font-display font-bold text-sm flex-shrink-0">{{ review.initial }}</div>
        <div class="flex-1 min-w-0">
          <div class="font-display text-sm font-semibold text-ink">{{ review.name }}</div>
          <div class="text-xs text-ink-faint">{{ t('web.testi_buyer', lang) }} · {{ review.product }}</div>
        </div>
        <div class="flex-shrink-0">{{ shop.stars(review.rating) }}</div>
      </div>
      <p class="text-sm text-ink-soft leading-relaxed border-t border-line pt-3 italic">
        “{{ review.comment }}”
      </p>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ── 7. FAQ ── #}
<section class="mt-16 reveal">
  <p class="text-center text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.faq_kicker', lang) }}</p>
  <h2 class="mt-1 text-center font-display text-3xl font-bold text-ink">{{ t('web.faq_title', lang) }}</h2>
  <p class="mt-2 text-center text-ink-soft">{{ t('web.faq_sub', lang) }}</p>
  <div class="mx-auto mt-8 max-w-3xl space-y-3">
    {% for n in [1, 2, 3, 4, 5] %}
    <details class="faq group rounded-2xl border border-line bg-card px-5 py-1" {% if loop.first %}open{% endif %}>
      <summary class="flex cursor-pointer items-center justify-between p-6 font-semibold text-ink">
        {{ t('web.faq_q' + n, lang) }}
        <i data-lucide="chevron-down" class="h-5 w-5 text-ink-faint transition-transform group-open:rotate-180"></i>
      </summary>
      <div class="px-6 pb-6 text-sm text-ink-soft leading-relaxed">
        {{ t('web.faq_a' + n, lang) }}
      </div>
    </details>
    {% endfor %}
  </div>
</section>

{# ── 8. Kontak ── #}
<section class="mt-16 reveal" id="kontak">
  <p class="text-center text-sm font-semibold uppercase tracking-wide text-pine">{{ t('web.contact_kicker', lang) }}</p>
  <h2 class="mt-1 text-center font-display text-3xl font-bold text-ink">{{ t('web.contact_title', lang) }}</h2>
  <p class="mt-2 text-center text-ink-soft">{{ t('web.contact_sub', lang) }}</p>

  <div class="mt-8 grid grid-cols-1 {{ 'sm:grid-cols-3' if wa_number else 'sm:grid-cols-2' }} gap-4 max-w-2xl mx-auto">
    {% if wa_number %}
    <a href="https://wa.me/{{ wa_number }}" target="_blank" rel="noopener noreferrer"
       class="flex flex-col items-center gap-3 rounded-2xl border border-line bg-card p-6 text-center shadow-sm transition hover:shadow-md">
      <div class="grid h-12 w-12 place-items-center rounded-2xl bg-grass-tint">
        <svg class="h-6 w-6 text-grass-dark" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      </div>
      <div>
        <h3 class="font-semibold text-ink">WhatsApp</h3>
        <p class="mt-1 text-xs text-ink-faint">{{ t('web.contact_wa_sub', lang) }}</p>
      </div>
    </a>
    {% endif %}

    <a href="https://t.me/{{ bot_username }}" target="_blank" rel="noopener noreferrer"
       class="flex flex-col items-center gap-3 rounded-2xl border border-line bg-card p-6 text-center shadow-sm transition hover:shadow-md">
      <div class="grid h-12 w-12 place-items-center rounded-2xl bg-[#eff6ff]">
        <svg class="h-6 w-6 text-[#2563eb]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </div>
      <div>
        <h3 class="font-semibold text-ink">Telegram</h3>
        <p class="mt-1 text-xs text-ink-faint">{{ t('web.contact_tg_sub', lang) }}</p>
      </div>
    </a>

    <a href="/account/support"
       class="flex flex-col items-center gap-3 rounded-2xl border border-line bg-card p-6 text-center shadow-sm transition hover:shadow-md">
      <div class="grid h-12 w-12 place-items-center rounded-2xl bg-pine-tint">
        <i data-lucide="ticket" class="h-6 w-6 text-pine"></i>
      </div>
      <div>
        <h3 class="font-semibold text-ink">{{ t('web.contact_ticket', lang) }}</h3>
        <p class="mt-1 text-xs text-ink-faint">{{ t('web.contact_ticket_sub', lang) }}</p>
      </div>
    </a>
  </div>

  <div class="mt-5 max-w-sm mx-auto">
    <div class="rounded-2xl bg-pine-tint p-4 flex items-start gap-2.5 text-sm text-ink-soft">
      <i data-lucide="clock" class="h-4 w-4 text-pine shrink-0 mt-0.5"></i>
      <p>{{ t('web.contact_hours', lang) }}</p>
    </div>
  </div>
</section>

{# ── Skrip: scroll reveal ── #}
<script>
(function () {
  'use strict';
  var reveals = document.querySelectorAll('.reveal');
  if (reveals.length && 'IntersectionObserver' in window) {
    var revObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); revObs.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    reveals.forEach(function (r) { revObs.observe(r); });
  } else {
    reveals.forEach(function (r) { r.classList.add('visible'); });
  }
}());
</script>

{% endblock %}
