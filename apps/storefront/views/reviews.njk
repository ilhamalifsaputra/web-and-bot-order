{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% import "_shop.njk" as shop %}

{% block title %}{{ t('web.account_reviews', lang) }} — {{ shop_name }}{% endblock %}

{% block content %}
<h1 class="page-title mb-6">{{ t('web.account_reviews', lang) }}</h1>

{% if pending.length %}
<section class="mb-8">
  <h2 class="section-title mb-3">{{ t('web.review_pending', lang) }}</h2>
  <div class="space-y-4">
    {% for p in pending %}
    <form method="post" action="/account/reviews" class="card card-pad">
      {{ ui.csrf_field(customer) }}
      <input type="hidden" name="order_id" value="{{ p.order_id }}">
      <input type="hidden" name="product_id" value="{{ p.product_id }}">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div>
          <div class="font-semibold text-sm">{{ p.product_name }}</div>
          <div class="text-xs text-ink-faint font-mono">{{ p.code }}</div>
        </div>
        <label class="text-xs text-ink-soft">{{ t('web.your_rating', lang) }}
          <select name="rating" class="field !w-20 inline-block ml-1">
            {% for r in [5, 4, 3, 2, 1] %}<option value="{{ r }}">{{ r }} ★</option>{% endfor %}
          </select>
        </label>
      </div>
      <textarea name="comment" rows="2" class="field mt-3" placeholder="{{ t('web.review_placeholder', lang) }}"></textarea>
      <div class="mt-3 text-right">
        <button type="submit" class="btn btn-primary btn-sm">{{ t('web.review_submit', lang) }}</button>
      </div>
    </form>
    {% endfor %}
  </div>
</section>
{% endif %}

<section>
  <h2 class="section-title mb-3">{{ t('web.account_reviews', lang) }}</h2>
  {% if reviews.length %}
  <div class="grid sm:grid-cols-2 gap-4">
    {% for r in reviews %}
    <div class="card card-pad">
      <div class="flex items-center justify-between gap-2">
        <div class="font-semibold text-sm">{{ r.product_name }}</div>
        {{ shop.stars(r.rating) }}
      </div>
      {% if r.comment %}<p class="text-sm text-ink-soft mt-2">{{ r.comment }}</p>{% endif %}
      <div class="text-xs text-ink-faint mt-2">{{ r.created_at | localdt('yyyy-LL-dd') }}</div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="card card-pad text-center text-ink-faint py-10">{{ t('web.reviews_none', lang) }}</div>
  {% endif %}
</section>
{% endblock %}
