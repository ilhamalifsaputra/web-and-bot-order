{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Catalog · Stock Admin{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-6">Catalog</h1>
{{ ui.flash(msg, kind) }}

<!-- Categories -->
<section class="mb-10">
  <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-2">Categories</h2>
  <div class="bg-white rounded-lg shadow overflow-x-auto mb-4">
    <table class="min-w-full text-sm">
      <thead class="bg-slate-100 text-slate-600 text-left">
        <tr><th class="px-4 py-2">Name</th><th class="px-4 py-2">Emoji</th><th class="px-4 py-2">Sort</th><th class="px-4 py-2">Active</th><th class="px-4 py-2"></th></tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for c in categories %}
        <tr>
          <td class="px-4 py-2 font-medium">{{ c.name }}</td>
          <td class="px-4 py-2">{{ c.emoji or '—' }}</td>
          <td class="px-4 py-2">{{ c.sortOrder }}</td>
          <td class="px-4 py-2">{{ ui.status_badge('active' if c.isActive else 'inactive') }}</td>
          <td class="px-4 py-2 text-right">
            <form method="post" action="/catalog/category/{{ c.id }}/toggle" class="inline">
              {{ ui.csrf_field(admin) }}
              <input type="hidden" name="is_active" value="{{ 'false' if c.isActive else 'true' }}">
              <button class="text-xs px-2 py-1 rounded bg-slate-200 hover:bg-slate-300">{{ 'Deactivate' if c.isActive else 'Activate' }}</button>
            </form>
          </td>
        </tr>
        {% else %}
        <tr><td colspan="5" class="px-4 py-6 text-center text-slate-400">No categories yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  <details class="bg-white rounded-lg shadow p-4">
    <summary class="cursor-pointer font-medium text-sm">+ New category</summary>
    <form method="post" action="/catalog/category" class="mt-3 flex flex-wrap gap-3 items-end text-sm">
      {{ ui.csrf_field(admin) }}
      <div><label class="block text-xs text-slate-500 mb-1">Name</label><input name="name" required class="border rounded px-2 py-1"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Emoji</label><input name="emoji" class="border rounded px-2 py-1 w-20"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Sort</label><input name="sort_order" type="number" value="0" class="border rounded px-2 py-1 w-20"></div>
      <button class="bg-slate-900 text-white px-4 py-1.5 rounded hover:bg-slate-700">Create</button>
    </form>
  </details>
</section>

<!-- Products -->
<section>
  <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-2">Products</h2>

  <details class="bg-white rounded-lg shadow p-4 mb-4">
    <summary class="cursor-pointer font-medium text-sm">+ New product</summary>
    <form method="post" action="/catalog/product" class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
      {{ ui.csrf_field(admin) }}
      <div><label class="block text-xs text-slate-500 mb-1">Category</label>
        <select name="category_id" required class="border rounded px-2 py-1 w-full">
          {% for c in categories %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
        </select></div>
      <div><label class="block text-xs text-slate-500 mb-1">Type</label>
        <select name="type" class="border rounded px-2 py-1 w-full">
          {% for t in product_types %}<option value="{{ t }}">{{ t | lower }}</option>{% endfor %}
        </select></div>
      <div><label class="block text-xs text-slate-500 mb-1">Name</label><input name="name" required class="border rounded px-2 py-1 w-full"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Duration label</label><input name="duration_label" required placeholder="1 Month" class="border rounded px-2 py-1 w-full"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Price ({{ currency }})</label><input name="price" required class="border rounded px-2 py-1 w-full"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Reseller price</label><input name="reseller_price" class="border rounded px-2 py-1 w-full"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Warranty days</label><input name="warranty_days" type="number" class="border rounded px-2 py-1 w-full"></div>
      <div><label class="block text-xs text-slate-500 mb-1">Image file_id</label><input name="image_file_id" class="border rounded px-2 py-1 w-full"></div>
      <div class="sm:col-span-2"><label class="block text-xs text-slate-500 mb-1">Description</label><textarea name="description" rows="2" class="border rounded px-2 py-1 w-full"></textarea></div>
      <div><button class="bg-slate-900 text-white px-4 py-1.5 rounded hover:bg-slate-700">Create product</button></div>
    </form>
  </details>

  <div class="space-y-3">
    {% for p in products %}
    {% set rule = rules_by_product[p.id] %}
    <div class="bg-white rounded-lg shadow p-4">
      <div class="flex items-start justify-between">
        <div>
          <span class="font-medium">{{ p.name }}</span>
          <span class="text-slate-400 text-sm">· {{ p.category.name if p.category else '—' }} · {{ p.durationLabel }}</span>
          {{ ui.status_badge('active' if p.isActive else 'inactive') }}
        </div>
        <div class="text-right text-sm">
          <div class="font-semibold">{{ p.price | money }} {{ currency }}</div>
          {% if p.resellerPrice %}<div class="text-slate-400 text-xs">reseller {{ p.resellerPrice | money }}</div>{% endif %}
        </div>
      </div>

      <div class="mt-3 flex flex-wrap gap-4 text-sm">
        <details>
          <summary class="cursor-pointer text-slate-700 hover:underline">Edit</summary>
          <form method="post" action="/catalog/product/{{ p.id }}/update" class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
            {{ ui.csrf_field(admin) }}
            <div><label class="block text-xs text-slate-500 mb-1">Name</label><input name="name" value="{{ p.name }}" required class="border rounded px-2 py-1 w-full"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Duration</label><input name="duration_label" value="{{ p.durationLabel }}" required class="border rounded px-2 py-1 w-full"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Price</label><input name="price" value="{{ p.price | money }}" required class="border rounded px-2 py-1 w-full"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Reseller price</label><input name="reseller_price" value="{{ p.resellerPrice | money if p.resellerPrice else '' }}" class="border rounded px-2 py-1 w-full"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Warranty days</label><input name="warranty_days" type="number" value="{{ p.warrantyDays }}" class="border rounded px-2 py-1 w-full"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Image file_id</label><input name="image_file_id" value="{{ p.imageFileId or '' }}" class="border rounded px-2 py-1 w-full"></div>
            <div class="sm:col-span-2"><label class="block text-xs text-slate-500 mb-1">Description</label><textarea name="description" rows="2" class="border rounded px-2 py-1 w-full">{{ p.description or '' }}</textarea></div>
            <label class="flex items-center gap-2 text-xs"><input type="checkbox" name="is_active" value="true" {% if p.isActive %}checked{% endif %}> Active</label>
            <div class="sm:col-span-2"><button class="bg-slate-900 text-white px-4 py-1.5 rounded hover:bg-slate-700">Save</button></div>
          </form>
        </details>

        <details>
          <summary class="cursor-pointer text-slate-700 hover:underline">Bulk pricing {% if rule %}({{ rule.minQuantity }}+ → {{ rule.discountPercent }}%){% endif %}</summary>
          <form method="post" action="/catalog/product/{{ p.id }}/bulk-pricing" class="mt-3 flex flex-wrap gap-3 items-end">
            {{ ui.csrf_field(admin) }}
            <div><label class="block text-xs text-slate-500 mb-1">Min qty</label><input name="min_quantity" type="number" value="{{ rule.minQuantity if rule else '' }}" class="border rounded px-2 py-1 w-24"></div>
            <div><label class="block text-xs text-slate-500 mb-1">Discount %</label><input name="discount_percent" value="{{ rule.discountPercent if rule else '' }}" class="border rounded px-2 py-1 w-24"></div>
            <button class="bg-slate-200 px-3 py-1.5 rounded hover:bg-slate-300">Save</button>
            <span class="text-xs text-slate-400">Leave min qty empty to remove.</span>
          </form>
        </details>

        <a href="/stock/{{ p.id }}" class="text-slate-700 hover:underline self-center">Stock →</a>
      </div>
    </div>
    {% else %}
    <p class="text-slate-400">No products yet.</p>
    {% endfor %}
  </div>
</section>
{% endblock %}
