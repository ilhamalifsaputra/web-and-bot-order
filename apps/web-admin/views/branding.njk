{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Branding · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Branding', "Your logo, hero image, bot banner, and shop identity text — all in one place.", 'image', 'settings') }}
{{ ui.flash(msg, kind) }}

<div class="space-y-6">

  {# ── Favicon ── #}
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="star" class="w-5 h-5 text-sky-500"></i> Favicon
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      Recommended 512×512 px, square. PNG, ICO, or SVG. Max 1 MB.
    </p>
    {% if favicon_url %}
    <div class="flex items-center gap-2 mb-3">
      <img src="{{ favicon_url }}" alt="Current favicon" class="w-12 h-12 rounded border border-sand object-contain bg-sand/40">
      <span class="text-xs text-ink-soft">Current favicon — uploading a new one will replace it.</span>
    </div>
    {% endif %}
    <form method="post" action="/branding/favicon" enctype="multipart/form-data" class="flex items-center gap-2">
      <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
      <input type="file" name="favicon" accept="image/png,image/x-icon,image/vnd.microsoft.icon,image/svg+xml" required
             class="field text-sm file:mr-2 file:btn file:btn-soft file:border-0 file:text-xs">
      <button class="btn btn-primary btn-sm whitespace-nowrap">Upload favicon</button>
    </form>
  </div>

  {# ── Hero ── #}
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="image" class="w-5 h-5 text-sky-500"></i> Hero image
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      Recommended 1600×900 px (16:9), landscape. JPG, PNG, or WebP. Max 5 MB.
    </p>
    {% if hero_url %}
    <div class="mb-3">
      <img src="{{ hero_url }}" alt="Current hero" class="max-w-xs w-full rounded-lg border border-sand object-cover">
      <p class="text-xs text-ink-soft mt-1">Current hero — uploading a new one will replace it.</p>
    </div>
    {% endif %}
    <form method="post" action="/branding/hero" enctype="multipart/form-data" class="flex items-center gap-2">
      <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
      <input type="file" name="hero" accept="image/jpeg,image/png,image/webp" required
             class="field text-sm file:mr-2 file:btn file:btn-soft file:border-0 file:text-xs">
      <button class="btn btn-primary btn-sm whitespace-nowrap">Upload hero</button>
    </form>
  </div>

  {# ── Bot banner ── #}
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="panel-top" class="w-5 h-5 text-sky-500"></i> Bot banner
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      Shown above the bot's main menu and product list. Recommended 1280×720 px (16:9). JPG, PNG, or WebP. Max 5 MB.
    </p>
    {% if banner_url %}
    <div class="mb-3">
      <img src="{{ banner_url }}" alt="Current banner" class="max-w-xs w-full rounded-lg border border-sand object-cover">
      <p class="text-xs text-ink-soft mt-1">Current banner — uploading a new one will replace it.</p>
    </div>
    {% endif %}
    {% if banner_is_legacy %}
    <p class="text-xs text-amberx mb-3">
      A banner is currently set from the bot (Telegram image). Uploading here replaces it.
    </p>
    {% endif %}
    <form method="post" action="/branding/banner" enctype="multipart/form-data" class="flex items-center gap-2">
      <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
      <input type="file" name="banner" accept="image/jpeg,image/png,image/webp" required
             class="field text-sm file:mr-2 file:btn file:btn-soft file:border-0 file:text-xs">
      <button class="btn btn-primary btn-sm whitespace-nowrap">Upload banner</button>
    </form>
    {% if banner_url or banner_is_legacy %}
    <form method="post" action="/branding/banner/clear" class="mt-2">
      <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
      <button class="btn btn-ghost btn-sm">Remove banner</button>
    </form>
    {% endif %}
  </div>

  {# ── Identity text ── #}
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="type" class="w-5 h-5 text-sky-500"></i> Shop identity
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      The name and tagline shown to customers, plus the bot's welcome message.
    </p>
    <div class="space-y-3">
      <form method="post" action="/branding/text" class="flex gap-2 items-end">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <input type="hidden" name="key" value="shop_name">
        <div class="flex-1">
          <label class="field-label">Shop name</label>
          <input type="text" name="value" value="{{ shop_name }}" class="field">
        </div>
        <button class="btn btn-soft">Save</button>
      </form>

      <form method="post" action="/branding/text" class="flex gap-2 items-end">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <input type="hidden" name="key" value="shop_tagline">
        <div class="flex-1">
          <label class="field-label">Shop tagline</label>
          <input type="text" name="value" value="{{ shop_tagline }}" class="field">
        </div>
        <button class="btn btn-soft">Save</button>
      </form>

      <form method="post" action="/branding/text" class="flex gap-2 items-end">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <input type="hidden" name="key" value="welcome">
        <div class="flex-1">
          <label class="field-label">Bot welcome message</label>
          <input type="text" name="value" value="{{ welcome }}" class="field">
        </div>
        <button class="btn btn-soft">Save</button>
      </form>
    </div>
  </div>

</div>
{% endblock %}
