{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Products · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Products', 'Group products into categories and set their prices.', 'package', 'products') }}
{{ ui.flash(msg, kind) }}

<!-- Categories -->
<section class="mb-10">
  <h2 class="section-title mb-3">Categories</h2>
  <div class="card overflow-x-auto mb-4">
    <table class="data-table">
      <thead>
        <tr><th>Name</th><th>Icon</th><th>Order</th><th>Shown to customers</th><th></th></tr>
      </thead>
      <tbody>
        {% for c in categories %}
        <tr>
          <td class="font-medium">{{ c.name }}</td>
          <td>{{ c.emoji or '—' }}</td>
          <td class="tabular">{{ c.sortOrder }}</td>
          <td>{{ ui.status_badge('active' if c.isActive else 'inactive') }}</td>
          <td class="text-right">
            <form method="post" action="/catalog/category/{{ c.id }}/toggle" class="inline">
              {{ ui.csrf_field(admin) }}
              <input type="hidden" name="is_active" value="{{ 'false' if c.isActive else 'true' }}">
              <button class="btn btn-soft btn-sm">{{ 'Hide' if c.isActive else 'Show' }}</button>
            </form>
          </td>
        </tr>
        {% else %}
        {{ ui.empty_row(5, 'No categories yet.') }}
        {% endfor %}
      </tbody>
    </table>
  </div>
  <details class="card card-pad">
    <summary class="cursor-pointer font-medium text-sm text-pine">+ Add a category</summary>
    <form method="post" action="/catalog/category" class="mt-4 flex flex-wrap gap-3 items-end">
      {{ ui.csrf_field(admin) }}
      <div><label class="field-label">Name</label><input name="name" required class="field"></div>
      <div><label class="field-label">Icon</label><input name="emoji" class="field w-20"></div>
      <div><label class="field-label">Order</label><input name="sort_order" type="number" value="0" class="field w-20"></div>
      <button class="btn btn-primary">Add</button>
    </form>
  </details>
</section>

<!-- Product groups (denominations) -->
<section class="mb-10">
  <h2 class="section-title mb-3">Product Groups (denominations)</h2>
  <div class="card overflow-x-auto mb-4">
    <table class="data-table">
      <thead>
        <tr><th>Group</th><th>Category</th><th>Members</th><th>Active</th><th></th></tr>
      </thead>
      <tbody>
        {% for g in groups %}
        <tr>
          <td class="font-medium">{{ g.emoji or '' }} {{ g.name }}</td>
          <td>{{ g.category.name if g.category else '—' }}</td>
          <td class="tabular">{{ g._count.products }}</td>
          <td>{{ ui.status_badge('active' if g.isActive else 'inactive') }}</td>
          <td class="text-right">
            <form method="post" action="/catalog/group/{{ g.id }}/delete" class="inline"
                  onsubmit="return confirm('Delete group? Products are kept.');">
              {{ ui.csrf_field(admin) }}
              <button class="btn btn-soft btn-sm">Delete</button>
            </form>
          </td>
        </tr>
        {% else %}
        {{ ui.empty_row(5, 'No product groups yet.') }}
        {% endfor %}
      </tbody>
    </table>
  </div>

  <details class="card card-pad mb-4">
    <summary class="cursor-pointer font-medium text-sm text-pine">+ Add a group</summary>
    <form method="post" action="/catalog/group" class="mt-4 flex flex-wrap gap-3 items-end">
      {{ ui.csrf_field(admin) }}
      <div><label class="field-label">Category</label>
        <select name="category_id" required class="field">
          {% for c in categories %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
        </select></div>
      <div><label class="field-label">Name</label><input name="name" required placeholder="e.g. Capcut" class="field"></div>
      <div><label class="field-label">Icon</label><input name="emoji" class="field w-20" placeholder="emoji (optional)"></div>
      <div><label class="field-label">Order</label><input name="sort_order" type="number" value="0" class="field w-20"></div>
      <button class="btn btn-primary">Add group</button>
    </form>
  </details>

  {% if groups %}
  <p class="text-xs text-ink-faint">Untuk memasukkan produk ke grup: buka produk di <b>Items for sale</b> → <b>Edit</b> → pilih <b>Group</b>.</p>
  {% endif %}
</section>

<!-- Products -->
<section>
  <h2 class="section-title mb-3">Items for sale</h2>

  <details class="card card-pad mb-4">
    <summary class="cursor-pointer font-medium text-sm text-pine">+ Add a product</summary>
    <form method="post" action="/catalog/product" class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {{ ui.csrf_field(admin) }}
      <div><label class="field-label">Category</label>
        <select name="category_id" required class="field">
          {% for c in categories %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
        </select></div>
      <div><label class="field-label">Kind</label>
        <select name="type" class="field">
          {% for t in product_types %}<option value="{{ t }}">{{ t | lower | title }}</option>{% endfor %}
        </select></div>
      <div><label class="field-label">Name</label><input name="name" required class="field"></div>
      <div><label class="field-label">Duration</label><input name="duration_label" required placeholder="1 Month" class="field"></div>
      <div><label class="field-label">Price (Rupiah)</label><input name="price" required class="field js-idr-price">
        <div class="text-xs text-ink-faint mt-1 js-usdt-preview"></div></div>
      <div><label class="field-label">Reseller price (Rupiah)</label><input name="reseller_price" class="field"></div>
      <div><label class="field-label">Warranty (days)</label><input name="warranty_days" type="number" class="field"></div>
      <div><label class="field-label">Bot photo ID (optional)</label><input name="image_file_id" class="field" placeholder="Telegram file_id"></div>
      <div><label class="field-label">Web photo URL (optional)</label><input name="web_image_url" type="url" placeholder="https://… (or upload after saving)" class="field"></div>
      <div class="sm:col-span-2"><label class="field-label">Description</label><textarea name="description" rows="2" class="field"></textarea></div>
      <div><button class="btn btn-primary">Add product</button></div>
    </form>
  </details>

  <details class="card card-pad mb-4">
    <summary class="cursor-pointer font-medium text-sm text-pine">⇪ Add many at once (from a list)</summary>
    <form method="post" action="/catalog/products/import" class="mt-4">
      {{ ui.csrf_field(admin) }}
      <p class="text-xs text-ink-soft mb-3">
        One product per line, separated by the "|" symbol. The <b>category</b> must already exist.<br>
        <code class="codeish">category | name | kind | duration | price | reseller price | warranty days | description</code><br>
        Required: category, name, kind (shared/private), duration, price. The rest are optional. You'll see a preview before anything is saved.
      </p>
      <textarea name="csv" rows="6" required class="field font-mono text-xs"
        placeholder="Streaming | Netflix 1 Month | shared | 1 Month | 5.00 | 4.00 | 30 | Shared profile"></textarea>
      <button type="submit" class="btn btn-soft mt-3">Preview →</button>
    </form>
  </details>

  {% if products %}
  <form id="bulk-products-form" method="post" action="/catalog/products/bulk" class="card p-3 mb-3 flex flex-wrap items-center gap-2 text-sm">
    {{ ui.csrf_field(admin) }}
    <input type="hidden" name="ids" id="bp-ids">
    <input type="hidden" name="action" id="bp-action">
    <label class="flex items-center gap-1 text-ink-soft"><input type="checkbox" onclick="document.querySelectorAll('.bp-cb').forEach(c=>c.checked=this.checked)"> Select all</label>
    <span class="text-line">·</span>
    <button type="button" onclick="bulkProducts('activate')" class="btn btn-soft btn-sm">Show selected</button>
    <button type="button" onclick="bulkProducts('deactivate')" class="btn btn-ghost btn-sm">Hide selected</button>
    <span class="text-line">·</span>
    <select name="mode" class="field w-auto py-1.5">
      <option value="set">Set price to</option>
      <option value="percent">Change by %</option>
    </select>
    <input type="text" name="value" id="bp-value" placeholder="e.g. 9.99 or -10" class="field w-28 py-1.5">
    <button type="button" onclick="bulkPriceProducts()" class="btn btn-soft btn-sm">Preview price →</button>
  </form>
  {% endif %}

  <div class="space-y-3">
    {% for p in products %}
    {% set rule = rules_by_product[p.id] %}
    <div class="card card-pad">
      <div class="flex items-start justify-between gap-3">
        <div class="flex items-start gap-2">
          <input type="checkbox" class="bp-cb mt-1" value="{{ p.id }}">
          <div>
            <span class="font-medium">{{ p.name }}</span>
            <span class="text-ink-faint text-sm">· {{ p.category.name if p.category else '—' }} · {{ p.durationLabel }} · #{{ p.id }}</span>
            {% if p.productGroup %}<span class="text-pine text-xs">· Grup: {{ p.productGroup.name }}</span>{% endif %}
            {{ ui.status_badge('active' if p.isActive else 'inactive') }}
          </div>
        </div>
        <div class="text-right text-sm">
          <div class="font-semibold tabular">{{ p.price | idr }}
            {% if usd_idr_rate %}<span class="text-ink-faint font-normal text-xs">≈ {{ p.price | usdt(usd_idr_rate) }}</span>{% endif %}</div>
          {% if p.resellerPrice %}<div class="text-ink-faint text-xs">reseller {{ p.resellerPrice | idr }}</div>{% endif %}
        </div>
      </div>

      <div class="mt-3 border-t border-line pt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm items-start">
        <details class="w-auto open:w-full open:order-last">
          <summary class="cursor-pointer link font-normal">Edit</summary>
          <form method="post" action="/catalog/product/{{ p.id }}/update" class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
            {{ ui.csrf_field(admin) }}
            <div><label class="field-label">Name</label><input name="name" value="{{ p.name }}" required class="field"></div>
            <div><label class="field-label">Duration</label><input name="duration_label" value="{{ p.durationLabel }}" required class="field"></div>
            <div><label class="field-label">Price (Rupiah)</label><input name="price" value="{{ p.price }}" required class="field js-idr-price">
              <div class="text-xs text-ink-faint mt-1 js-usdt-preview"></div></div>
            <div><label class="field-label">Reseller price (Rupiah)</label><input name="reseller_price" value="{{ p.resellerPrice or '' }}" class="field"></div>
            <div><label class="field-label">Warranty (days)</label><input name="warranty_days" type="number" value="{{ p.warrantyDays }}" class="field"></div>
            <div><label class="field-label">Bot photo ID</label><input name="image_file_id" value="{{ p.imageFileId or '' }}" class="field" placeholder="Telegram file_id (set from bot)"></div>
            <div>
              <label class="field-label">Web photo URL</label>
              <input name="web_image_url" type="url" value="{{ p.webImageUrl or '' }}" placeholder="https://… or upload below" class="field">
              <p class="text-xs text-ink-faint mt-0.5">Paste an external URL, or use the upload button below.</p>
            </div>
            <div><label class="field-label">Group (optional)</label>
              <select name="product_group_id" class="field">
                <option value="">— No group —</option>
                {% for g in groups %}{% if g.categoryId == p.categoryId %}
                <option value="{{ g.id }}" {% if p.productGroupId == g.id %}selected{% endif %}>{{ g.name }}</option>
                {% endif %}{% endfor %}
              </select>
              <p class="text-xs text-ink-faint mt-0.5">Kelompokkan denominasi (mis. semua varian Capcut) di bawah satu grup.</p></div>
            <div class="sm:col-span-2"><label class="field-label">Description</label><textarea name="description" rows="2" class="field">{{ p.description or '' }}</textarea></div>
            <label class="flex items-center gap-2 text-xs"><input type="checkbox" name="is_active" value="true" {% if p.isActive %}checked{% endif %}> Shown to customers</label>
            <div class="sm:col-span-2"><button class="btn btn-primary">Save changes</button></div>
          </form>
        </details>

        <details class="w-auto open:w-full open:order-last">
          <summary class="cursor-pointer link font-normal">Foto{% if p.webImageUrl %} ✓{% endif %}</summary>
          <div class="mt-3">
            {% if p.webImageUrl %}
            <div class="mb-2 flex items-center gap-3">
              <img src="{{ p.webImageUrl }}" alt="" class="w-16 h-16 object-cover rounded border border-sand">
              <span class="text-xs text-ink-soft">Current photo — uploading a new one will replace it.</span>
            </div>
            {% endif %}
            <form method="post" action="/catalog/product/{{ p.id }}/photo" enctype="multipart/form-data" class="flex items-center gap-2">
              <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
              <input type="file" name="photo" accept="image/jpeg,image/png,image/webp" required class="field text-sm file:mr-2 file:btn file:btn-soft file:border-0 file:text-xs">
              <button class="btn btn-soft btn-sm whitespace-nowrap">Upload</button>
            </form>
            <p class="text-xs text-ink-faint mt-1">JPG, PNG, or WebP · max 5 MB</p>
          </div>
        </details>

        <details class="w-auto open:w-full open:order-last">
          <summary class="cursor-pointer link font-normal">Quantity discount {% if rule %}({{ rule.minQuantity }}+ → {{ rule.discountPercent }}%){% endif %}</summary>
          <form method="post" action="/catalog/product/{{ p.id }}/bulk-pricing" class="mt-3 flex flex-wrap gap-3 items-end">
            {{ ui.csrf_field(admin) }}
            <div><label class="field-label">Buy at least</label><input name="min_quantity" type="number" value="{{ rule.minQuantity if rule else '' }}" class="field w-24"></div>
            <div><label class="field-label">Discount %</label><input name="discount_percent" value="{{ rule.discountPercent if rule else '' }}" class="field w-24"></div>
            <button class="btn btn-soft">Save</button>
            <span class="text-xs text-ink-faint self-center">Leave "buy at least" empty to remove.</span>
          </form>
        </details>

        <a href="/stock/{{ p.id }}" class="link self-center">Manage stock →</a>
      </div>
    </div>
    {% else %}
    <p class="text-ink-faint">No products yet.</p>
    {% endfor %}
  </div>
</section>

<script>
function selectedProductIds() {
  return [...document.querySelectorAll('.bp-cb:checked')].map(c => c.value);
}
function bulkProducts(action) {
  const ids = selectedProductIds();
  if (!ids.length) { alert('Select at least one product.'); return; }
  document.getElementById('bp-ids').value = ids.join(',');
  document.getElementById('bp-action').value = action;
  const f = document.getElementById('bulk-products-form');
  f.action = '/catalog/products/bulk';
  f.submit();
}
function bulkPriceProducts() {
  const ids = selectedProductIds();
  if (!ids.length) { alert('Select at least one product.'); return; }
  if (!document.getElementById('bp-value').value.trim()) { alert('Enter a price or percent value.'); return; }
  document.getElementById('bp-ids').value = ids.join(',');
  const f = document.getElementById('bulk-products-form');
  f.action = '/catalog/products/bulk-price';
  f.submit();
}

// Read-only USDT preview next to Rupiah price inputs — the same rounded figure
// customers see ($ = price / usd_idr_rate, nearest 0.1). Rate comes from
// Settings → Payments; no rate = no preview.
(function () {
  const rate = Number({{ usd_idr_rate | default("null") }});
  document.querySelectorAll('.js-idr-price').forEach((input) => {
    const out = input.parentElement.querySelector('.js-usdt-preview');
    if (!out) return;
    const update = () => {
      const idr = Number(String(input.value).replace(/[^\d.]/g, ''));
      out.textContent = rate > 0 && idr > 0
        ? 'Customers also see ≈ $' + (Math.round((idr / rate) * 10) / 10)
        : (rate > 0 ? '' : 'Set the USDT rate in Settings → Payments to show a USDT figure.');
    };
    input.addEventListener('input', update);
    update();
  });
})();
</script>
{% endblock %}
