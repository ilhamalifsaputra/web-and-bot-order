{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Customers · Shop Admin{% endblock %}

{% block content %}
<header class="mb-6">
  <h1 class="page-title flex items-center gap-2.5"><i data-lucide="users" class="w-7 h-7 text-emerald-500"></i> Customers</h1>
  <p class="page-lead">Find a customer to view their orders, wallet, and tickets.</p>
</header>
{{ ui.flash(msg, kind) }}

<form method="get" action="/users" class="card card-pad mb-6 flex gap-3 items-end">
  <div class="flex-1">
    <label class="field-label">Search by Telegram ID, username, or name</label>
    <input type="text" name="q" value="{{ q }}" class="field">
  </div>
  <button class="btn btn-primary"><i data-lucide="search" class="w-4 h-4"></i> Search</button>
</form>

{% if q %}
<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr><th>Name</th><th>Username</th><th>Telegram</th><th>Type</th><th>Blocked</th><th></th></tr>
    </thead>
    <tbody>
      {% for u in results %}
      <tr>
        <td>{{ u.fullName or '—' }}</td>
        <td>{{ u.username or '—' }}</td>
        <td class="font-mono text-xs">{{ u.telegramId or "—" }}</td>
        <td>{{ ui.status_badge(u.role) }}</td>
        <td>{% if u.banned %}<span class="chip bg-rust-tint text-rust-dark">Blocked</span>{% else %}<span class="text-ink-faint">—</span>{% endif %}</td>
        <td class="text-right"><a class="link" href="/users/{{ u.id }}">Open →</a></td>
      </tr>
      {% else %}
      {{ ui.empty_row(6, 'No customers match "' + q + '".') }}
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<p class="text-ink-faint">Type something above to find a customer.</p>
{% endif %}
{% endblock %}
