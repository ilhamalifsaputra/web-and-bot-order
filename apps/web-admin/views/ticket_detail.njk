{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Ticket #{{ ticket.id }} · Support{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="/support" class="text-sm text-slate-500 hover:underline">← Support</a>
  <h1 class="text-2xl font-semibold mt-1 flex items-center gap-3">Ticket #{{ ticket.id }} {{ ui.status_badge(ticket.status) }}</h1>
  {% if ticket_user %}
  <p class="text-slate-500 text-sm">from
    <a class="hover:underline" href="/users/{{ ticket_user.id }}">{{ ticket_user.fullName or ticket_user.username or ('tg:' + (ticket_user.telegramId | string)) }}</a>
  </p>
  {% endif %}
</div>
{{ ui.flash(msg, kind) }}

<div class="bg-white rounded-lg shadow p-5 mb-6">
  <div class="text-xs text-slate-400 mb-1">Original message · {{ ticket.createdAt | localdt }}</div>
  <p class="whitespace-pre-wrap text-sm">{{ ticket.message }}</p>
  {% if ticket.photoFileIds %}<p class="text-xs text-slate-400 mt-2 font-mono break-all">photos: {{ ticket.photoFileIds }}</p>{% endif %}
</div>

<div class="space-y-3 mb-6">
  {% for m in messages %}
  <div class="flex {% if (m.senderType | lower) == 'admin' %}justify-end{% endif %}">
    <div class="max-w-lg rounded-lg px-4 py-2 text-sm
      {% if (m.senderType | lower) == 'admin' %}bg-slate-900 text-white{% else %}bg-white shadow{% endif %}">
      <div class="text-xs opacity-60 mb-1">{{ m.senderType | lower }} · {{ m.createdAt | localdt }}</div>
      <p class="whitespace-pre-wrap">{{ m.content }}</p>
    </div>
  </div>
  {% else %}
  <p class="text-slate-400 text-sm">No thread messages yet.</p>
  {% endfor %}
</div>

{% if (ticket.status | lower) != 'closed' %}
<div class="bg-white rounded-lg shadow p-5">
  <h2 class="font-semibold mb-2">Reply</h2>
  <p class="text-xs text-amber-600 mb-3">Recorded for the thread only — the web app does not send Telegram messages, so this reply is not auto-delivered to the customer.</p>
  <form method="post" action="/support/{{ ticket.id }}/reply" class="space-y-2">
    {{ ui.csrf_field(admin) }}
    <textarea name="content" rows="3" required class="w-full border rounded px-3 py-2 text-sm"></textarea>
    <div class="flex gap-3">
      <button class="bg-slate-900 text-white px-4 py-2 rounded text-sm hover:bg-slate-700">Save reply</button>
    </div>
  </form>
  <form method="post" action="/support/{{ ticket.id }}/close" class="mt-3"
        onsubmit="return confirm('Close this ticket?');">
    {{ ui.csrf_field(admin) }}
    <button class="text-sm text-red-700 hover:underline">Close ticket</button>
  </form>
</div>
{% endif %}
{% endblock %}
