{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Reviews · Shop Admin{% endblock %}

{% block content %}
<header class="mb-6">
  <h1 class="page-title flex items-center gap-2.5"><i data-lucide="star" class="w-7 h-7 text-amber-500"></i> Reviews</h1>
  <p class="page-lead">What customers say about your products. Hide anything unfair or inappropriate.</p>
</header>
{{ ui.flash(msg, kind) }}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <aside class="space-y-4">
    <div class="card card-pad text-sm">
      <h2 class="section-title mb-3">Ratings by product</h2>
      <p class="text-xs text-ink-faint mb-2">Hidden reviews don't count toward the average.</p>
      <table class="data-table">
        <thead><tr><th>Product</th><th class="text-right">Avg</th><th class="text-right">Shown</th><th class="text-right">Hidden</th></tr></thead>
        <tbody>
          {% for s in summaries %}
          <tr>
            <td><a class="link font-normal" href="/reviews?product={{ s.productId }}">{{ s.productName }}</a></td>
            <td class="text-right tabular">{% if s.avg %}{{ s.avg | round(1) }}{% else %}—{% endif %}</td>
            <td class="text-right tabular text-ink-soft">{{ s.count }}</td>
            <td class="text-right tabular {% if s.hiddenCount %}text-rust{% else %}text-ink-faint{% endif %}">{{ s.hiddenCount }}</td>
          </tr>
          {% else %}
          {{ ui.empty_row(4, 'No reviews yet.') }}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </aside>

  <section class="lg:col-span-2 space-y-4">
    <form method="get" action="/reviews" class="card card-pad flex flex-wrap gap-3 items-end">
      <div>
        <label class="field-label">Product id</label>
        <input type="text" name="product" value="{{ f.product }}" class="field w-28">
      </div>
      <div>
        <label class="field-label">Show</label>
        <select name="hidden" class="field">
          <option value="" {% if f.hidden == '' %}selected{% endif %}>All</option>
          <option value="0" {% if f.hidden == '0' %}selected{% endif %}>Visible</option>
          <option value="1" {% if f.hidden == '1' %}selected{% endif %}>Hidden</option>
        </select>
      </div>
      <button class="btn btn-soft">Filter</button>
      <a href="/reviews" class="btn btn-ghost">Clear</a>
    </form>

    <div class="card divide-y divide-line">
      {% for r in reviews %}
      <div class="p-4 {% if r.hidden %}bg-rust-tint/30{% endif %}">
        <div class="flex items-start justify-between gap-3">
          <div>
            <div class="text-sm">
              <span class="font-medium text-amberx">{{ '★' * r.rating }}{{ '☆' * (5 - r.rating) }}</span>
              <span class="text-ink-soft">· {{ r.product.name }}</span>
              {% if r.hidden %}<span class="ml-1 chip bg-rust-tint text-rust-dark">Hidden</span>{% endif %}
            </div>
            <p class="text-sm text-ink mt-1">{{ r.comment or '(no comment)' }}</p>
            <p class="text-xs text-ink-faint mt-1">
              <a class="link font-normal" href="/users/{{ r.user.id }}">{{ r.user.fullName or r.user.username or (r.user.telegramId and ('Telegram ' + (r.user.telegramId | string))) or r.user.email or '—' }}</a>
              · {{ r.createdAt | localdt }}
            </p>
          </div>
          <form method="post" action="/reviews/{{ r.id }}/hide">
            {{ ui.csrf_field(admin) }}
            <input type="hidden" name="hidden" value="{{ 'false' if r.hidden else 'true' }}">
            {% if r.hidden %}
            <button class="btn btn-soft btn-sm whitespace-nowrap">Show again</button>
            {% else %}
            <button class="btn btn-danger btn-sm whitespace-nowrap">Hide</button>
            {% endif %}
          </form>
        </div>
      </div>
      {% else %}
      <div class="p-6 text-center text-ink-faint">No reviews match.</div>
      {% endfor %}
    </div>

    {% if has_next or page > 1 %}
    <div class="flex justify-between text-sm">
      {% if page > 1 %}<a class="link" href="/reviews?product={{ f.product }}&hidden={{ f.hidden }}&page={{ page - 1 }}">← Newer</a>{% else %}<span></span>{% endif %}
      {% if has_next %}<a class="link" href="/reviews?product={{ f.product }}&hidden={{ f.hidden }}&page={{ page + 1 }}">Older →</a>{% endif %}
    </div>
    {% endif %}
  </section>
</div>
{% endblock %}
