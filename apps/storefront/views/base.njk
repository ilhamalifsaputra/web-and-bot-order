<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}{{ shop_name }}{% endblock %}</title>
  {% block meta %}{% endblock %}
  <link rel="icon" href="{{ favicon_url }}">

  {# Design tokens + component classes come from the SHARED theme partial
     (packages/web-ui/views/_theme.njk) — identical to web-admin. #}
  {% include "_theme.njk" %}
</head>
<body class="min-h-screen flex flex-col"
      {% if customer %}hx-headers='{"x-csrf-token": "{{ customer.csrf }}"}'{% endif %}>

{% block nav %}
{# Shop header: brand · search · account · cart. Sticky like the admin nav. #}
<header class="sticky top-0 z-30 border-b border-line bg-card/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-4 px-4 lg:px-6">
    <a href="/" class="flex shrink-0 items-center gap-2 text-pine">
      {% if logo_url %}
      <img src="{{ logo_url }}" alt="{{ shop_name }}" class="h-7 w-auto max-w-[10rem] object-contain">
      {% else %}
      <i data-lucide="store" class="h-6 w-6"></i>
      {% endif %}
      <span class="text-lg font-display font-semibold text-ink">{{ shop_name }}</span>
    </a>

    <form method="get" action="/search" class="relative hidden flex-1 sm:block mx-4 max-w-xl">
      <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-faint"></i>
      <input type="search" name="q" value="{{ q }}" placeholder="{{ t('web.search_placeholder', lang) }}"
             class="h-10 w-full rounded-full border border-line bg-paper pl-9 pr-4 text-sm focus:border-pine focus:bg-card focus:outline-none focus:ring-2 focus:ring-pine-tint" aria-label="{{ t('web.search_placeholder', lang) }}">
    </form>

    <nav class="ml-auto flex items-center gap-1 text-sm text-ink-soft sm:ml-0">
      {# Language toggle #}
      {% set other_lang = 'en' if lang == 'id' else 'id' %}
      <a href="/lang?to={{ other_lang }}&back={{ path | default('/') | urlencode }}" class="hidden items-center gap-1 rounded-lg px-2.5 py-2 hover:bg-sand sm:flex uppercase" aria-label="{{ t('web.lang_label', lang) }}">
        <i data-lucide="globe" class="h-4 w-4"></i> {{ other_lang }}
      </a>

      {% if customer %}
      <a href="/account" class="flex items-center gap-1 rounded-lg px-2.5 py-2 hover:bg-sand {% if active_nav == '/account' %}text-pine{% endif %}">
        <i data-lucide="user" class="h-4 w-4"></i> <span class="hidden sm:inline">{{ t('web.nav_account', lang) }}</span>
      </a>
      {% else %}
      <a href="/login" class="flex items-center gap-1 rounded-lg px-2.5 py-2 hover:bg-sand">
        <i data-lucide="log-in" class="h-4 w-4"></i> <span class="hidden sm:inline">{{ t('web.nav_login', lang) }}</span>
      </a>
      {% endif %}

      <a href="/cart" class="flex items-center gap-1.5 rounded-full bg-pine-tint px-3 py-2 font-medium text-pine-dark hover:bg-pine-tint/80 relative" aria-label="{{ t('web.nav_cart', lang) }}">
        <i data-lucide="shopping-cart" class="h-4 w-4"></i> <span class="hidden sm:inline">{{ t('web.nav_cart', lang) }}</span>
        {% if cart_count and cart_count > 0 %}
        <span class="absolute -top-1 -right-1 flex h-4 min-w-[1rem] items-center justify-center rounded-full bg-pine px-1 text-[0.65rem] font-bold text-white">{{ cart_count }}</span>
        {% endif %}
      </a>
    </nav>
  </div>

  {# Mobile search — second row below the brand bar. #}
  <div class="sm:hidden border-t border-line px-4 py-2 bg-card">
    <form method="get" action="/search" class="relative">
      <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-faint"></i>
      <input type="search" name="q" value="{{ q }}" placeholder="{{ t('web.search_placeholder', lang) }}"
             class="h-10 w-full rounded-full border border-line bg-paper pl-9 pr-4 text-sm focus:border-pine focus:bg-card focus:outline-none focus:ring-2 focus:ring-pine-tint" aria-label="{{ t('web.search_placeholder', lang) }}">
    </form>
  </div>
</header>
{% endblock %}

<main class="max-w-6xl mx-auto px-4 py-8 lg:px-6 flex-1">
  {% block content %}{% endblock %}
</main>

<footer class="mt-16 border-t border-line bg-card">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-4 py-6 text-sm sm:flex-row lg:px-6">
    <span class="flex items-center gap-2 font-display font-semibold text-pine">
      <i data-lucide="store" class="h-5 w-5"></i> {{ shop_name }}
    </span>
    <span class="text-ink-faint text-xs sm:text-sm">{{ t('web.footer_note', lang) }}</span>
  </div>
</footer>

<script>
  // Render Lucide icons on load, and again after HTMX swaps content.
  function renderIcons() { if (window.lucide) window.lucide.createIcons(); }
  renderIcons();
  document.addEventListener('htmx:afterSettle', renderIcons);
</script>

<script>
  // M-1 (execution/04): guard checkout/pay forms against double-submit. Pure
  // progressive enhancement — with JS off the form posts normally. The first
  // submit goes through; we then disable the clicked button and show a spinner,
  // and block any further submit of the same form until the page navigates.
  document.addEventListener('submit', function (e) {
    var form = e.target;
    if (!form || !form.matches || !form.matches('form[data-submit-once]')) return;
    if (form.dataset.submitting === '1') { e.preventDefault(); return; }
    form.dataset.submitting = '1';
    var btn = e.submitter;
    if (!btn) return;
    // Defer so the submitter's name/value is still included in the POST body.
    setTimeout(function () {
      btn.disabled = true;
      btn.setAttribute('aria-busy', 'true');
      btn.classList.add('opacity-70', 'cursor-wait');
      var spin = document.createElement('span');
      spin.setAttribute('aria-hidden', 'true');
      spin.className = 'inline-block w-3.5 h-3.5 mr-1.5 align-[-2px] rounded-full border-2 border-current border-r-transparent animate-spin';
      btn.prepend(spin);
    }, 0);
  });
</script>

</body>
</html>
