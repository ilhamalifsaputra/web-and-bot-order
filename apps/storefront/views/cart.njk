{% extends "base.njk" %}
{% import "_shop.njk" as shop %}

{% block title %}{{ t('web.cart_title', lang) }} — {{ shop_name }}{% endblock %}

{% block content %}
{{ shop.stepper(1, lang) }}
<h1 class="page-title !text-2xl mb-5">{{ t('web.cart_title', lang) }}{% if cart_count %} ({{ cart_count }}){% endif %}</h1>

{% if items.length %}
<div class="grid lg:grid-cols-3 gap-6 items-start">
  {# Lines #}
  <div class="lg:col-span-2 card divide-y divide-line">
    {% for item in items %}
    <div class="p-4 flex items-center gap-3 sm:gap-4">
      <a href="/p/{{ item.product_id }}" class="w-16 h-16 rounded-xl overflow-hidden bg-sand shrink-0">
        <img src="{{ item.image }}" alt="{{ item.name }}" loading="lazy" class="w-full h-full object-cover">
      </a>
      <div class="flex-1 min-w-0">
        <a href="/p/{{ item.product_id }}" class="font-display text-sm font-semibold text-ink hover:text-pine line-clamp-2">{{ item.name }}</a>
        <div class="mt-1">{{ shop.price(item.unit_price, fx, "text-sm") }}</div>
        {% if item.qty > item.available %}
        <div class="text-xs text-rust mt-1">{{ t('web.stock_left', lang, { count: item.available }) }}</div>
        {% endif %}
      </div>
      <form method="post" action="/cart/update" class="flex items-center gap-1.5">
        {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
        <input type="hidden" name="key" value="{{ item.key }}">
        <input type="number" name="qty" value="{{ item.qty }}" min="0" max="99"
               class="field !w-16 text-center" aria-label="{{ t('web.qty', lang) }}">
        <button type="submit" class="btn btn-ghost btn-sm" aria-label="{{ t('web.update', lang) }}">
          <i data-lucide="refresh-cw" class="w-4 h-4"></i>
        </button>
      </form>
      <form method="post" action="/cart/remove">
        {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
        <input type="hidden" name="key" value="{{ item.key }}">
        <button type="submit" class="btn btn-ghost btn-sm text-rust" aria-label="{{ t('web.remove', lang) }}">
          <i data-lucide="trash-2" class="w-4 h-4"></i>
        </button>
      </form>
    </div>
    {% endfor %}
  </div>

  {# Summary #}
  <div class="card card-pad">
    <h2 class="section-title mb-3">{{ t('web.summary', lang) }}</h2>
    <div class="flex items-center justify-between text-sm py-1.5">
      <span class="text-ink-soft">{{ t('web.subtotal', lang) }}</span>
      {{ shop.price(subtotal, fx, "text-sm") }}
    </div>
    <p class="text-xs text-ink-faint mt-1">{{ t('web.discounts_at_checkout', lang) }}</p>
    <a href="/checkout" class="btn btn-primary w-full mt-4">
      {{ t('web.to_checkout', lang) }} <i data-lucide="chevron-right" class="w-4 h-4"></i>
    </a>
    {% if not customer %}
    <p class="text-xs text-ink-faint mt-3">{{ t('web.login_to_checkout', lang) }}</p>
    {% endif %}
  </div>
</div>
{% else %}
<div class="card card-pad text-center py-14">
  <i data-lucide="shopping-cart" class="w-10 h-10 text-ink-faint mx-auto mb-3"></i>
  <p class="text-ink-soft">{{ t('web.cart_empty', lang) }}</p>
  <a href="/" class="btn btn-primary mt-4">{{ t('web.hero_cta', lang) }}</a>
</div>
{% endif %}
{% endblock %}
