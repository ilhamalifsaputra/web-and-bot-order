{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Products · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Products', 'Atur kategori dan produk. Harga & stok diatur per denominasi di dalam tiap produk.', 'package', 'products') }}
{{ ui.flash(msg, kind) }}

<!-- Categories -->
<section class="mb-10">
  <h2 class="section-title mb-3">Categories</h2>
  <div class="card overflow-x-auto mb-4">
    <table class="data-table">
      <thead>
        <tr><th>Name</th><th>Icon</th><th>Order</th><th>Shown to customers</th><th></th></tr>
      </thead>
      <tbody>
        {% for c in categories %}
        <tr>
          <td class="font-medium">{{ c.name }}</td>
          <td>{{ c.emoji or '—' }}</td>
          <td class="tabular">{{ c.sortOrder }}</td>
          <td>{{ ui.status_badge('active' if c.isActive else 'inactive') }}</td>
          <td class="text-right">
            {% call ui.dropdown('', 'ellipsis-vertical') %}
            <form method="post" action="/catalog/category/{{ c.id }}/update" class="flex flex-col gap-2 px-3 py-2 w-64">
              {{ ui.csrf_field(admin) }}
              <input name="name" value="{{ c.name }}" required class="field text-xs" placeholder="Name">
              <input name="emoji" value="{{ c.emoji or '' }}" class="field text-xs" placeholder="Icon">
              <textarea name="description" rows="2" class="field text-xs" placeholder="Description">{{ c.description or '' }}</textarea>
              <input name="image" value="{{ c.image or '' }}" class="field text-xs" placeholder="Image URL">
              <input name="sort_order" type="number" value="{{ c.sortOrder }}" class="field text-xs" placeholder="Order">
              <label class="flex items-center gap-2 text-xs"><input type="checkbox" name="is_active" value="true" {% if c.isActive %}checked{% endif %}> Shown to customers</label>
              <button class="btn btn-soft btn-sm">Save</button>
            </form>
            <form method="post" action="/catalog/category/{{ c.id }}/toggle" class="px-3 py-2 border-t border-line">
              {{ ui.csrf_field(admin) }}
              <input type="hidden" name="is_active" value="{{ 'false' if c.isActive else 'true' }}">
              <button class="btn btn-ghost btn-sm w-full">{{ 'Hide' if c.isActive else 'Show' }}</button>
            </form>
            {% endcall %}
          </td>
        </tr>
        {% else %}
        {{ ui.empty_row(5, 'No categories yet.') }}
        {% endfor %}
      </tbody>
    </table>
  </div>
  <details class="card card-pad group">
    <summary class="cursor-pointer select-none font-medium text-sm text-ink-soft flex items-center gap-1.5 list-none">
      <i data-lucide="chevron-right" class="w-4 h-4 transition-transform group-open:rotate-90"></i>
      <i data-lucide="plus" class="w-4 h-4 text-pine"></i> Add a category</summary>
    <form method="post" action="/catalog/category" class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {{ ui.csrf_field(admin) }}
      <div><label class="field-label">Name</label><input name="name" required class="field"></div>
      <div><label class="field-label">Icon</label><input name="emoji" class="field w-20"></div>
      <div><label class="field-label">Order</label><input name="sort_order" type="number" value="0" class="field w-20"></div>
      <div><label class="field-label">Image URL (optional)</label><input name="image" type="url" class="field"></div>
      <div class="sm:col-span-2"><label class="field-label">Description (optional)</label><textarea name="description" rows="2" class="field"></textarea></div>
      <div><button class="btn btn-primary">Add</button></div>
    </form>
  </details>
</section>

<!-- Products -->
<section>
  <h2 class="section-title mb-3">Products</h2>

  <details class="card card-pad mb-4 group">
    <summary class="cursor-pointer select-none font-medium text-sm text-ink-soft flex items-center gap-1.5 list-none">
      <i data-lucide="chevron-right" class="w-4 h-4 transition-transform group-open:rotate-90"></i>
      <i data-lucide="plus" class="w-4 h-4 text-pine"></i> Add a product</summary>
    <form method="post" action="/catalog/product" class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {{ ui.csrf_field(admin) }}
      <div><label class="field-label">Category</label>
        <select name="category_id" required class="field">
          {% for c in categories %}<option value="{{ c.id }}">{{ c.name }}</option>{% endfor %}
        </select></div>
      <div><label class="field-label">Name</label><input name="name" required placeholder="e.g. CapCut Pro" class="field"></div>
      <div><label class="field-label">Icon (optional)</label><input name="emoji" class="field w-20"></div>
      <div><label class="field-label">Order</label><input name="sort_order" type="number" value="0" class="field w-20"></div>
      <div><label class="field-label">Bot photo ID (optional)</label><input name="image_file_id" class="field" placeholder="Telegram file_id"></div>
      <div><label class="field-label">Web photo URL (optional)</label><input name="web_image_url" type="url" placeholder="https://… (or upload after saving)" class="field"></div>
      <div class="sm:col-span-2"><label class="field-label">Description</label><textarea name="description" rows="2" class="field"></textarea></div>
      <div><button class="btn btn-primary">Add product</button></div>
    </form>
  </details>

  <details class="card card-pad mb-4 group">
    <summary class="cursor-pointer select-none font-medium text-sm text-ink-soft flex items-center gap-1.5 list-none">
      <i data-lucide="chevron-right" class="w-4 h-4 transition-transform group-open:rotate-90"></i>
      <i data-lucide="upload" class="w-4 h-4 text-pine"></i> Add many at once (from a list)</summary>
    <form method="post" action="/catalog/products/import" class="mt-4">
      {{ ui.csrf_field(admin) }}
      <p class="text-xs text-ink-soft mb-3">
        One denomination per line, separated by the "|" symbol. The <b>category</b> must already exist; the
        <b>product</b> is created automatically if it doesn't exist yet.<br>
        <code class="codeish">category | product | denomination | kind | duration | price | cost | reseller price | warranty days | description</code><br>
        Required: category, product, denomination, kind (shared/private), duration, price. The rest are optional.
        You'll see a preview before anything is saved.
      </p>
      <textarea name="csv" rows="6" required class="field font-mono text-xs"
        placeholder="Streaming | Netflix Premium | 1 Month | shared | 1 Month | 5.00 | 3.00 | 4.00 | 30 | Shared profile"></textarea>
      <button type="submit" class="btn btn-soft mt-3"><i data-lucide="eye" class="w-4 h-4"></i> Preview</button>
    </form>
  </details>

  {% if products %}
  <form id="bulk-products-form" method="post" action="/catalog/products/bulk" class="card p-3 mb-3 flex flex-wrap items-center gap-2 text-sm">
    {{ ui.csrf_field(admin) }}
    <input type="hidden" name="ids" id="bp-ids">
    <input type="hidden" name="action" id="bp-action">
    <label class="flex items-center gap-1 text-ink-soft"><input type="checkbox" onclick="document.querySelectorAll('.bp-cb').forEach(c=>c.checked=this.checked)"> Select all</label>
    <span class="text-line">·</span>
    <button type="button" onclick="bulkProducts('activate')" class="btn btn-soft btn-sm">Show selected</button>
    <button type="button" onclick="bulkProducts('deactivate')" class="btn btn-ghost btn-sm">Hide selected</button>
  </form>
  {% endif %}

  <div class="space-y-3">
    {% for p in products %}
    <div class="card card-pad flex items-start justify-between gap-3">
      <div class="flex items-start gap-3 min-w-0">
        <input type="checkbox" class="bp-cb mt-1.5" value="{{ p.id }}">
        {% if p.webImageUrl %}<img src="{{ p.webImageUrl }}" alt="" class="w-11 h-11 rounded-lg object-cover border border-sand shrink-0">{% endif %}
        <div class="min-w-0">
          <div class="font-medium text-ink truncate">{{ p.emoji or '' }} {{ p.name }}</div>
          <div class="flex flex-wrap items-center gap-2 mt-1.5">
            {{ ui.status_badge('active' if p.isActive else 'inactive') }}
            <span class="text-ink-faint text-xs">{{ p.category.name if p.category else '—' }} · #{{ p.id }}</span>
            {{ ui.badge(p._count.denominations ~ ' denomination' ~ ('s' if p._count.denominations != 1), 'info') }}
          </div>
        </div>
      </div>
      <div class="flex flex-col items-end gap-2 shrink-0">
        {{ ui.btn('Manage', 'sliders-horizontal', 'soft', href='/catalog/product/' ~ p.id, cls='btn-sm') }}
      </div>
    </div>
    {% else %}
    <p class="text-ink-faint">No products yet.</p>
    {% endfor %}
  </div>
</section>

<script>
function selectedProductIds() {
  return [...document.querySelectorAll('.bp-cb:checked')].map(c => c.value);
}
function bulkProducts(action) {
  const ids = selectedProductIds();
  if (!ids.length) { alert('Select at least one product.'); return; }
  document.getElementById('bp-ids').value = ids.join(',');
  document.getElementById('bp-action').value = action;
  const f = document.getElementById('bulk-products-form');
  f.action = '/catalog/products/bulk';
  f.submit();
}
</script>
{% endblock %}
