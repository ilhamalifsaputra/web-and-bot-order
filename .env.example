# Copy to .env and fill in real values. NEVER commit .env.
# The Node services read DATABASE_URL_PRISMA; the legacy Python stack reads DATABASE_URL.

# ---------------------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------------------
BOT_TOKEN=123456:your-bot-token
BOT_USERNAME=YourBot
ADMIN_IDS=11111111,22222222
# SUPPORT_GROUP_ID=-1001234567890

# ---------------------------------------------------------------------
# PAYMENT — Binance Pay (existing, manual proof + admin approval)
# ---------------------------------------------------------------------
BINANCE_PAY_ID=123456789
# BINANCE_QR_PATH=
CURRENCY=USDT
PAYMENT_WINDOW_MINUTES=30
USE_UNIQUE_CENTS=1

# ---------------------------------------------------------------------
# PAYMENT — Binance Internal Transfer (UID-based, auto-confirmed)
# Leave the API key/secret + UID blank to hide this option and disable the
# poller. The API key MUST be READ-ONLY (no trading/withdrawal permissions).
# ---------------------------------------------------------------------
BINANCE_RECEIVE_UID=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
POLL_INTERVAL_SECONDS=10
INTERNAL_PAYMENT_WINDOW_MINUTES=15
# Optional: show an IDR equivalent on the instructions (USDT * rate).
# USDT_IDR_RATE=16300

# ---------------------------------------------------------------------
# PAYMENT — Bybit USDT-BSC deposit (on-chain, auto-confirmed by unique amount)
# These three (address + API key/secret) can ALSO be set in web-admin → Settings,
# which TAKE PRECEDENCE over these env values (env is the bootstrap/recovery
# fallback). Leave all blank here AND in Settings to hide the option + idle the
# poller. The API key MUST be Wallet-READ-ONLY (no Withdraw). BEP20 has no memo,
# so matching is by the order's unique amount — keep USE_UNIQUE_CENTS=1.
# Reuses POLL_INTERVAL_SECONDS above. Probe first: pnpm bybit-probe
# ---------------------------------------------------------------------
BYBIT_DEPOSIT_ADDRESS=
BYBIT_DEPOSIT_CHAIN=BSC
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_API_BASE=https://api.bybit.com
BYBIT_PAYMENT_WINDOW_MINUTES=30

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------
# Prisma (file: URL; in Docker use an absolute path file:/app/data/bot.db).
DATABASE_URL_PRISMA=file:../data/bot.db

# ---------------------------------------------------------------------
# BEHAVIOUR / TUNING
# ---------------------------------------------------------------------
DEFAULT_LANGUAGE=en
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3
REFERRAL_COMMISSION_PERCENT=10
DEFAULT_WARRANTY_DAYS=30
LOW_STOCK_THRESHOLD=3
TIMEZONE=Asia/Jakarta

# ---------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------
# debug | info | warn | error  (lowercase)
LOG_LEVEL=info

# ---------------------------------------------------------------------
# WEB ADMIN
# ---------------------------------------------------------------------
# WAJIB: minimal 32 karakter acak. Bikin nilai acak:
#   - Linux/Mac/Git-Bash: openssl rand -hex 32
#   - Atau ketik asal-asalan >32 huruf/angka. Jangan pernah dibagikan.
WEB_COOKIE_SECRET=change-me-to-a-random-string-of-at-least-32-characters
WEB_COOKIE_NAME=stockweb_session
WEB_SESSION_TTL_HOURS=12
WEB_HOST=127.0.0.1
WEB_PORT=8000
# Set true di PRODUKSI (di balik HTTPS) supaya cookie sesi tidak bocor lewat
# koneksi http biasa. Biarkan false saat tes lokal di http://127.0.0.1.
WEB_COOKIE_SECURE=false

# ---------------------------------------------------------------------
# STOREFRONT (toko web pelanggan)
# ---------------------------------------------------------------------
# Dua cara menyajikan toko + admin:
#  (a) Satu domain berbeda subdomain (cocok untuk Hostinger Passenger 1-port):
#      isi SHOP_HOST = host toko. Request ke host itu -> toko; selain itu -> admin.
#  (b) Tanpa SHOP_HOST: toko jalan di port terpisah STOREFRONT_PORT (dev/VPS).
# SHOP_HOST=shop.domainkamu.com
# SHOP_PUBLIC_URL=https://shop.domainkamu.com   # untuk link di DM pelanggan
STOREFRONT_PORT=8100

# ---------------------------------------------------------------------
# SERVER GABUNGAN (apps/server) — transport bot
# ---------------------------------------------------------------------
# polling (default) = bot long-polling, TIDAK butuh domain/HTTPS untuk bot.
# webhook           = bot jadi route di Fastify yang sama (butuh PUBLIC_URL +
#                     WEBHOOK_SECRET). Dipakai di managed hosting (Passenger).
BOT_MODE=polling
# PUBLIC_URL=https://app.domainkamu.com    # WAJIB jika BOT_MODE=webhook (tanpa / di akhir)
# WEBHOOK_SECRET=string-acak-panjang        # WAJIB jika BOT_MODE=webhook; jangan dibagikan

# ---------------------------------------------------------------------
# NOTIFIER (channel testimoni publik)
# ---------------------------------------------------------------------
# NOTIF_BOT_TOKEN & PUBLIC_CHANNEL_ID kini bisa diisi di web admin
# (Settings → Bot & notifications). Untuk channel, tempel link t.me/… atau
# @username — otomatis di-resolve jadi ID numerik. NOTIF_BOT_TOKEN opsional:
# kosong = pakai bot utama (harus jadi admin channel). Baris di bawah hanya
# fallback bootstrap sampai baris Settings dibuat.
# NOTIF_BOT_TOKEN=
# PUBLIC_CHANNEL_ID=-100...
NOTIF_POLL_INTERVAL_SECONDS=10
NOTIF_MAX_ATTEMPTS=5

# ---------------------------------------------------------------------
# EMAIL / SMTP — hanya untuk fitur "lupa password" di toko (storefront)
# ---------------------------------------------------------------------
# Aktif hanya bila SMTP_HOST dan SMTP_FROM terisi. Kalau kosong, fitur lupa
# password lewat email mati (admin tetap bisa reset lewat Telegram/CLI).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=akun@gmail.com
# SMTP_PASS=app-password-16-digit
# SMTP_FROM=Toko Kamu <akun@gmail.com>
# SMTP_SECURE=false

# ---------------------------------------------------------------------
# DIATUR DARI WEB-ADMIN (Settings), BUKAN di sini:
#   - TokoPay (QRIS Rupiah): tokopay_merchant_id, tokopay_secret, tokopay_enabled
#   - Kurs USDT->IDR: usd_idr_rate (+ auto-update), usd_idr_rate_rounding
#   - Token bot & notifier juga BISA dipindah ke Settings (DB menang atas env)
# Lihat DOCS.md untuk detailnya.
# ---------------------------------------------------------------------
