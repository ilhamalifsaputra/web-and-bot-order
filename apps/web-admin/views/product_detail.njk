{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}{{ product.name }} · Product{% endblock %}

{% set return_to = '/catalog/product/' + product.id | string %}

{% block content %}
<div class="mb-5">
  {{ ui.btn('Products', 'arrow-left', 'ghost', href='/catalog', cls='btn-sm') }}
</div>

{# ── Header: title + identity badges on the left, price card on the right ──── #}
<header class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
  <div class="min-w-0">
    <h1 class="font-display text-3xl font-semibold tracking-tight text-ink flex items-center gap-2.5">
      <i data-lucide="package" class="w-7 h-7 text-violet-500 shrink-0"></i>
      <span class="truncate">{{ product.name }}</span>
    </h1>
    <div class="flex flex-wrap items-center gap-2 mt-3">
      {{ ui.badge('#' + product.id | string, 'neutral') }}
      {{ ui.badge(product.type | lower | title, 'info') }}
      {% if product.durationLabel %}{{ ui.badge(product.durationLabel, 'neutral') }}{% endif %}
      {% if product.productGroup %}{{ ui.badge('Denominasi: ' + product.productGroup.name, 'info') }}{% endif %}
      {{ ui.status_badge('active' if product.isActive else 'inactive') }}
    </div>
    <p class="page-lead mt-2">{{ product.category.name if product.category else 'Uncategorized' }}</p>
  </div>

  <div class="card card-pad w-full lg:w-72 shrink-0">
    <div class="stat-label">Price</div>
    <div class="stat-value tabular">{{ product.price | idr }}</div>
    {% if usd_idr_rate %}<div class="stat-sub">Customers also see ≈ {{ product.price | usdt(usd_idr_rate) }}</div>{% endif %}
    {% if product.resellerPrice %}
    {{ ui.separator('!my-3') }}
    <div class="flex items-center justify-between text-sm">
      <span class="text-ink-soft">Reseller</span>
      <span class="font-semibold tabular">{{ product.resellerPrice | idr }}</span>
    </div>
    {% endif %}
    <div class="flex items-center justify-between text-sm mt-2">
      <span class="text-ink-soft">Ready to sell</span>
      <span class="font-semibold tabular">{{ available }}</span>
    </div>
  </div>
</header>

{{ ui.flash(msg, kind) }}

{# ── Tabs ──────────────────────────────────────────────────────────────────── #}
{{ ui.tabs('product', [
  { key: 'general',   label: 'General',   icon: 'sliders-horizontal' },
  { key: 'photos',    label: 'Photos',    icon: 'image' },
  { key: 'discounts', label: 'Discounts', icon: 'ticket-percent' },
  { key: 'inventory', label: 'Inventory', icon: 'boxes' }
]) }}

{# General #}
{% call ui.tab_panel('product', 'general', first=true) %}
<form method="post" action="/catalog/product/{{ product.id }}/update" class="card card-pad grid grid-cols-1 sm:grid-cols-2 gap-4">
  {{ ui.csrf_field(admin) }}
  <input type="hidden" name="return_to" value="{{ return_to }}">
  <div><label class="field-label">Name</label><input name="name" value="{{ product.name }}" required class="field"></div>
  <div><label class="field-label">Duration</label><input name="duration_label" value="{{ product.durationLabel }}" required class="field"></div>
  <div><label class="field-label">Price (Rupiah)</label><input name="price" value="{{ product.price }}" required class="field js-idr-price">
    <div class="text-xs text-ink-faint mt-1 js-usdt-preview"></div></div>
  <div><label class="field-label">Reseller price (Rupiah)</label><input name="reseller_price" value="{{ product.resellerPrice or '' }}" class="field"></div>
  <div><label class="field-label">Warranty (days)</label><input name="warranty_days" type="number" value="{{ product.warrantyDays }}" class="field"></div>
  <div><label class="field-label">Denominasi (opsional)</label>
    <select name="product_group_id" class="field">
      <option value="">— Tanpa denominasi —</option>
      {% for g in groups %}{% if g.categoryId == product.categoryId %}
      <option value="{{ g.id }}" {% if product.productGroupId == g.id %}selected{% endif %}>{{ g.name }}</option>
      {% endif %}{% endfor %}
    </select>
    <p class="text-xs text-ink-faint mt-1">Kelompokkan varian/denominasi (mis. semua varian Capcut) di bawah satu denominasi.</p></div>
  <div><label class="field-label">Bot photo ID</label><input name="image_file_id" value="{{ product.imageFileId or '' }}" class="field" placeholder="Telegram file_id (set from bot)"></div>
  <div class="sm:col-span-2"><label class="field-label">Description</label><textarea name="description" rows="3" class="field">{{ product.description or '' }}</textarea></div>
  <label class="flex items-center gap-2 text-sm sm:col-span-2"><input type="checkbox" name="is_active" value="true" {% if product.isActive %}checked{% endif %}> Shown to customers</label>
  <div class="sm:col-span-2">{{ ui.btn('Save changes', 'save', 'primary') }}</div>
</form>
{% endcall %}

{# Photos #}
{% call ui.tab_panel('product', 'photos') %}
<div class="card card-pad space-y-4">
  <div>
    <h2 class="section-title">Web photo</h2>
    <p class="text-sm text-ink-soft mt-1">Shown on the storefront. Uploading a new one replaces the current image.</p>
  </div>
  {{ ui.dropzone('photo', '/catalog/product/' + product.id | string + '/photo', admin.csrf, current_url=product.webImageUrl, return_to=return_to) }}
  <div>
    <label class="field-label">Or paste an external URL</label>
    <form method="post" action="/catalog/product/{{ product.id }}/update" class="flex flex-wrap items-end gap-2">
      {{ ui.csrf_field(admin) }}
      <input type="hidden" name="return_to" value="{{ return_to }}">
      {# Re-send the required fields so the update validates and nothing else changes. #}
      <input type="hidden" name="name" value="{{ product.name }}">
      <input type="hidden" name="duration_label" value="{{ product.durationLabel }}">
      <input type="hidden" name="price" value="{{ product.price }}">
      <input type="hidden" name="reseller_price" value="{{ product.resellerPrice or '' }}">
      <input type="hidden" name="warranty_days" value="{{ product.warrantyDays }}">
      <input type="hidden" name="image_file_id" value="{{ product.imageFileId or '' }}">
      <input type="hidden" name="description" value="{{ product.description or '' }}">
      {% if product.isActive %}<input type="hidden" name="is_active" value="true">{% endif %}
      <input name="web_image_url" type="url" value="{{ product.webImageUrl or '' }}" placeholder="https://…" class="field flex-1 min-w-[16rem]">
      {{ ui.btn('Save URL', 'link', 'soft', cls='btn-sm') }}
    </form>
  </div>
</div>
{% endcall %}

{# Discounts #}
{% call ui.tab_panel('product', 'discounts') %}
<div class="card card-pad">
  <div class="flex items-center justify-between gap-3 mb-4">
    <h2 class="section-title">Quantity discount</h2>
    {% if rule %}{{ ui.badge(rule.minQuantity | string + '+ → ' + rule.discountPercent | string + '%', 'success') }}{% endif %}
  </div>
  <form method="post" action="/catalog/product/{{ product.id }}/bulk-pricing" class="flex flex-wrap gap-3 items-end">
    {{ ui.csrf_field(admin) }}
    <input type="hidden" name="return_to" value="{{ return_to }}">
    <div><label class="field-label">Buy at least</label><input name="min_quantity" type="number" value="{{ rule.minQuantity if rule else '' }}" class="field w-28"></div>
    <div><label class="field-label">Discount %</label><input name="discount_percent" value="{{ rule.discountPercent if rule else '' }}" class="field w-28"></div>
    {{ ui.btn('Save', 'save', 'primary') }}
    <span class="text-xs text-ink-faint self-center">Leave "buy at least" empty to remove the rule.</span>
  </form>
</div>
{% endcall %}

{# Inventory #}
{% call ui.tab_panel('product', 'inventory') %}
<div class="space-y-5">
  <section class="card card-pad">
    <div class="flex items-center justify-between gap-3 mb-2">
      <h2 class="section-title">Add stock</h2>
      {% if available %}{{ ui.btn('Download remaining (' + available | string + ')', 'download', 'soft', href='/stock/' + product.id | string + '/download', cls='btn-sm') }}{% endif %}
    </div>
    {% if waiting %}
    <p class="text-sm mb-3 text-amberx bg-amberx-tint border border-amberx/30 rounded-xl px-3 py-2">
      <strong>{{ waiting }}</strong> customer{{ 's' if waiting != 1 }} waiting on restock — they'll be notified automatically once you add stock.
    </p>
    {% endif %}
    <p class="text-xs text-ink-soft mb-3">One login per line, for example <code class="codeish">email:password</code> or <code class="codeish">email|password|extra</code>.</p>
    <form method="post" action="/stock/{{ product.id }}/add">
      {{ ui.csrf_field(admin) }}
      <input type="hidden" name="return_to" value="{{ return_to }}">
      <textarea name="credentials" rows="6" required class="field font-mono text-sm"
        placeholder="user1@example.com:pass1&#10;user2@example.com:pass2"></textarea>
      <div class="mt-3">{{ ui.btn('Add stock', 'plus', 'primary') }}</div>
    </form>
  </section>

  {% if items %}
  {# No form-level data-confirm: each button carries its own message, and the
     inline onsubmit collects the selected ids (admin-ui.js confirms first, then
     requestSubmit re-runs onsubmit to populate the hidden field). #}
  <form id="bulk-stock-form" method="post" action="/stock/{{ product.id }}/bulk-dead"
        class="card p-3 flex flex-wrap items-center gap-2 text-sm" onsubmit="return collectBulkStock();">
    {{ ui.csrf_field(admin) }}
    <input type="hidden" name="ids" id="bs-ids">
    <input type="hidden" name="return_to" value="{{ return_to }}">
    <label class="flex items-center gap-1 text-ink-soft"><input type="checkbox" onclick="document.querySelectorAll('.bs-cb').forEach(c=>c.checked=this.checked)"> Select all</label>
    <input type="text" name="note" placeholder="reason (optional)" class="field w-auto py-1.5">
    {{ ui.btn('Mark bad', 'circle-slash', 'danger', cls='btn-sm', attrs='data-confirm="Mark the selected items as bad (no longer usable)?"') }}
    {{ ui.btn('Delete', 'trash-2', 'danger', cls='btn-sm', attrs='formaction="/stock/' + product.id | string + '/bulk-delete" data-confirm="Permanently delete the selected items? This cannot be undone. Sold items are kept."') }}
  </form>
  {% endif %}

  <section class="card overflow-hidden">
    <div class="max-h-[28rem] overflow-y-auto">
      <table class="data-table data-table--sticky">
        <thead>
          <tr>
            <th></th><th>#</th><th>Status</th><th>Login</th><th>Order</th><th>Added</th><th>Note</th><th></th>
          </tr>
        </thead>
        <tbody>
          {% for it in items %}
          <tr>
            <td>{% if (it.status | lower) != 'sold' %}<input type="checkbox" class="bs-cb" value="{{ it.id }}">{% endif %}</td>
            <td class="text-ink-faint tabular">{{ it.id }}</td>
            <td>{{ ui.status_badge(it.status) }}</td>
            <td class="font-mono text-xs break-all max-w-xs">{{ it.credentials }}</td>
            <td class="text-ink-soft">{{ it.orderId or '—' }}</td>
            <td class="text-ink-soft whitespace-nowrap">{{ it.addedAt | localdt }}</td>
            <td class="text-ink-soft">{{ it.note or '—' }}</td>
            <td class="text-right">
              {% call ui.dropdown('', 'ellipsis-vertical') %}
              <form method="post" action="/stock/item/{{ it.id }}/note" class="flex gap-1 px-3 py-2">
                {{ ui.csrf_field(admin) }}
                <input type="hidden" name="return_to" value="{{ return_to }}">
                <input type="text" name="note" value="{{ it.note or '' }}" placeholder="note" class="field text-xs w-40 py-1">
                {{ ui.icon_button('save', 'Save note', 'soft') }}
              </form>
              {% if (it.status | lower) not in ['sold', 'dead'] %}
              <form method="post" action="/stock/item/{{ it.id }}/dead" class="flex gap-1 px-3 py-2 border-t border-line"
                    data-confirm="Mark item #{{ it.id }} as bad?">
                {{ ui.csrf_field(admin) }}
                <input type="hidden" name="return_to" value="{{ return_to }}">
                <input type="text" name="note" placeholder="reason" class="field text-xs w-40 py-1">
                {{ ui.icon_button('circle-slash', 'Mark as bad', 'danger') }}
              </form>
              {% endif %}
              {% endcall %}
            </td>
          </tr>
          {% else %}
          {{ ui.empty_row(8, 'No stock added yet.') }}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </section>
</div>
{% endcall %}

{{ ui.tabs_end() }}

<script>
function collectBulkStock() {
  const ids = [...document.querySelectorAll('.bs-cb:checked')].map(c => c.value);
  if (!ids.length) { alert('Select at least one item.'); return false; }
  document.getElementById('bs-ids').value = ids.join(',');
  return true;
}

// Read-only USDT preview next to the Rupiah price input — same rounded figure
// customers see ($ = price / usd_idr_rate, nearest 0.1). No rate → no preview.
(function () {
  const rate = Number({{ usd_idr_rate | default("null") }});
  document.querySelectorAll('.js-idr-price').forEach((input) => {
    const out = input.parentElement.querySelector('.js-usdt-preview');
    if (!out) return;
    const update = () => {
      const idr = Number(String(input.value).replace(/[^\d.]/g, ''));
      out.textContent = rate > 0 && idr > 0
        ? 'Customers also see ≈ $' + (Math.round((idr / rate) * 10) / 10)
        : (rate > 0 ? '' : 'Set the USDT rate in Settings → Payments to show a USDT figure.');
    };
    input.addEventListener('input', update);
    update();
  });
})();
</script>
{% endblock %}
