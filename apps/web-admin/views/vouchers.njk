{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Discount Codes · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Discount Codes', 'Codes customers can type at checkout for money off.', 'ticket-percent', 'products') }}
{{ ui.flash(msg, kind) }}

<details class="card card-pad mb-6">
  <summary class="cursor-pointer font-medium text-sm text-pine">+ Create a discount code</summary>
  <form method="post" action="/vouchers" class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
    {{ ui.csrf_field(admin) }}
    <div><label class="field-label">Code</label><input name="code" required class="field uppercase"></div>
    <div><label class="field-label">Type</label>
      <select name="type" class="field">
        {% for t in types %}<option value="{{ t }}">{{ t | lower | title }}</option>{% endfor %}
      </select></div>
    <div><label class="field-label">Amount (% or fixed)</label><input name="value" required class="field"></div>
    <div><label class="field-label">How many times it can be used</label><input name="usage_limit" type="number" placeholder="No limit" class="field"></div>
    <div><label class="field-label">Minimum spend</label><input name="min_purchase" value="0" class="field"></div>
    <div><label class="field-label">Expires on</label><input name="expires_at" type="date" class="field"></div>
    <div class="sm:col-span-3"><button class="btn btn-primary">Create code</button></div>
  </form>
</details>

<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr>
        <th>Code</th><th>Type</th><th class="text-right">Amount</th>
        <th class="text-right">Used</th><th class="text-right">Min spend</th>
        <th>Expires</th><th>Status</th><th></th>
      </tr>
    </thead>
    <tbody>
      {% for v in vouchers %}
      <tr>
        <td class="font-mono">{{ v.code }}</td>
        <td>{{ v.type | lower | title }}</td>
        <td class="text-right tabular">{{ v.value }}{% if (v.type | lower) == 'percent' %}%{% endif %}</td>
        <td class="text-right tabular">{{ v.usedCount }}{% if v.usageLimit %}/{{ v.usageLimit }}{% endif %}</td>
        <td class="text-right tabular">{{ v.minPurchase | idr }}</td>
        <td class="text-ink-soft">{{ v.expiresAt | localdt if v.expiresAt else '—' }}</td>
        <td>{{ ui.status_badge('active' if v.isActive else 'inactive') }}</td>
        <td class="text-right">
          <form method="post" action="/vouchers/{{ v.id }}/toggle" class="inline">
            {{ ui.csrf_field(admin) }}
            <input type="hidden" name="is_active" value="{{ 'false' if v.isActive else 'true' }}">
            <button class="btn btn-soft btn-sm">{{ 'Turn off' if v.isActive else 'Turn on' }}</button>
          </form>
        </td>
      </tr>
      {% else %}
      {{ ui.empty_row(8, 'No discount codes yet.') }}
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
