{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Support · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Support', 'Questions and problems sent in by customers.', 'life-buoy', 'customers') }}
{{ ui.flash(msg, kind) }}

<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr><th>#</th><th>Message</th><th>Status</th><th>Sent</th><th></th></tr>
    </thead>
    <tbody>
      {% for t in tickets %}
      <tr>
        <td class="text-ink-faint">{{ t.id }}</td>
        <td>{{ t.message.substring(0, 80) }}{% if t.message | length > 80 %}…{% endif %}</td>
        <td>{{ ui.status_badge(t.status) }}</td>
        <td class="text-ink-soft">{{ t.createdAt | localdt }}</td>
        <td class="text-right"><a class="link" href="/support/{{ t.id }}">Open →</a></td>
      </tr>
      {% else %}
      {{ ui.empty_row(5, 'No open tickets. 🎉') }}
      {% endfor %}
    </tbody>
  </table>
</div>
<p class="text-xs text-ink-faint mt-3">Showing open and replied tickets. Closed ones are hidden.</p>
{% endblock %}
