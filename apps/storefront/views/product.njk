{% extends "base.njk" %}
{% import "_shop.njk" as shop %}

{% block title %}{{ product.name }} — {{ shop_name }}{% endblock %}

{% block content %}
{{ shop.breadcrumb([
  { label: t('web.nav_home', lang), href: "/" },
  { label: product.category_name, href: "/c/" + product.category_slug },
  { label: product.name }
], lang) }}

<div class="grid md:grid-cols-2 gap-6 lg:gap-10">
  {# Image #}
  <div class="card overflow-hidden self-start">
    <div class="aspect-[4/3] bg-sand">
      <img src="{{ product.image }}" alt="{{ product.name }}" decoding="async"
           class="w-full h-full object-cover">
    </div>
  </div>

  {# Facts + denomination picker + actions #}
  <div id="product-detail">
    <h1 class="page-title !text-2xl sm:!text-3xl">{{ product.name }}</h1>

    {% if product.description %}
    <div class="mt-3 text-sm text-ink-soft whitespace-pre-line">{{ product.description }}</div>
    {% endif %}

    {# Denomination cards — pick a plan (never a dropdown). The cheapest active
       denomination is preselected; selecting another updates the live price /
       stock / warranty and the checkout payload below. #}
    <div class="mt-6">
      <h2 class="section-title mb-3">{{ t('web.choose_plan', lang) }}</h2>
      <div id="denom-list" class="grid gap-2.5">
        {% for d in denominations %}
        {{ shop.denomination_card(d, fx, low_threshold, lang) }}
        {% endfor %}
      </div>
    </div>

    {# Live summary — price/stock/warranty of the selected denomination. #}
    <div class="card card-pad mt-5">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        <div id="sel-price" class="font-display font-semibold text-pine text-2xl"></div>
        <div id="sel-stock"></div>
      </div>
      {% if fx %}
      <div class="text-xs text-ink-faint mt-1.5">{{ t('web.usdt_note', lang) }}</div>
      {% endif %}

      {# Buy Now / Add To Cart — both post the selected denomination_id. #}
      <form id="buy-form" method="post" action="/cart/add" class="mt-5 flex flex-wrap items-end gap-2">
        {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
        <input type="hidden" name="denomination_id" id="sel-denom-input" value="">
        <div class="flex flex-col gap-1">
          <label class="text-xs text-ink-soft" for="qty">{{ t('web.qty', lang) }}</label>
          <input id="qty" type="number" name="qty" value="1" min="1" max="99" class="field !w-20 text-center">
        </div>
        <button type="submit" id="btn-cart" class="btn btn-soft">
          <i data-lucide="shopping-cart" class="w-4 h-4"></i> {{ t('web.add_to_cart', lang) }}
        </button>
        <button type="submit" id="btn-buy" name="buy_now" value="1" class="btn btn-primary">
          <i data-lucide="zap" class="w-4 h-4"></i> {{ t('web.buy_now', lang) }}
        </button>
      </form>

      {# Out-of-stock restock CTA — shown by JS when the selected plan is empty
         (works only when logged in). #}
      <form id="restock-form" method="post" action="/restock/" class="mt-3 hidden">
        {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
        <button type="submit" class="btn btn-soft">
          <i data-lucide="bell" class="w-4 h-4"></i> {{ t('web.notify_restock', lang) }}
        </button>
      </form>
    </div>
  </div>
</div>

{# Reviews #}
<section class="mt-10">
  <h2 class="section-title mb-3">{{ t('web.reviews', lang) }}</h2>
  {% if reviews.length %}
  <div class="grid sm:grid-cols-2 gap-4">
    {% for r in reviews %}
    <div class="card card-pad">
      <div class="flex items-center gap-2">
        {{ shop.stars(r.rating) }}
        <span class="text-xs text-ink-faint">{{ r.author }} · {{ r.created_at | localdt('yyyy-LL-dd') }}</span>
      </div>
      {% if r.comment %}<p class="text-sm text-ink-soft mt-2">{{ r.comment }}</p>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="card card-pad text-center text-ink-faint py-10">{{ t('web.no_reviews', lang) }}</div>
  {% endif %}
</section>

{# Denomination selection: update the live price/stock + checkout payload, and
   swap Buy/Cart ↔ restock CTA when the picked plan is out of stock. Pure
   progressive enhancement — the radios + form already carry the data. #}
<script>
(function () {
  'use strict';
  var root = document.getElementById('product-detail');
  if (!root) return;
  var radios = root.querySelectorAll('.denom-radio');
  var priceEl = document.getElementById('sel-price');
  var stockEl = document.getElementById('sel-stock');
  var denomInput = document.getElementById('sel-denom-input');
  var qtyInput = document.getElementById('qty');
  var buyForm = document.getElementById('buy-form');
  var restockForm = document.getElementById('restock-form');
  // Locale strings + threshold (developer-controlled — never user input).
  var T = {{ {
    low: low_threshold,
    available: t('web.stock_available', lang),
    left: t('web.stock_left', lang, { count: '__N__' }),
    out: t('web.stock_out', lang)
  } | dump | safe }};

  function fmtIdr(v) {
    try { return 'Rp' + Number(v).toLocaleString('id-ID'); } catch (e) { return 'Rp' + v; }
  }

  function select(label) {
    var price = label.getAttribute('data-price');
    var avail = parseInt(label.getAttribute('data-available'), 10) || 0;
    var id = label.getAttribute('data-denom-id');
    priceEl.textContent = fmtIdr(price);
    denomInput.value = id;
    if (qtyInput) qtyInput.max = Math.max(1, avail);
    // Stock badge text mirrors the server macro (kept simple here).
    var cls, txt;
    if (avail > T.low) { cls = 'bg-grass-tint text-grass-dark'; txt = T.available; }
    else if (avail > 0) { cls = 'bg-amberx-tint text-amberx'; txt = T.left.replace('__N__', avail); }
    else { cls = 'bg-rust-tint text-rust-dark'; txt = T.out; }
    stockEl.innerHTML = '<span class="chip ' + cls + '">' + txt + '</span>';
    // Toggle Buy/Cart vs restock when empty.
    if (avail > 0) {
      buyForm.classList.remove('hidden');
      restockForm.classList.add('hidden');
    } else {
      buyForm.classList.add('hidden');
      restockForm.classList.remove('hidden');
      restockForm.setAttribute('action', '/restock/' + id);
    }
  }

  radios.forEach(function (r) {
    r.addEventListener('change', function () {
      if (r.checked) select(r.closest('.denom-card'));
    });
  });

  // Preselect the first in-stock plan, else the first plan.
  var firstEnabled = null;
  for (var i = 0; i < radios.length; i++) {
    if (!radios[i].disabled) { firstEnabled = radios[i]; break; }
  }
  var initial = firstEnabled || radios[0];
  if (initial) { initial.checked = true; select(initial.closest('.denom-card')); }
}());
</script>
{% endblock %}
