{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% import "_shop.njk" as shop %}

{% block title %}{{ order.code }} — {{ shop_name }}{% endblock %}

{% block content %}
<div class="mb-6 flex items-center justify-between gap-3 flex-wrap">
  <div>
    <div class="text-xs text-ink-faint mb-1">
      <a href="/account/orders" class="hover:text-pine">{{ t('web.account_orders', lang) }}</a>
      <span class="mx-1">/</span> <span class="font-mono">{{ order.code }}</span>
    </div>
    <h1 class="page-title !text-2xl">{{ t('web.order_code', lang) }} <span class="font-mono">{{ order.code }}</span></h1>
  </div>
  {{ ui.status_badge(order.status) }}
</div>

{% if pending_payment %}
<div class="card card-pad mb-5 flex items-center justify-between gap-3 flex-wrap bg-pine-tint/40">
  <div class="text-sm text-ink-soft">{{ t('web.order_status', lang) }}: {{ ui.status_badge(order.status) }}</div>
  <a href="/checkout/{{ order.code }}/pay" class="btn btn-primary">
    <i data-lucide="wallet" class="w-4 h-4"></i> {{ t('web.pay_now', lang) }}
  </a>
</div>
{% endif %}

<div class="card overflow-x-auto mb-5">
  <table class="data-table">
    <thead>
      <tr>
        <th>{{ t('web.order_items', lang) }}</th>
        <th>{{ t('web.order_total', lang) }}</th>
        <th>{{ t('web.warranty', lang) }}</th>
      </tr>
    </thead>
    <tbody>
      {% for i in order.items %}
      <tr>
        <td>
          <div class="font-semibold text-sm">{{ i.name }}</div>
          <div class="text-xs text-ink-faint">{{ i.duration }}</div>
        </td>
        <td>{{ shop.price(i.unit_price, fx, "text-sm") }}</td>
        <td class="text-xs text-ink-soft">{{ t('web.warranty_days', lang, { days: i.warranty_days }) }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="card card-pad mb-5 max-w-md ml-auto text-sm">
  <div class="flex justify-between py-1"><span class="text-ink-soft">Subtotal</span> <span>{{ order.subtotal | idr }}</span></div>
  {% if order.bulk_discount and order.bulk_discount != '0' %}
  <div class="flex justify-between py-1 text-grass-dark"><span>Bulk</span> <span>−{{ order.bulk_discount | idr }}</span></div>
  {% endif %}
  {% if order.discount and order.discount != '0' %}
  <div class="flex justify-between py-1 text-grass-dark"><span>Voucher</span> <span>−{{ order.discount | idr }}</span></div>
  {% endif %}
  <div class="flex justify-between py-2 border-t border-line mt-1 font-semibold">
    <span>{{ t('web.order_total', lang) }}</span> {{ shop.price(order.total, fx, "text-base") }}
  </div>
</div>

{% if delivered %}
<section class="card card-pad border-grass/40">
  <h2 class="section-title flex items-center gap-2">
    <i data-lucide="badge-check" class="w-5 h-5 text-grass"></i> {{ t('web.credentials', lang) }}
  </h2>
  <p class="text-xs text-ink-faint mt-1">{{ t('web.credentials_hint', lang) }}</p>
  <div class="mt-3 space-y-2">
    {% for i in order.items %}
    {% if i.credentials %}
    <div class="flex items-center gap-2">
      <code class="codeish flex-1 !text-sm break-all select-all" id="cred-{{ loop.index }}">{{ i.credentials }}</code>
      <button type="button" class="btn btn-soft btn-sm"
              onclick="navigator.clipboard.writeText(document.getElementById('cred-{{ loop.index }}').textContent)">
        <i data-lucide="copy" class="w-3.5 h-3.5"></i> {{ t('web.copy', lang) }}
      </button>
    </div>
    {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}
{% endblock %}
