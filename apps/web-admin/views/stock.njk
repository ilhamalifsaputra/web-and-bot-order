{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Stock · Shop Admin{% endblock %}

{% block content %}
<header class="mb-6">
  <h1 class="page-title flex items-center gap-2.5"><i data-lucide="boxes" class="w-7 h-7 text-violet-500"></i> Stock</h1>
  <p class="page-lead">How many of each product you have ready to sell.</p>
</header>
{{ ui.flash(msg, kind) }}

{% if not products %}
<p class="text-ink-soft">No products yet. Add one under <a class="link" href="/catalog">Products</a>.</p>
{% endif %}

{% for cat_name, items in groups %}
<section class="mb-8">
  <h2 class="section-title mb-3">{{ cat_name }}</h2>
  <div class="card overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th>Product</th>
          <th class="text-right">Ready</th>
          <th class="text-right">Held</th>
          <th class="text-right">Sold</th>
          <th class="text-right">Bad</th>
          <th class="text-right">Waiting</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for p in items %}
        {% set c = counts[p.id] %}
        {% set avail = c.available if c else 0 %}
        <tr>
          <td>
            <span class="font-medium">{{ p.name }}</span>
            <span class="text-ink-faint">· {{ p.durationLabel }}</span>
            {% if not p.isActive %}<span class="ml-1 text-xs text-rust">(hidden)</span>{% endif %}
          </td>
          <td class="text-right tabular {% if avail == 0 %}text-rust font-semibold{% endif %}">{{ avail }}</td>
          <td class="text-right tabular text-ink-soft">{{ c.reserved if c else 0 }}</td>
          <td class="text-right tabular text-ink-soft">{{ c.sold if c else 0 }}</td>
          <td class="text-right tabular text-ink-soft">{{ c.dead if c else 0 }}</td>
          {% set w = waiting[p.id] %}
          <td class="text-right tabular {% if w and avail == 0 %}text-amberx font-semibold{% else %}text-ink-soft{% endif %}">{{ w or 0 }}</td>
          <td class="text-right">
            <a class="link" href="/stock/{{ p.id }}">Manage →</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endfor %}
{% endblock %}
