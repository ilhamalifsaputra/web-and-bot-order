{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}{{ user.fullName or user.telegramId }} · Customers{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="/users" class="link text-sm">← Customers</a>
  <h1 class="page-title mt-1 flex items-center gap-3 flex-wrap">
    <i data-lucide="user-round" class="w-7 h-7 text-emerald-500"></i>
    {{ user.fullName or user.username or ('Telegram ' + (user.telegramId | string)) }}
    {{ ui.status_badge(user.role) }}
    {% if user.banned %}<span class="chip bg-rust-tint text-rust-dark">Blocked</span>{% endif %}
  </h1>
</div>
{{ ui.flash(msg, kind) }}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <aside class="space-y-6">
    <div class="card card-pad text-sm">
      <h2 class="section-title mb-3">About</h2>
      <dl class="space-y-1.5">
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Telegram</dt><dd class="font-mono">{{ user.telegramId }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Username</dt><dd>{{ user.username or '—' }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Wallet balance</dt><dd class="tabular">{{ user.walletBalance | money }} {{ currency }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Total spent</dt><dd class="tabular">{{ total_spent | money }} {{ currency }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Referral code</dt><dd class="font-mono">{{ user.referralCode }}</dd></div>
        <div class="flex justify-between gap-3"><dt class="text-ink-soft">Joined</dt><dd>{{ user.createdAt | localdt }}</dd></div>
        {% if user.banned and user.bannedReason %}<div class="text-rust text-xs mt-2">Block reason: {{ user.bannedReason }}</div>{% endif %}
      </dl>
    </div>

    <div class="card card-pad text-sm space-y-4">
      <h2 class="section-title">Manage</h2>
      <form method="post" action="/users/{{ user.id }}/role" class="flex gap-2 items-end">
        {{ ui.csrf_field(admin) }}
        <div class="flex-1"><label class="field-label">Customer type</label>
          <select name="role" class="field">
            {% for r in roles %}<option value="{{ r }}" {% if user.role == r %}selected{% endif %}>{{ r | lower | title }}</option>{% endfor %}
          </select></div>
        <button class="btn btn-soft">Save</button>
      </form>

      <form method="post" action="/users/{{ user.id }}/ban" class="space-y-2">
        {{ ui.csrf_field(admin) }}
        <input type="hidden" name="banned" value="{{ 'false' if user.banned else 'true' }}">
        {% if not user.banned %}
        <input type="text" name="reason" placeholder="Why are you blocking them?" class="field">
        <button class="btn btn-danger w-full">Block customer</button>
        {% else %}
        <button class="btn btn-soft w-full">Unblock customer</button>
        {% endif %}
      </form>

      <form method="post" action="/users/{{ user.id }}/wallet" class="space-y-2">
        {{ ui.csrf_field(admin) }}
        <label class="field-label">Add or remove wallet credit</label>
        <input type="text" name="delta" placeholder="e.g. 5 or -2.5" class="field" required>
        <input type="text" name="note" placeholder="reason (required)" class="field" required>
        <button class="btn btn-soft w-full">Update wallet</button>
      </form>
    </div>
  </aside>

  <section class="lg:col-span-2 space-y-6">
    <div class="card card-pad">
      <h2 class="section-title mb-3">Recent orders</h2>
      <table class="data-table">
        <thead><tr><th>Code</th><th>Status</th><th class="text-right">Total</th><th>Placed</th></tr></thead>
        <tbody>
          {% for o in orders %}
          <tr>
            <td><a class="link font-mono text-xs" href="/orders/{{ o.id }}">{{ o.orderCode }}</a></td>
            <td>{{ ui.status_badge(o.status) }}</td>
            <td class="text-right tabular">{{ o.totalAmount | money }}</td>
            <td class="text-ink-soft">{{ o.createdAt | localdt }}</td>
          </tr>
          {% else %}
          {{ ui.empty_row(4, 'No orders.') }}
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="card card-pad">
      <h2 class="section-title mb-3">Wallet history</h2>
      <p class="text-xs text-ink-faint mb-2">Every change to their wallet — top-ups, refunds, referral rewards, and payments — with the balance after each one.</p>
      <table class="data-table">
        <thead><tr><th>When</th><th class="text-right">Change</th><th class="text-right">Balance</th><th>Reason</th><th>Link</th></tr></thead>
        <tbody>
          {% for e in ledger %}
          <tr>
            <td class="text-ink-soft">{{ e.createdAt | localdt }}</td>
            <td class="text-right font-mono tabular {% if e.delta[0] == '-' %}text-rust{% else %}text-grass{% endif %}">{{ e.delta }}</td>
            <td class="text-right font-mono tabular text-ink-soft">{{ e.balanceAfter }}</td>
            <td>
              <span class="chip bg-sand text-ink-soft">{{ e.reason | replace('_', ' ') | title }}</span>
              {% if e.note %}<span class="text-ink-soft">· {{ e.note }}</span>{% endif %}
            </td>
            <td class="text-xs text-ink-faint">
              {% if e.orderId %}<a class="link font-normal" href="/orders/{{ e.orderId }}">order #{{ e.orderId }}</a>{% endif %}
              {% if e.adminId %}<span>by team #{{ e.adminId }}</span>{% endif %}
            </td>
          </tr>
          {% else %}
          {{ ui.empty_row(5, 'No wallet activity.') }}
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="card card-pad">
      <h2 class="section-title mb-3">Support tickets</h2>
      <ul class="divide-y divide-line text-sm">
        {% for t in tickets %}
        <li class="py-2.5 flex items-center justify-between gap-3">
          <a class="link font-normal text-ink hover:text-pine truncate" href="/support/{{ t.id }}">#{{ t.id }} · {{ t.message.substring(0, 60) }}</a>
          {{ ui.status_badge(t.status) }}
        </li>
        {% else %}
        <li class="py-4 text-center text-ink-faint">No tickets.</li>
        {% endfor %}
      </ul>
    </div>
  </section>
</div>
{% endblock %}
