<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Shop Admin{% endblock %}</title>

  {# Design tokens + component classes live in the SHARED theme partial
     (packages/web-ui/views/_theme.njk) so admin & storefront stay identical.
     Change a token there → both webs change. #}
  {% include "_theme.njk" %}
</head>
<body class="min-h-screen"
      {% if admin %}hx-headers='{"x-csrf-token": "{{ admin.csrf }}"}'{% endif %}>

{% block nav %}
{% if admin %}
{# Plain-English nav. Each group's `match` lists the paths that light up its
   label as active. Labels avoid jargon (Outbox→Notifications, Vouchers→Discount
   Codes, Broadcast→Announcements, Audit→Activity Log, Admins→Team). #}
{% set nav_groups = [
  { label: 'Sales',     icon: 'shopping-cart', color: 'text-blue-500',    match: ['/orders', '/payments', '/outbox'],              items: [['/orders', 'Orders', 'shopping-cart'], ['/payments', 'Payments', 'wallet'], ['/outbox', 'Notifications', 'bell']] },
  { label: 'Products',  icon: 'package',       color: 'text-violet-500',  match: ['/catalog', '/stock', '/vouchers'],              items: [['/catalog', 'Products', 'package'], ['/stock', 'Stock', 'boxes'], ['/vouchers', 'Discount Codes', 'ticket-percent']] },
  { label: 'Customers', icon: 'users',         color: 'text-emerald-500', match: ['/users', '/reviews', '/support', '/broadcast'], items: [['/users', 'Customers', 'users'], ['/reviews', 'Reviews', 'star'], ['/support', 'Support', 'life-buoy'], ['/broadcast', 'Announcements', 'megaphone']] },
  { label: 'Reports',   icon: 'bar-chart-3',   color: 'text-amber-500',   match: ['/reports', '/audit', '/search'],                items: [['/reports', 'Reports', 'trending-up'], ['/audit', 'Activity Log', 'history'], ['/search', 'Search', 'search']] }
] %}
{% set role_label = { 'super': 'Owner', 'support': 'Support', 'readonly': 'View only' } %}
<nav class="sticky top-0 z-30 bg-card/85 backdrop-blur border-b border-line">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-display text-lg font-semibold text-pine whitespace-nowrap">
      <i data-lucide="store" class="w-5 h-5"></i>
      Shop Admin
    </a>

    <div class="flex flex-wrap items-center gap-x-1 gap-y-1 text-sm">
      <a href="/"
         class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition-colors hover:bg-sand {% if active_nav == '/' %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
        <i data-lucide="layout-dashboard" class="w-4 h-4 text-rose-500"></i> Home
      </a>

      {% for g in nav_groups %}
      <details class="relative group">
        <summary class="flex items-center gap-1.5 cursor-pointer select-none px-3 py-1.5 rounded-lg transition-colors hover:bg-sand {% if active_nav in g.match %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
          <i data-lucide="{{ g.icon }}" class="w-4 h-4 {{ g.color }}"></i> {{ g.label }}
          <span class="text-[0.6rem] opacity-60 group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <div class="absolute left-0 mt-2 min-w-[12rem] rounded-xl bg-card py-1.5 shadow-lift border border-line z-40">
          {% for it in g.items %}
          <a href="{{ it[0] }}"
             class="flex items-center gap-2.5 px-4 py-2 text-sm transition-colors hover:bg-sand {% if active_nav == it[0] %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
            <i data-lucide="{{ it[2] }}" class="w-4 h-4 {% if active_nav == it[0] %}{% else %}{{ g.color }}{% endif %}"></i> {{ it[1] }}
          </a>
          {% endfor %}
        </div>
      </details>
      {% endfor %}

      {% set settings_active = active_nav == '/settings' or active_nav == '/admins' or active_nav == '/branding' %}
      <details class="relative group">
        <summary class="flex items-center gap-1.5 cursor-pointer select-none px-3 py-1.5 rounded-lg transition-colors hover:bg-sand {% if settings_active %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
          <i data-lucide="settings" class="w-4 h-4 text-sky-500"></i> Settings
          <span class="text-[0.6rem] opacity-60 group-open:rotate-180 transition-transform">▾</span>
        </summary>
        <div class="absolute right-0 mt-2 min-w-[12rem] rounded-xl bg-card py-1.5 shadow-lift border border-line z-40">
          <a href="/settings"
             class="flex items-center gap-2.5 px-4 py-2 text-sm transition-colors hover:bg-sand {% if active_nav == '/settings' %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
            <i data-lucide="sliders-horizontal" class="w-4 h-4 {% if active_nav == '/settings' %}{% else %}text-sky-500{% endif %}"></i> Settings
          </a>
          <a href="/branding"
             class="flex items-center gap-2.5 px-4 py-2 text-sm transition-colors hover:bg-sand {% if active_nav == '/branding' %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
            <i data-lucide="image" class="w-4 h-4 {% if active_nav == '/branding' %}{% else %}text-sky-500{% endif %}"></i> Branding
          </a>
          {% if admin.role == 'super' %}
          <a href="/admins"
             class="flex items-center gap-2.5 px-4 py-2 text-sm transition-colors hover:bg-sand {% if active_nav == '/admins' %}text-pine font-semibold bg-pine-tint{% else %}text-ink-soft{% endif %}">
            <i data-lucide="users-round" class="w-4 h-4 {% if active_nav == '/admins' %}{% else %}text-sky-500{% endif %}"></i> Team
          </a>
          {% endif %}
        </div>
      </details>
    </div>

    <div class="flex items-center gap-3 text-sm whitespace-nowrap">
      {% if admin.role %}<span class="chip bg-pine-tint text-pine-dark"><i data-lucide="shield-check" class="w-3.5 h-3.5"></i> {{ role_label[admin.role] or admin.role }}</span>{% endif %}
      {% if admin.telegramId %}<span class="hidden sm:inline text-ink-faint text-xs">Telegram {{ admin.telegramId }}</span>{% endif %}
      <form method="post" action="/logout" class="inline">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <button type="submit" class="flex items-center gap-1.5 text-ink-soft hover:text-rust transition-colors"><i data-lucide="log-out" class="w-4 h-4"></i> Sign out</button>
      </form>
    </div>
  </div>
</nav>
{% endif %}
{% endblock %}

<main class="max-w-6xl mx-auto px-4 py-8 sm:py-10">
  {% block content %}{% endblock %}
</main>

<script>
  // Render Lucide icons on load, and again after HTMX swaps content (e.g. the
  // dashboard "needs attention" widgets) so swapped-in <i> tags become SVGs.
  function renderIcons() { if (window.lucide) window.lucide.createIcons(); }
  renderIcons();
  document.addEventListener('htmx:afterSettle', renderIcons);

  // Close any open nav dropdown when clicking outside it.
  document.addEventListener('click', function (e) {
    document.querySelectorAll('nav details[open]').forEach(function (d) {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });
</script>

</body>
</html>
