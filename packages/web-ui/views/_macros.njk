{# Reusable form/UI snippets shared by web-admin AND the storefront (moved from
   apps/web-admin/views/_macros.njk — plan.md §6 decision B). Import with:
   {% import "_macros.njk" as ui %} #}

{% macro csrf_field(admin) -%}
<input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
{%- endmacro %}

{# ── Section accent tones ── ONE place mapping a nav section to its colour, so
   every page header's icon matches the menu group the page lives under
   (Sales=blue, Products=violet, Customers=green, Reports=amber, Settings=sky,
   Home=rose). Keep in sync with the `nav_groups` colours in base.njk. #}
{% set _section_tone = {
  'home':      'text-rose-500',
  'sales':     'text-blue-500',
  'products':  'text-violet-500',
  'customers': 'text-emerald-500',
  'reports':   'text-amber-500',
  'settings':  'text-sky-500'
} %}

{# Standard page header: a section-tinted icon + title, with an optional lead
   line. Replaces the hand-copied <header> block that used to live on every
   page (each with a different, arbitrary icon colour). `section` picks the
   colour so the header always matches its nav group — see _section_tone. #}
{% macro page_header(title, lead, icon, section='home') -%}
<header class="mb-6">
  <h1 class="page-title flex items-center gap-2.5">
    <i data-lucide="{{ icon }}" class="w-7 h-7 {{ _section_tone[section] or 'text-pine' }}"></i> {{ title }}
  </h1>
  {% if lead %}<p class="page-lead">{{ lead }}</p>{% endif %}
</header>
{%- endmacro %}

{# Lucide icon. Rendered to an <svg> by base.njk's init script. Size + colour
   come from Tailwind classes (icons inherit currentColor). #}
{% macro ic(name, cls="w-5 h-5") -%}
<i data-lucide="{{ name }}" class="{{ cls }}"></i>
{%- endmacro %}

{% macro flash(message, kind="info") -%}
{% if message %}
<div class="flex items-start gap-2 rounded-xl px-4 py-3 mb-5 text-sm border
  {% if kind == 'error' %}bg-rust-tint text-rust-dark border-rust/30
  {% elif kind == 'success' %}bg-grass-tint text-grass-dark border-grass/30
  {% else %}bg-sand text-ink border-line{% endif %}">
  <span class="mt-px">
    {%- if kind == 'error' %}✕{% elif kind == 'success' %}✓{% else %}•{% endif -%}
  </span>
  <span>{{ message }}</span>
</div>
{% endif %}
{%- endmacro %}

{# Enum values are stored UPPERCASE in the DB. We show a plain-English label and
   a colour that reads at a glance — green=good/done, amber=needs attention,
   blue=waiting, red=stopped/bad. Unknown values fall back to a tidied string. #}
{% set _status_labels = {
  'delivered': 'Delivered', 'paid': 'Paid', 'available': 'In stock',
  'active': 'Active', 'closed': 'Closed', 'sent': 'Sent', 'matched': 'Matched',
  'pending_verification': 'Awaiting check', 'reserved': 'Reserved',
  'open': 'Open', 'replied': 'Replied', 'pending': 'Waiting',
  'pending_payment': 'Awaiting payment', 'underpaid': 'Paid too little',
  'cancelled': 'Cancelled', 'rejected': 'Rejected', 'refunded': 'Refunded',
  'dead': 'Used up', 'failed': 'Failed', 'unmatched': 'Unmatched',
  'credited_to_balance': 'Added to credit balance'
} %}
{% macro status_badge(value) -%}
{% set v = (value | string | lower) %}
<span class="chip
  {% if v in ['delivered', 'paid', 'available', 'active', 'closed', 'sent', 'matched', 'credited_to_balance'] %}bg-grass-tint text-grass-dark
  {% elif v in ['pending_verification', 'reserved', 'open', 'replied', 'pending', 'underpaid'] %}bg-amberx-tint text-amberx
  {% elif v in ['pending_payment'] %}bg-pine-tint text-pine-dark
  {% elif v in ['cancelled', 'rejected', 'refunded', 'dead', 'failed', 'unmatched'] %}bg-rust-tint text-rust-dark
  {% else %}bg-sand text-ink-soft{% endif %}">
  {{ _status_labels[v] or (v | replace('_', ' ') | title) }}
</span>
{%- endmacro %}

{# An order's settlement currency, next to its status badge — IDR is the
   neutral default tone, anything else (USDT today, future codes) gets the
   pine accent so a non-IDR order is visually distinct at a glance. #}
{% macro currency_badge(currency) -%}
<span class="chip {% if (currency | string | upper) == 'IDR' %}bg-sand text-ink-soft{% else %}bg-pine-tint text-pine-dark{% endif %}">
  {{ currency | string | upper }}
</span>
{%- endmacro %}

{# Empty-state row for tables: a quiet, friendly "nothing here yet" line. #}
{% macro empty_row(cols, message) -%}
<tr><td colspan="{{ cols }}" class="px-4 py-10 text-center text-ink-faint">{{ message }}</td></tr>
{%- endmacro %}

{# Pager: the count + Newer/Older nav under a list table. ONE place for the
   layout so every paginated page reads the same. `qbase` is the page's query
   string WITHOUT &page=…; `label` is the already-pluralised noun e.g.
   "order(s)". Newer = lower page number (more recent), Older = higher. #}
{% macro pager(qbase, page, has_next, total, label) -%}
<div class="flex items-center justify-between mt-4 text-sm text-ink-soft">
  <span>{{ total }} {{ label }} · page {{ page }}</span>
  <span class="flex gap-3">
    {% if page > 1 %}<a class="link" href="{{ qbase }}&page={{ page - 1 }}">← Newer</a>{% endif %}
    {% if has_next %}<a class="link" href="{{ qbase }}&page={{ page + 1 }}">Older →</a>{% endif %}
  </span>
</div>
{%- endmacro %}

{# ─────────────────────────────────────────────────────────────────────────────
   Component layer (shadcn/Linear-flavoured) — ADDITIVE & OPT-IN. These macros
   are only rendered where a template calls them, so existing pages (and the
   whole storefront) are unaffected until they adopt them. They lean on the
   shared theme tokens + .btn/.chip/.card/.field classes; the interactive ones
   (tabs, dropdown, dropzone, [data-confirm]) are driven by web-admin's
   static/admin-ui.js and degrade gracefully without JS.
   ──────────────────────────────────────────────────────────────────────────── #}

{# Generic pill. `status_badge` maps DB enums; this is for free-form labels
   (kind, SKU, "10+ → 15%"). Tones reuse the same tint pairs. #}
{% set _badge_tone = {
  'neutral': 'bg-sand text-ink-soft',
  'success': 'bg-grass-tint text-grass-dark',
  'warn':    'bg-amberx-tint text-amberx',
  'info':    'bg-pine-tint text-pine-dark',
  'danger':  'bg-rust-tint text-rust-dark'
} %}
{% macro badge(text, tone='neutral') -%}
<span class="chip {{ _badge_tone[tone] or _badge_tone['neutral'] }}">{{ text }}</span>
{%- endmacro %}

{# Button/link. Renders <a> when `href` is set, else <button type=…>. `icon` is
   a Lucide name; `variant` ∈ primary|soft|ghost|danger; `cls` adds classes
   (e.g. 'btn-sm w-full'). Non-class attributes (data-confirm, formaction, name,
   value, …) pass via `attrs` (raw, caller-trusted — admin templates only). #}
{% macro btn(label, icon=None, variant='primary', href=None, type='submit', cls='', attrs='') -%}
{% if href -%}
<a href="{{ href }}" class="btn btn-{{ variant }} {{ cls }}" {{ attrs | safe }}>
  {%- if icon %}<i data-lucide="{{ icon }}" class="w-4 h-4"></i>{% endif %} {{ label }}</a>
{%- else -%}
<button type="{{ type }}" class="btn btn-{{ variant }} {{ cls }}" {{ attrs | safe }}>
  {%- if icon %}<i data-lucide="{{ icon }}" class="w-4 h-4"></i>{% endif %} {{ label }}</button>
{%- endif %}
{%- endmacro %}

{# Square icon-only button with an accessible label + hover tooltip (data-tip).
   Use for compact row/toolbar actions. `attrs` carries formaction/name/value. #}
{% macro icon_button(icon, label, variant='ghost', cls='', attrs='') -%}
<button type="submit" class="btn btn-{{ variant }} btn-sm !px-2 {{ cls }}" aria-label="{{ label }}" data-tip="{{ label }}" {{ attrs | safe }}>
  <i data-lucide="{{ icon }}" class="w-4 h-4"></i>
</button>
{%- endmacro %}

{# Hairline divider (shadcn Separator). #}
{% macro separator(cls='') -%}
<div role="separator" class="h-px bg-line my-4 {{ cls }}"></div>
{%- endmacro %}

{# Tablist. `id` namespaces the group (URL hash + sessionStorage key);
   `items` = [{key,label,icon}]. The matching panels are emitted by tab_panel().
   admin-ui.js wires roving focus, arrows, aria-selected and hash/restore. With
   no JS every panel stays visible (progressive enhancement). #}
{% macro tabs(id, items) -%}
<div class="tabs" data-tabs="{{ id }}">
  <div role="tablist" aria-label="{{ id }}" class="flex flex-wrap gap-1 border-b border-line mb-5">
    {% for it in items %}
    <button type="button" role="tab" id="tab-{{ id }}-{{ it.key }}"
            data-tab="{{ it.key }}" aria-controls="panel-{{ id }}-{{ it.key }}"
            aria-selected="{{ 'true' if loop.first else 'false' }}"
            tabindex="{{ '0' if loop.first else '-1' }}"
            class="tab-btn -mb-px flex items-center gap-2 px-3.5 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-ink-soft hover:text-ink transition-colors">
      {% if it.icon %}<i data-lucide="{{ it.icon }}" class="w-4 h-4"></i>{% endif %} {{ it.label }}
    </button>
    {% endfor %}
  </div>
{%- endmacro %}

{# Close the <div class="tabs"> opened by tabs(). #}
{% macro tabs_end() -%}
</div>
{%- endmacro %}

{# One panel. `key` must match a tabs() item key; `id` the same group id.
   Caller puts the panel body between {% call %} … {% endcall %}. #}
{% macro tab_panel(id, key, first=False) -%}
<section role="tabpanel" id="panel-{{ id }}-{{ key }}" aria-labelledby="tab-{{ id }}-{{ key }}"
         data-panel="{{ key }}" {% if not first %}hidden{% endif %}>
  {{ caller() }}
</section>
{%- endmacro %}

{# Keyboard-native menu (shadcn DropdownMenu) built on <details>. The caller
   supplies the menu items between {% call %} … {% endcall %}. admin-ui.js
   closes it on outside-click / Escape; the chevron rotates when open. #}
{% macro dropdown(label='', icon='ellipsis-vertical', align='right') -%}
<details class="dropdown relative inline-block">
  <summary class="btn btn-ghost btn-sm cursor-pointer select-none list-none">
    {% if icon %}<i data-lucide="{{ icon }}" class="w-4 h-4"></i>{% endif %}{% if label %} {{ label }}{% endif %}
    <i data-lucide="chevron-down" class="w-3.5 h-3.5 dd-chevron transition-transform"></i>
  </summary>
  <div class="absolute {{ 'right-0' if align == 'right' else 'left-0' }} mt-2 min-w-[12rem] max-w-[calc(100vw-2rem)] rounded-xl bg-card py-1.5 shadow-lift border border-line z-40 flex flex-col text-sm max-sm:!fixed max-sm:!left-4 max-sm:!right-4 max-sm:!top-auto max-sm:!bottom-4 max-sm:!mt-0 max-sm:!w-auto max-sm:!max-h-[75vh] max-sm:!overflow-y-auto max-sm:!z-50">
    {{ caller() }}
  </div>
</details>
{%- endmacro %}

{# Drag-and-drop image upload card + live preview. Wraps the EXISTING photo
   endpoint untouched (multipart, hidden csrf_token, optional return_to). Click
   still opens the file picker without JS; admin-ui.js adds drag/preview. #}
{% macro dropzone(name, action, csrf, current_url=None, return_to=None) -%}
<form method="post" action="{{ action }}" enctype="multipart/form-data" class="dropzone-form">
  <input type="hidden" name="csrf_token" value="{{ csrf }}">
  {% if return_to %}<input type="hidden" name="return_to" value="{{ return_to }}">{% endif %}
  <label class="dropzone card card-pad flex flex-col items-center justify-center gap-3 text-center cursor-pointer border-2 border-dashed border-line hover:border-pine transition-colors">
    <img class="dz-preview w-28 h-28 object-cover rounded-lg border border-sand {{ '' if current_url else 'hidden' }}"
         src="{{ current_url or '' }}" alt="">
    <div class="dz-prompt flex flex-col items-center gap-1 {{ 'hidden' if current_url else '' }}">
      <i data-lucide="image-up" class="w-7 h-7 text-ink-faint"></i>
      <span class="text-sm font-semibold text-ink">Drop an image, or click to choose</span>
    </div>
    <input type="file" name="{{ name }}" accept="image/jpeg,image/png,image/webp" required
           class="dz-input sr-only">
    <span class="dz-name text-xs text-ink-faint"></span>
  </label>
  <div class="mt-3 flex items-center gap-2">
    {{ btn('Upload photo', 'upload', 'primary') }}
    <span class="text-xs text-ink-faint">JPG, PNG, or WebP · max 5 MB · rasio 4:3 disarankan (mis. 800×600 / 1200×900).</span>
  </div>
</form>
{%- endmacro %}
