{% extends "base.njk" %}
{% import "_shop.njk" as shop %}

{% block title %}{{ product.name }} — {{ shop_name }}{% endblock %}

{% block content %}
<div class="grid md:grid-cols-2 gap-6 lg:gap-10">
  {# Image #}
  <div class="card overflow-hidden self-start">
    <div class="aspect-[4/3] bg-sand">
      <img src="{{ product.image }}" alt="{{ product.name }}" decoding="async"
           class="w-full h-full object-cover">
    </div>
  </div>

  {# Facts + actions #}
  <div>
    <div class="text-xs text-ink-faint mb-1">
      <a href="/" class="hover:text-pine">{{ t('web.nav_home', lang) }}</a>
      <span class="mx-1">/</span> {{ product.category_name }}
    </div>
    <h1 class="page-title !text-2xl sm:!text-3xl">{{ product.name }}</h1>
    <div class="flex items-center gap-2 mt-2 text-sm text-ink-soft flex-wrap">
      <span>{{ product.duration_label }}</span>
      <span class="text-ink-faint">·</span>
      <span class="inline-flex items-center gap-1">
        <i data-lucide="shield-check" class="w-4 h-4 text-grass"></i>
        {{ t('web.warranty_days', lang, { days: product.warranty_days }) }}
      </span>
    </div>

    {% if rating_count > 0 %}
    <div class="flex items-center gap-2 mt-3 text-sm text-ink-soft">
      {{ shop.stars(rating, "w-4 h-4") }}
      <span class="font-semibold text-ink">{{ rating | round(1) }}</span>
      <span class="text-ink-faint">({{ t('web.review_count', lang, { count: rating_count }) }})</span>
    </div>
    {% endif %}

    <div class="card card-pad mt-5">
      <div class="flex items-center justify-between gap-3 flex-wrap">
        {{ shop.price(product.price, fx, "text-2xl") }}
        {{ shop.stock_badge(available, low_threshold, lang) }}
      </div>
      {% if fx %}
      <div class="text-xs text-ink-faint mt-1.5">{{ t('web.usdt_note', lang) }}</div>
      {% endif %}

      {% if bulk %}
      <div class="chip bg-pine-tint text-pine-dark mt-3">
        <i data-lucide="tag" class="w-3.5 h-3.5"></i>
        {{ t('web.bulk_deal', lang, { min: bulk.min_quantity, percent: bulk.discount_percent }) }}
      </div>
      {% endif %}

      <div class="mt-5 flex gap-2 flex-wrap">
        {% if available > 0 %}
        <form method="post" action="/cart/add" class="flex gap-2 items-center flex-wrap">
          {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
          <input type="hidden" name="product_id" value="{{ product.id }}">
          <label class="text-xs text-ink-soft" for="qty">{{ t('web.qty', lang) }}</label>
          <input id="qty" type="number" name="qty" value="1" min="1" max="{{ available }}" class="field !w-20 text-center">
          <button type="submit" class="btn btn-primary">
            <i data-lucide="shopping-cart" class="w-4 h-4"></i> {{ t('web.add_to_cart', lang) }}
          </button>
        </form>
        {% else %}
        <form method="post" action="/restock/{{ product.id }}">
          {% if customer %}<input type="hidden" name="csrf_token" value="{{ customer.csrf }}">{% endif %}
          <button type="submit" class="btn btn-soft">
            <i data-lucide="bell" class="w-4 h-4"></i> {{ t('web.notify_restock', lang) }}
          </button>
        </form>
        {% endif %}
      </div>
    </div>

    {% if product.description %}
    <div class="mt-6">
      <h2 class="section-title mb-2">{{ t('web.description', lang) }}</h2>
      <div class="text-sm text-ink-soft whitespace-pre-line">{{ product.description }}</div>
    </div>
    {% endif %}
  </div>
</div>

{# Reviews #}
<section class="mt-10">
  <h2 class="section-title mb-3">{{ t('web.reviews', lang) }}</h2>
  {% if reviews.length %}
  <div class="grid sm:grid-cols-2 gap-4">
    {% for r in reviews %}
    <div class="card card-pad">
      <div class="flex items-center gap-2">
        {{ shop.stars(r.rating) }}
        <span class="text-xs text-ink-faint">{{ r.author }} · {{ r.created_at | localdt('yyyy-LL-dd') }}</span>
      </div>
      {% if r.comment %}<p class="text-sm text-ink-soft mt-2">{{ r.comment }}</p>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="card card-pad text-center text-ink-faint py-10">{{ t('web.no_reviews', lang) }}</div>
  {% endif %}
</section>
{% endblock %}
