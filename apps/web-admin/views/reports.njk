{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Reports · Stock Admin{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-6">Reports</h1>

<section class="bg-white rounded-lg shadow p-5 mb-6">
  <div class="flex items-baseline justify-between mb-3">
    <h2 class="font-semibold">Revenue — last 30 days</h2>
    <span class="text-sm text-slate-500">{{ total_30d | money }} {{ currency }} total</span>
  </div>
  <svg viewBox="0 0 {{ spark.width }} {{ spark.height }}" class="w-full h-32" preserveAspectRatio="none" role="img" aria-label="Daily revenue trend">
    {% if spark.area %}<polygon points="{{ spark.area }}" fill="#0f172a" fill-opacity="0.06" />{% endif %}
    <polyline points="{{ spark.line }}" fill="none" stroke="#0f172a" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" />
  </svg>
  <p class="text-xs text-slate-400 mt-1">Peak day: {{ spark.max | round(2) }} {{ currency }} · buckets are UTC days.</p>
</section>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <section class="bg-white rounded-lg shadow p-5">
    <h2 class="font-semibold mb-3">Top products</h2>
    <table class="min-w-full text-sm">
      <thead class="text-slate-500 text-left"><tr><th class="py-1">Product</th><th class="py-1 text-right">Sold</th><th class="py-1 text-right">Revenue</th></tr></thead>
      <tbody class="divide-y divide-slate-100">
        {% for p in products %}
        <tr>
          <td class="py-1"><a class="hover:underline" href="/stock/{{ p.productId }}">{{ p.name }}</a></td>
          <td class="py-1 text-right">{{ p.qty }}</td>
          <td class="py-1 text-right">{{ p.revenue | money }} {{ currency }}</td>
        </tr>
        {% else %}
        <tr><td colspan="3" class="py-4 text-center text-slate-400">No delivered sales yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <section class="bg-white rounded-lg shadow p-5">
    <h2 class="font-semibold mb-3">Orders by status</h2>
    <table class="min-w-full text-sm">
      <tbody class="divide-y divide-slate-100">
        {% for s in funnel %}
        <tr>
          <td class="py-1">{{ ui.status_badge(s.status) }}</td>
          <td class="py-1 text-right">{{ s.count }}</td>
        </tr>
        {% else %}
        <tr><td class="py-4 text-center text-slate-400">No orders yet.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <section class="bg-white rounded-lg shadow p-5 lg:col-span-2">
    <h2 class="font-semibold mb-3">Voucher usage</h2>
    <table class="min-w-full text-sm">
      <thead class="text-slate-500 text-left"><tr><th class="py-1">Code</th><th class="py-1 text-right">Used</th><th class="py-1 text-right">Limit</th><th class="py-1">Active</th></tr></thead>
      <tbody class="divide-y divide-slate-100">
        {% for v in vouchers %}
        <tr>
          <td class="py-1 font-mono">{{ v.code }}</td>
          <td class="py-1 text-right">{{ v.usedCount }}</td>
          <td class="py-1 text-right text-slate-500">{{ v.usageLimit if v.usageLimit != null else '∞' }}</td>
          <td class="py-1">{% if v.isActive %}{{ ui.status_badge('active') }}{% else %}<span class="text-slate-400 text-xs">inactive</span>{% endif %}</td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="py-4 text-center text-slate-400">No vouchers.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </section>
</div>
{% endblock %}
