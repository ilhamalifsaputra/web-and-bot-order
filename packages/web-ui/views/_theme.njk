{# Shared "Clean Modern" theme — included from the <head> of BOTH web-admin and
   the storefront base.njk so the two webs stay one visual family. Source of
   truth for every design token (colours, fonts, radius, shadows) and the
   component @layer. Change a token here → both webs change.
   Extracted from apps/web-admin/views/base.njk (plan.md §6, decision B). #}

{# Clean Modern type system: Outfit (headings) + Manrope (body) +
   JetBrains Mono (order codes / ids). The colour tokens keep their names
   (paper/card/ink/pine/amberx/rust) so every view re-skins from here. #}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script>
  // Clean Modern palette — cool off-white background, confident blue accent.
  // ("pine" token now carries the blue so views need no edits.)
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          paper: "#f6f8fb",
          card:  "#ffffff",
          sand:  "#eef1f6",
          line:  "#e3e8ef",
          ink:   { DEFAULT: "#1b2330", soft: "#5a6473", faint: "#97a1b1" },
          pine:  { DEFAULT: "#2563eb", dark: "#1d4ed8", tint: "#e6effe" },
          grass: { DEFAULT: "#16a34a", dark: "#15803d", tint: "#e7f6ec" },
          amberx:{ DEFAULT: "#b45c0a", tint: "#fdedcf" },
          rust:  { DEFAULT: "#dc2626", dark: "#b91c1c", tint: "#fde7e7" },
        },
        fontFamily: {
          display: ['Outfit', 'system-ui', 'sans-serif'],
          sans: ['Manrope', 'system-ui', 'sans-serif'],
          mono: ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
        },
        boxShadow: {
          soft: "0 1px 2px rgba(16,24,40,.04), 0 8px 24px -14px rgba(16,24,40,.12)",
          lift: "0 2px 4px rgba(16,24,40,.06), 0 16px 36px -18px rgba(16,24,40,.18)",
        },
        borderRadius: { xl2: "1.25rem" },
      },
    },
  };
</script>

<style>
  /* Component classes as plain CSS — works regardless of which Tailwind CDN
     version is loaded. CSS variables come from app.css :root (with hardcoded
     fallbacks so the page looks correct even before app.css resolves). */

  /* Base */
  body { font-family: 'Manrope', system-ui, sans-serif; background-color: var(--paper, #f6f8fb); color: var(--ink, #1b2330); -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  h1, h2, h3 { font-family: 'Outfit', system-ui, sans-serif; }

  /* Surfaces */
  .card     { background: var(--card, #fff); border-radius: 1rem; border: 1px solid var(--line, #e3e8ef); box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 8px 24px -14px rgba(16,24,40,.12); }
  .card-pad { padding: 1.25rem; }
  @media (min-width: 640px) { .card-pad { padding: 1.5rem; } }

  /* Headings */
  .page-title    { font-family: 'Outfit', system-ui, sans-serif; font-size: 1.875rem; font-weight: 600; letter-spacing: -0.025em; color: var(--ink, #1b2330); display: flex; align-items: center; gap: 0.625rem; }
  .page-lead     { font-size: 0.875rem; color: var(--ink-soft, #5a6473); margin-top: 0.25rem; }
  .section-title { font-family: 'Outfit', system-ui, sans-serif; font-size: 1.125rem; font-weight: 600; color: var(--ink, #1b2330); }

  /* Buttons */
  .btn         { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; border-radius: 0.75rem; padding: 0.5rem 1rem; font-size: 0.875rem; font-weight: 600; transition: background-color .15s, color .15s, box-shadow .15s; cursor: pointer; border: none; text-decoration: none; line-height: 1.25; }
  .btn:focus-visible { outline: none; box-shadow: 0 0 0 3px rgba(37,99,235,.35); }
  .btn-primary { background: var(--pine, #2563eb); color: #fff; box-shadow: 0 1px 2px rgba(16,24,40,.04), 0 8px 24px -14px rgba(16,24,40,.12); }
  .btn-primary:hover { background: var(--pine-dark, #1d4ed8); }
  .btn-soft    { background: var(--pine-tint, #e6effe); color: var(--pine-dark, #1d4ed8); }
  .btn-soft:hover { background: rgba(37,99,235,.15); }
  .btn-ghost   { color: var(--ink-soft, #5a6473); background: transparent; }
  .btn-ghost:hover { background: var(--sand, #eef1f6); color: var(--ink, #1b2330); }
  .btn-danger  { background: var(--rust, #dc2626); color: #fff; }
  .btn-danger:hover { background: var(--rust-dark, #b91c1c); }
  .btn-sm      { padding: .375rem .75rem; font-size: .75rem; border-radius: .5rem; }

  /* Forms */
  .field-label { display: block; font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-soft, #5a6473); margin-bottom: .375rem; }
  .field       { display: block; width: 100%; border-radius: .75rem; border: 1px solid var(--line, #e3e8ef); background: #fff; padding: .5rem .75rem; font-size: .875rem; color: var(--ink, #1b2330); transition: border-color .15s, box-shadow .15s; outline: none; font-family: inherit; box-sizing: border-box; }
  .field::placeholder { color: var(--ink-faint, #97a1b1); }
  .field:focus { border-color: var(--pine, #2563eb); box-shadow: 0 0 0 3px rgba(37,99,235,.2); outline: none; }
  select.field { -webkit-appearance: auto; appearance: auto; }
  input[type="file"].field { -webkit-appearance: auto; appearance: auto; padding: .25rem .5rem; }
  textarea.field { resize: vertical; }

  /* Stats */
  .stat-label { font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-soft, #5a6473); }
  .stat-value { font-family: 'Outfit', system-ui, sans-serif; font-size: 1.875rem; font-weight: 600; color: var(--ink, #1b2330); margin-top: .5rem; line-height: 1; }
  .stat-sub   { font-size: .75rem; color: var(--ink-soft, #5a6473); margin-top: .5rem; }

  /* Tables */
  .data-table          { min-width: 100%; font-size: .875rem; border-collapse: collapse; }
  .data-table thead th { padding: .75rem 1rem; text-align: left; font-size: .7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: var(--ink-soft, #5a6473); background: rgba(238,241,246,.5); }
  .data-table tbody td { padding: .75rem 1rem; vertical-align: middle; }
  .data-table tbody tr { border-top: 1px solid var(--line, #e3e8ef); }
  .data-table tbody tr:hover { background: rgba(238,241,246,.3); }

  /* Misc */
  .link    { color: var(--pine, #2563eb); font-weight: 600; text-decoration: none; text-underline-offset: .125rem; }
  .link:hover { color: var(--pine-dark, #1d4ed8); text-decoration: underline; }
  .codeish { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: .75rem; background: rgba(238,241,246,.6); border-radius: .25rem; padding: .125rem .375rem; color: var(--ink, #1b2330); }
  .chip    { display: inline-flex; align-items: center; gap: .25rem; border-radius: 9999px; padding: .125rem .625rem; font-size: .75rem; font-weight: 600; }
</style>

<script src="https://unpkg.com/htmx.org@2.0.3" defer></script>
{# Lucide — free open-source icons (https://lucide.dev). Stroke icons inherit
   currentColor, so a text-* class tints them. #}
<script src="https://unpkg.com/lucide@latest"></script>
<link rel="stylesheet" href="/static/app.css">
<style>
  /* Icons sit on the text baseline and never shrink in flex rows. */
  [data-lucide], svg.lucide { display: inline-block; vertical-align: -0.125em; flex-shrink: 0; }
</style>
