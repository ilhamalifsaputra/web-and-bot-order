{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Settings · Shop Admin{% endblock %}

{% block content %}
{{ ui.page_header('Settings', "Your shop's options and your sign-in security — grouped by what they change.", 'settings', 'settings') }}
{{ ui.flash(msg, kind) }}

<p class="text-xs text-ink-soft mb-5 flex items-center gap-2">
  <i data-lucide="info" class="w-3.5 h-3.5"></i>
  Most changes take effect immediately. Fields marked
  <span class="chip bg-amberx-tint text-amberx text-[11px] whitespace-nowrap"><i data-lucide="rotate-cw" class="w-3 h-3"></i> restart needed</span>
  only apply after you restart the app.
</p>

{% macro setting_form(fld) %}
<form method="post" action="/settings/edit" class="flex gap-2 items-end">
  {{ ui.csrf_field(admin) }}
  <input type="hidden" name="key" value="{{ fld.key }}">
  <div class="flex-1">
    <label class="field-label flex flex-wrap items-center gap-2">
      <span>{{ fld.label }}</span>
      {% if fld.needs_restart %}<span class="chip bg-amberx-tint text-amberx text-[11px] whitespace-nowrap"><i data-lucide="rotate-cw" class="w-3 h-3"></i> restart needed</span>{% endif %}
    </label>
    {% if fld.secret %}
    {# Write-only: the saved value is never echoed back; blank = keep it. #}
    <input type="password" name="value" value="" autocomplete="new-password" class="field"
           placeholder="{% if fld.has_value %}●●● saved — leave blank to keep{% else %}not set yet{% endif %}">
    {% else %}
    <input type="text" name="value" value="{{ fld.value }}" class="field">
    {% endif %}
  </div>
  <button class="btn btn-soft">Save</button>
</form>
{% endmacro %}

{# ── Tab bar: one topic on screen at a time, nothing piled up. ── #}
{% set tabs = [
  { id: "website",  icon: "globe",     label: "Website" },
  { id: "payments", icon: "wallet",    label: "Payments" },
  { id: "bot",      icon: "bot",       label: "Telegram bot" },
  { id: "security", icon: "lock",      label: "Security" },
  { id: "all",      icon: "list",      label: "All saved data" }
] %}
<div id="settings-tabs" class="flex flex-wrap gap-2 mb-6" role="tablist">
  {% for tab in tabs %}
  <button type="button" role="tab" data-tab="{{ tab.id }}"
          class="chip !px-3.5 !py-2 transition-colors bg-sand text-ink-soft hover:bg-pine-tint hover:text-pine-dark">
    <i data-lucide="{{ tab.icon }}" class="w-4 h-4"></i> {{ tab.label }}
  </button>
  {% endfor %}
</div>

{# ════ Website — what customers see on the online store ════ #}
<section data-panel="website" class="space-y-6">
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="globe" class="w-5 h-5 text-sky-500"></i> Your online store
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      These appear on the website your customers visit: the name in the header,
      the tagline, and the WhatsApp button on the home page.
    </p>
    <div class="space-y-3">
      {% for fld in website_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>
</section>

{# ════ Payments — split per method so nothing gets mixed up ════ #}
<section data-panel="payments" class="space-y-6">
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="refresh-cw" class="w-5 h-5 text-sky-500"></i> USDT rate
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      Prices are set in Rupiah. The USDT rate follows the real market rate
      (rounded, refreshed hourly) and is shown next to prices on the website.
    </p>
    <form method="post" action="/settings/fx/refresh" class="mb-4">
      {{ ui.csrf_field(admin) }}
      <button class="btn btn-soft btn-sm flex items-center gap-1.5">
        <i data-lucide="refresh-cw" class="w-4 h-4"></i> Update USDT rate from the market now
      </button>
    </form>
    <div class="space-y-3">
      {% for fld in pay_rate_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card card-pad">
      <h2 class="section-title mb-1 flex items-center gap-2">
        <i data-lucide="qr-code" class="w-5 h-5 text-sky-500"></i> Rupiah (QRIS) on the website
      </h2>
      <p class="text-xs text-ink-soft mb-4">
        The TokoPay keys turn on Rupiah (QRIS) payments at checkout on the website.
      </p>
      <div class="space-y-3">
        {% for fld in pay_qris_fields %}{{ setting_form(fld) }}{% endfor %}
      </div>
    </div>

    <div class="card card-pad">
      <h2 class="section-title mb-1 flex items-center gap-2">
        <i data-lucide="coins" class="w-5 h-5 text-sky-500"></i> USDT via Binance
      </h2>
      <p class="text-xs text-ink-soft mb-4">
        Shown to buyers who pay with USDT: your Binance Pay ID at checkout, and
        the QR image the bot sends for payment.
      </p>

      {% if qr_is_upload %}
      <div class="flex items-center gap-2 mb-3">
        <img src="{{ qr_url }}" alt="Current payment QR" class="w-20 h-20 rounded border border-sand object-contain bg-sand/40">
        <span class="text-xs text-ink-soft">Current QR — uploading a new one will replace it.</span>
      </div>
      {% endif %}
      <form method="post" action="/settings/qr" enctype="multipart/form-data" class="flex items-center gap-2 mb-4">
        <input type="hidden" name="csrf_token" value="{{ admin.csrf }}">
        <input type="file" name="qr_image" accept="image/jpeg,image/png,image/webp" required
               class="field text-sm file:mr-2 file:btn file:btn-soft file:border-0 file:text-xs">
        <button class="btn btn-primary btn-sm whitespace-nowrap">Upload QR</button>
      </form>

      <div class="space-y-3">
        {% for fld in pay_binance_fields %}{{ setting_form(fld) }}{% endfor %}
      </div>
    </div>
  </div>

  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="qr-code" class="w-5 h-5 text-sky-500"></i> Rupiah (QRIS/e-wallet) via PayDisini di website
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      The PayDisini keys turn on Rupiah (QRIS/e-wallet) payments at checkout on the website.
    </p>
    <div class="space-y-3">
      {% for fld in pay_paydisini_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>

  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="bitcoin" class="w-5 h-5 text-sky-500"></i> USDT via NOWPayments (hosted crypto invoice)
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      The NOWPayments keys turn on USDT payments at checkout on the website via a
      hosted crypto invoice. The pay currency selects the underlying crypto
      network/rail (e.g. <span class="codeish">usdttrc20</span> for USDT on TRON).
    </p>
    <div class="space-y-3">
      {% for fld in pay_nowpayments_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>

  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="link" class="w-5 h-5 text-sky-500"></i> USDT on BSC via Bybit (auto-confirm)
    </h2>
    <div class="text-xs text-ink-soft mb-4 space-y-1.5">
      <p>
        Fill all three to turn on automatic USDT payments: buyers send to your
        <strong class="text-ink">BEP20 (BNB Smart Chain)</strong> deposit address, and the bot
        confirms &amp; delivers on its own. Leave any blank to hide this option.
      </p>
      <p>
        The API key must be <strong class="text-ink">Wallet read-only</strong> (no Withdraw permission).
        Saved keys are hidden — leave a field blank to keep the current value.
        Takes effect within seconds, no restart needed.
      </p>
    </div>
    <div class="space-y-3">
      {% for fld in pay_bybit_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>

  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="arrow-left-right" class="w-5 h-5 text-sky-500"></i> USDT via Binance Internal Transfer (auto-confirm)
    </h2>
    <div class="text-xs text-ink-soft mb-4 space-y-1.5">
      <p>
        Fill all three to turn on automatic USDT payments: buyers send via
        <strong class="text-ink">Binance Internal Transfer</strong> to your UID, and the bot
        confirms &amp; delivers on its own. Leave any blank to hide this option.
      </p>
      <p>
        The API key must be <strong class="text-ink">read-only</strong> (no trading/withdraw).
        Saved keys are hidden — leave a field blank to keep the current value.
        Takes effect within seconds, no restart needed.
      </p>
    </div>
    <div class="space-y-3">
      {% for fld in pay_binance_internal_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>
</section>

{# ════ Telegram bot — messages the bot sends + its tokens ════ #}
<section data-panel="bot" class="space-y-6">
  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="message-square" class="w-5 h-5 text-sky-500"></i> Bot messages &amp; look
    </h2>
    <p class="text-xs text-ink-soft mb-4">
      What the Telegram bot shows to buyers: the welcome message, the banner
      image on its menu, and the support contact it hands out.
    </p>
    <div class="space-y-3">
      {% for fld in bot_message_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>

  <div class="card card-pad">
    <h2 class="section-title mb-1 flex items-center gap-2">
      <i data-lucide="key-round" class="w-5 h-5 text-sky-500"></i> Bot tokens
    </h2>
    <div class="text-xs text-ink-soft mb-4 space-y-1.5">
      <p>
        <strong class="text-ink">Order Bot</strong> — the main bot your customers talk to.
        It handles all orders and sends delivery messages.
        Get its token from <span class="codeish">@BotFather → /mybots → API Token</span>.
      </p>
      <p>
        <strong class="text-ink">Channel Notifier Bot</strong> — an optional <em>second</em> bot
        used only for posting announcements to your public channel.
        Leave blank if you want the Order Bot to post to the channel too.
      </p>
      <p>
        Tokens are verified with Telegram before saving.
        The app must <strong class="text-ink">restart</strong> before a new token takes effect.
        {% if not is_owner %}<span class="text-amberx">Only the owner can change these.</span>{% endif %}
        Type <span class="codeish">-</span> to remove a saved token and fall back to the server's own config.
      </p>
    </div>
    <div class="space-y-3">
      {% for fld in bot_token_fields %}{{ setting_form(fld) }}{% endfor %}
    </div>
  </div>
</section>

{# ════ Security — your own sign-in ════ #}
<section data-panel="security" class="space-y-6">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card card-pad">
      <h2 class="section-title mb-3 flex items-center gap-2">
        <i data-lucide="key" class="w-5 h-5 text-sky-500"></i> Change your password
      </h2>
      <form method="post" action="/settings/password" class="space-y-3 text-sm">
        {{ ui.csrf_field(admin) }}
        <div><label class="field-label">Current password</label>
          <input type="password" name="current_password" required autocomplete="current-password" class="field"></div>
        <div><label class="field-label">New password (at least 8 characters)</label>
          <input type="password" name="new_password" required minlength="8" autocomplete="new-password" class="field"></div>
        <div><label class="field-label">Type the new password again</label>
          <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password" class="field"></div>
        <button class="btn btn-primary">Change password</button>
      </form>
    </div>

    <div class="card card-pad">
      <h2 class="section-title mb-3 flex items-center gap-2">
        <i data-lucide="shield-check" class="w-5 h-5 text-sky-500"></i> Two-step sign-in
        {% if two_fa_enabled %}<span class="chip bg-grass-tint text-grass-dark">On</span>
        {% else %}<span class="chip bg-sand text-ink-soft">Off</span>{% endif %}
      </h2>

      {% if two_fa_enabled %}
      <p class="text-sm text-ink-soft mb-3">You'll be asked for a code from your authenticator app every time you sign in.</p>
      <form method="post" action="/settings/2fa/disable" class="flex flex-wrap gap-2 items-end text-sm">
        {{ ui.csrf_field(admin) }}
        <div><label class="field-label">Current password</label>
          <input type="password" name="current_password" required class="field"></div>
        <div><label class="field-label">Code from your app</label>
          <input type="text" name="totp_code" inputmode="numeric" required placeholder="6-digit code" class="field w-32"></div>
        <button class="btn btn-danger">Turn off</button>
      </form>

      {% elif two_fa_pending %}
      <p class="text-sm text-ink mb-2">1. Add this key to your authenticator app (Google Authenticator, Authy, and so on):</p>
      <div class="font-mono text-sm bg-sand/60 rounded-xl px-3 py-2 break-all mb-2">{{ two_fa_pending.secret }}</div>
      <p class="text-xs text-ink-faint mb-3 break-all">Or scan/paste this link: <span class="font-mono">{{ two_fa_pending.uri }}</span></p>
      <p class="text-sm text-ink mb-2">2. Enter the current 6-digit code to confirm:</p>
      <form method="post" action="/settings/2fa/enable" class="flex gap-2 items-center text-sm">
        {{ ui.csrf_field(admin) }}
        <input type="text" name="totp_code" inputmode="numeric" required placeholder="6-digit code" class="field w-32">
        <button class="btn btn-primary">Turn on</button>
      </form>
      <form method="post" action="/settings/2fa/cancel" class="mt-2">
        {{ ui.csrf_field(admin) }}
        <button class="text-xs text-ink-soft hover:underline">Cancel</button>
      </form>

      {% else %}
      <p class="text-sm text-ink-soft mb-3">Add a one-time code on top of your password. Strongly recommended — this dashboard can move money.</p>
      <form method="post" action="/settings/2fa/begin">
        {{ ui.csrf_field(admin) }}
        <button class="btn btn-primary">Set up two-step sign-in</button>
      </form>
      {% endif %}
    </div>
  </div>
</section>

{# ════ All saved data — the raw table, for checking what's stored ════ #}
<section data-panel="all" class="space-y-6">
  <div class="card overflow-x-auto">
    <div class="px-5 pt-4 section-title">All saved options</div>
    <p class="px-5 text-xs text-ink-soft mt-1">
      Everything stored in the shop's settings, read-only. Rows marked
      <span class="text-pine">✎</span> can be edited in the tabs above.
    </p>
    <table class="data-table mt-2">
      <thead>
        <tr><th>Name</th><th>Value</th><th>Updated</th></tr>
      </thead>
      <tbody>
        {% for r in rows %}
        <tr>
          <td class="font-mono text-xs">{{ r.key }}{% if r.editable %}<span class="ml-1 text-pine">✎</span>{% endif %}</td>
          <td class="break-all">{{ r.value }}</td>
          <td class="text-ink-soft">{{ r.updated_at | localdt }}</td>
        </tr>
        {% else %}
        {{ ui.empty_row(3, 'No options saved.') }}
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<script>
(function () {
  'use strict';
  // Simple tabs: one panel visible at a time. The choice survives in-page via the
  // URL hash, and — crucially — across the save round-trip too: every settings
  // form POSTs and the server 303-redirects back to /settings, and the URL hash
  // is NEVER sent to the server, so it's lost on the redirect. We stash the
  // active tab in sessionStorage on submit and restore it on the next load, so
  // saving keeps you on the tab you were editing instead of snapping back to the
  // first one. Without JS all panels stay visible.
  var PENDING_KEY = 'settings:tabAfterSave';
  var tabs = document.querySelectorAll('#settings-tabs [data-tab]');
  var panels = document.querySelectorAll('[data-panel]');
  var ids = Array.prototype.map.call(tabs, function (b) { return b.dataset.tab; });
  var current = ids[0];

  function show(id) {
    current = id;
    panels.forEach(function (p) { p.hidden = p.dataset.panel !== id; });
    tabs.forEach(function (b) {
      var on = b.dataset.tab === id;
      b.classList.toggle('!bg-pine', on);
      b.classList.toggle('!text-white', on);
      b.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    if (history.replaceState) history.replaceState(null, '', '#' + id);
  }

  tabs.forEach(function (b) {
    b.addEventListener('click', function () { show(b.dataset.tab); });
  });

  // Remember the active tab right before any settings form submits, so the
  // post-redirect load can land us back here.
  document.querySelectorAll('[data-panel] form').forEach(function (f) {
    f.addEventListener('submit', function () {
      try { sessionStorage.setItem(PENDING_KEY, current); } catch (e) { /* private mode */ }
    });
  });

  // One-shot restore after a save redirect; the hash (if present) still wins.
  var pending = null;
  try {
    pending = sessionStorage.getItem(PENDING_KEY);
    if (pending) sessionStorage.removeItem(PENDING_KEY);
  } catch (e) { /* private mode */ }

  var initial = location.hash.slice(1);
  if (ids.indexOf(initial) < 0 && pending && ids.indexOf(pending) >= 0) initial = pending;
  show(ids.indexOf(initial) >= 0 ? initial : ids[0]);
}());
</script>
{% endblock %}
