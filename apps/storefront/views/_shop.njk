{# Storefront-only macros on top of the shared theme (design.md §4). Import:
   {% import "_shop.njk" as shop %}
   The shared admin macros (_macros.njk: ic, flash, status_badge, …) come from
   packages/web-ui/views and are imported separately as `ui`. #}

{# Price tag (design.md §4.4 + §8b): the central IDR price as the main figure
   with the derived USDT (rounded, informational) BESIDE it — for every buyer.
   `fx` = usd_idr_rate as a string, or null/empty to hide the USDT info. #}
{% macro price(idr_value, fx, size="text-sm") -%}
<span class="inline-flex items-baseline gap-1.5 whitespace-nowrap">
  <span class="font-semibold text-pine {{ size }}">{{ idr_value | idr }}</span>
  {%- if fx %}<span class="text-ink-faint text-xs">{{ idr_value | usdt(fx) }}</span>{% endif -%}
</span>
{%- endmacro %}

{# Stock badge (design.md §4.3): honest, real-time stock from the shared DB. #}
{% macro stock_badge(count, low, lang) -%}
{% if count > low %}
<span class="rounded-full bg-grass-tint px-2.5 py-1 text-xs font-medium text-grass-dark">{{ t('web.stock_available', lang) }}</span>
{% elif count > 0 %}
<span class="rounded-full bg-amberx-tint px-2.5 py-1 text-xs font-medium text-amberx">{{ t('web.stock_left', lang, { count: count }) }}</span>
{% else %}
<span class="rounded-full bg-rust-tint px-2.5 py-1 text-xs font-medium text-rust-dark">{{ t('web.stock_out', lang) }}</span>
{% endif %}
{%- endmacro %}

{# Star rating (design.md §4.7): 5 lucide stars, filled = amber, empty = line. #}
{% macro stars(rating, cls="w-3.5 h-3.5") -%}
<span class="inline-flex items-center gap-0.5" aria-label="{{ rating | round(1) }}/5">
  {%- for i in [1, 2, 3, 4, 5] -%}
  <i data-lucide="star" class="{{ cls }} {% if rating >= i - 0.5 %}text-amber-400 fill-amber-400{% else %}text-line{% endif %}"></i>
  {%- endfor -%}
</span>
{%- endmacro %}

{# Product card (design.md §4.2) for the grid pages. #}
{% macro product_card(p, fx, low, lang) -%}
<a href="/p/{{ p.slug }}"
   class="group overflow-hidden rounded-2xl border border-line bg-card shadow-sm transition hover:shadow-md hover:border-pine-tint flex flex-col">
  <div class="relative flex h-44 items-center justify-center bg-sand overflow-hidden shrink-0">
    {% if p.image %}
    <img src="{{ p.image }}" alt="{{ p.name }}" loading="lazy" decoding="async"
         class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300">
    {% else %}
    <div class="absolute inset-0 bg-gradient-to-br from-ink to-ink-soft"></div>
    <span class="relative z-10 text-2xl font-bold text-white/90 px-4 text-center line-clamp-2">{{ p.name }}</span>
    {% endif %}
    
    {# Real quantity-discount badge (bulk pricing), corner of the photo. #}
    {% if p.bulk_discount %}
    <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-rust/90 px-2.5 py-1 text-xs font-medium text-white shadow-sm backdrop-blur">
      −{{ p.bulk_discount | float | round | int }}%
    </span>
    {% endif %}
    {# Instant auto-delivery is this shop's headline perk — flag it on the grid. #}
    <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-black/40 px-2.5 py-1 text-xs font-medium text-amber-300 backdrop-blur">
      <i data-lucide="zap" class="w-3 h-3"></i> {{ t('web.badge_instant', lang) }}
    </span>
  </div>
  <div class="p-4 flex flex-col flex-1">
    <h3 class="font-semibold text-ink line-clamp-1">{{ p.name }}</h3>
    <p class="text-sm text-ink-faint">
      {{ p.category_name }}
      {% if p.variant_count > 1 %}
      <span class="text-ink-soft">·</span> <span class="text-pine">{{ t('web.group_options', lang, { count: p.variant_count }) }}</span>
      {% endif %}
    </p>

    {% if p.rating_count > 0 %}
    <div class="flex items-center gap-1.5 text-xs text-ink-soft mt-1">
      {{ stars(p.rating) }} <span>{{ p.rating | round(1) }}</span>
      <span class="text-ink-faint">· {{ t('web.review_count', lang, { count: p.rating_count }) }}</span>
    </div>
    {% endif %}
    
    <div class="mt-auto pt-3 flex items-center justify-between gap-2 flex-wrap">
      <p class="text-sm text-ink-soft inline-flex items-baseline gap-1">
        {{ t('web.from_price', lang) }}
        {{ price(p.from_price, fx, "text-sm") }}
      </p>
      {{ stock_badge(p.available, low, lang) }}
    </div>
    
    {% if p.bulk_discount and p.bulk_min_qty %}
    <div class="text-[0.7rem] text-grass-dark font-medium flex items-center gap-1 mt-2">
      <i data-lucide="tag" class="w-3 h-3"></i>
      {{ t('web.bulk_hint', lang, { qty: p.bulk_min_qty, percent: p.bulk_discount | float | round | int }) }}
    </div>
    {% endif %}
  </div>
</a>
{%- endmacro %}

{# Breadcrumb (Home > Category > Product) for product detail. `crumbs` is a list
   of {label, href} where the LAST crumb is the current page (no link). #}
{% macro breadcrumb(crumbs, lang) -%}
<nav class="text-xs text-ink-faint mb-2 flex items-center flex-wrap gap-x-1" aria-label="breadcrumb">
  {%- for c in crumbs -%}
  {% if c.href and not loop.last %}<a href="{{ c.href }}" class="hover:text-pine">{{ c.label }}</a>{% else %}<span class="text-ink-soft">{{ c.label }}</span>{% endif %}
  {%- if not loop.last %}<span class="mx-0.5">/</span>{% endif -%}
  {%- endfor -%}
</nav>
{%- endmacro %}

{# Denomination (plan/variant) card on the product detail page (design.md §4.2).
   Selectable — clicking sets the active denomination (price/stock/checkout
   payload) via the small JS on product.njk. Expects: {id, name, duration_label,
   price, available, in_stock}. #}
{% macro denomination_card(d, fx, low, lang) -%}
<label class="denom-card card card-pad cursor-pointer flex items-center justify-between gap-3 transition-all duration-150 hover:shadow-lift has-[:checked]:ring-2 has-[:checked]:ring-pine has-[:checked]:bg-pine-tint/40 {% if not d.in_stock %}opacity-60{% endif %}"
       data-denom-id="{{ d.id }}" data-price="{{ d.price }}" data-available="{{ d.available }}"
       data-label="{{ d.name }}">
  <div class="flex items-center gap-3 min-w-0">
    <input type="radio" name="denomination_id" value="{{ d.id }}" form="buy-form" class="denom-radio accent-pine shrink-0"
           {% if not d.in_stock %}disabled{% endif %}>
    <div class="min-w-0">
      <div class="font-display text-sm font-semibold text-ink leading-snug">{{ d.duration_label or d.name }}</div>
      <div class="mt-0.5">{{ stock_badge(d.available, low, lang) }}</div>
    </div>
  </div>
  <div class="text-right shrink-0">{{ price(d.price, fx, "text-sm") }}</div>
</label>
{%- endmacro %}

{# Checkout stepper (design.md §4.6): 1 Keranjang → 2 Pembayaran → 3 Selesai. #}
{% macro stepper(step, lang) -%}
{% set labels = [t('web.step_cart', lang), t('web.step_pay', lang), t('web.step_done', lang)] %}
<ol class="flex items-center gap-2 text-xs font-semibold mb-6">
  {% for label in labels %}
  {% set n = loop.index %}
  <li class="chip {% if n < step %}bg-grass-tint text-grass-dark{% elif n == step %}bg-pine text-white{% else %}bg-sand text-ink-soft{% endif %}">
    {{ n }} · {{ label }}
  </li>
  {% if not loop.last %}<i data-lucide="chevron-right" class="h-3.5 w-3.5 text-ink-faint"></i>{% endif %}
  {% endfor %}
</ol>
{%- endmacro %}
