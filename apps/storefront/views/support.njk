{% extends "base.njk" %}
{% import "_macros.njk" as ui %}

{% block title %}{{ t('web.account_support', lang) }} — {{ shop_name }}{% endblock %}

{% block content %}
<h1 class="page-title mb-6">{{ t('web.account_support', lang) }}</h1>

<form method="post" action="/account/support" class="card card-pad mb-6">
  {{ ui.csrf_field(customer) }}
  <div class="field-label">{{ t('web.support_new', lang) }}</div>
  <textarea name="message" rows="3" required class="field" placeholder="{{ t('web.support_placeholder', lang) }}"></textarea>
  <div class="mt-3 text-right">
    <button type="submit" class="btn btn-primary btn-sm">
      <i data-lucide="send" class="w-3.5 h-3.5"></i> {{ t('web.support_send', lang) }}
    </button>
  </div>
</form>

<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr>
        <th>{{ t('web.ticket', lang) }}</th>
        <th>{{ t('web.order_status', lang) }}</th>
        <th>{{ t('web.order_date', lang) }}</th>
      </tr>
    </thead>
    <tbody>
      {% for tk in tickets %}
      <tr>
        <td>
          <a href="/account/support/{{ tk.id }}" class="link">#{{ tk.id }}</a>
          <div class="text-xs text-ink-soft max-w-[20rem] truncate">{{ tk.message }}</div>
        </td>
        <td>{{ ui.status_badge(tk.status) }}</td>
        <td class="text-ink-soft text-xs">{{ tk.created_at | localdt }}</td>
      </tr>
      {% else %}
      {{ ui.empty_row(3, t('web.no_tickets', lang)) }}
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
