# Copy to .env and fill in real values. NEVER commit .env.
# The Node services read DATABASE_URL_PRISMA; the legacy Python stack reads DATABASE_URL.

# ---------------------------------------------------------------------
# TELEGRAM
# ---------------------------------------------------------------------
BOT_TOKEN=123456:your-bot-token
BOT_USERNAME=YourBot
ADMIN_IDS=11111111,22222222
# SUPPORT_GROUP_ID=-1001234567890

# ---------------------------------------------------------------------
# PAYMENT — Binance Pay (existing, manual proof + admin approval)
# ---------------------------------------------------------------------
BINANCE_PAY_ID=123456789
# BINANCE_QR_PATH=
CURRENCY=USDT
PAYMENT_WINDOW_MINUTES=30
USE_UNIQUE_CENTS=1

# ---------------------------------------------------------------------
# PAYMENT — Binance Internal Transfer (UID-based, auto-confirmed)
# Leave the API key/secret + UID blank to hide this option and disable the
# poller. The API key MUST be READ-ONLY (no trading/withdrawal permissions).
# ---------------------------------------------------------------------
BINANCE_RECEIVE_UID=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_BASE=https://api.binance.com
POLL_INTERVAL_SECONDS=10
INTERNAL_PAYMENT_WINDOW_MINUTES=15
# Optional: show an IDR equivalent on the instructions (USDT * rate).
# USDT_IDR_RATE=16300

# ---------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------
# Prisma (file: URL; in Docker use an absolute path file:/app/data/bot.db).
DATABASE_URL_PRISMA=file:../data/bot.db

# ---------------------------------------------------------------------
# BEHAVIOUR / TUNING
# ---------------------------------------------------------------------
DEFAULT_LANGUAGE=en
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=3
REFERRAL_COMMISSION_PERCENT=10
DEFAULT_WARRANTY_DAYS=30
LOW_STOCK_THRESHOLD=3
TIMEZONE=Asia/Jakarta

# ---------------------------------------------------------------------
# LOGGING
# ---------------------------------------------------------------------
# debug | info | warn | error  (lowercase)
LOG_LEVEL=info

# ---------------------------------------------------------------------
# WEB ADMIN
# ---------------------------------------------------------------------
WEB_COOKIE_SECRET=change-me-to-a-random-string-of-at-least-32-characters
WEB_COOKIE_NAME=stockweb_session
WEB_SESSION_TTL_HOURS=12
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ---------------------------------------------------------------------
# NOTIFIER (testimoni bot)
# ---------------------------------------------------------------------
# NOTIF_BOT_TOKEN=
# PUBLIC_CHANNEL_ID=-100...
NOTIF_POLL_INTERVAL_SECONDS=10
NOTIF_MAX_ATTEMPTS=5
