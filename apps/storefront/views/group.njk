{% extends "base.njk" %}
{% import "_shop.njk" as shop %}

{% block title %}{{ group.name }} — {{ shop_name }}{% endblock %}

{% block content %}
<div class="mb-6">
  <h1 class="page-title">{% if group.emoji %}{{ group.emoji }} {% endif %}{{ group.name }}</h1>
  {% if group.description %}<p class="mt-2 text-sm text-ink-soft">{{ group.description }}</p>{% endif %}
</div>

{% if denominations.length %}
<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
  {% for d in denominations %}
  <a href="/p/{{ d.id }}"
     class="card overflow-hidden flex flex-col group transition-all duration-150 hover:shadow-lift hover:-translate-y-0.5">
    <div class="aspect-[4/3] bg-sand overflow-hidden relative">
      <img src="{{ d.image }}" alt="{{ d.name }}" loading="lazy" decoding="async"
           class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-300">
    </div>
    <div class="p-3.5 flex flex-col gap-1.5 flex-1">
      <div class="font-display text-sm font-semibold text-ink leading-snug line-clamp-2">
        {{ d.duration_label or d.name }}
      </div>
      <div class="mt-auto pt-2">
        {{ shop.price(d.price, fx, "text-sm") }}
      </div>
    </div>
  </a>
  {% endfor %}
</div>
{% else %}
<div class="card card-pad text-center text-ink-faint py-14">{{ t('web.catalog_empty', lang) }}</div>
{% endif %}
{% endblock %}
