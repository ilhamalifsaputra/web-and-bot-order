{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}{{ user.fullName or user.telegramId }} · Users{% endblock %}

{% block content %}
<div class="mb-6">
  <a href="/users" class="text-sm text-slate-500 hover:underline">← Users</a>
  <h1 class="text-2xl font-semibold mt-1">
    {{ user.fullName or user.username or ('tg:' + (user.telegramId | string)) }}
    {{ ui.status_badge(user.role) }}
    {% if user.banned %}<span class="text-red-600 text-sm">banned</span>{% endif %}
  </h1>
</div>
{{ ui.flash(msg, kind) }}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <aside class="space-y-6">
    <div class="bg-white rounded-lg shadow p-5 text-sm">
      <h2 class="font-semibold mb-3">Profile</h2>
      <dl class="space-y-1">
        <div class="flex justify-between"><dt class="text-slate-500">Telegram</dt><dd class="font-mono">{{ user.telegramId }}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Username</dt><dd>{{ user.username or '—' }}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Wallet</dt><dd>{{ user.walletBalance | money }} {{ currency }}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Total spent</dt><dd>{{ total_spent | money }} {{ currency }}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Referral code</dt><dd class="font-mono">{{ user.referralCode }}</dd></div>
        <div class="flex justify-between"><dt class="text-slate-500">Joined</dt><dd>{{ user.createdAt | localdt }}</dd></div>
        {% if user.banned and user.bannedReason %}<div class="text-red-600 text-xs mt-2">Ban reason: {{ user.bannedReason }}</div>{% endif %}
      </dl>
    </div>

    <div class="bg-white rounded-lg shadow p-5 text-sm space-y-4">
      <h2 class="font-semibold">Actions</h2>
      <form method="post" action="/users/{{ user.id }}/role" class="flex gap-2 items-end">
        {{ ui.csrf_field(admin) }}
        <div class="flex-1"><label class="block text-xs text-slate-500 mb-1">Role</label>
          <select name="role" class="border rounded px-2 py-1 w-full">
            {% for r in roles %}<option value="{{ r }}" {% if user.role == r %}selected{% endif %}>{{ r | lower }}</option>{% endfor %}
          </select></div>
        <button class="bg-slate-200 px-3 py-1.5 rounded hover:bg-slate-300">Set</button>
      </form>

      <form method="post" action="/users/{{ user.id }}/ban" class="space-y-2">
        {{ ui.csrf_field(admin) }}
        <input type="hidden" name="banned" value="{{ 'false' if user.banned else 'true' }}">
        {% if not user.banned %}
        <input type="text" name="reason" placeholder="Ban reason" class="border rounded px-2 py-1 w-full">
        <button class="bg-red-100 text-red-700 px-3 py-1.5 rounded hover:bg-red-200 w-full">Ban user</button>
        {% else %}
        <button class="bg-green-100 text-green-700 px-3 py-1.5 rounded hover:bg-green-200 w-full">Unban user</button>
        {% endif %}
      </form>

      <form method="post" action="/users/{{ user.id }}/wallet" class="space-y-2">
        {{ ui.csrf_field(admin) }}
        <label class="block text-xs text-slate-500">Wallet adjustment (+/−)</label>
        <input type="text" name="delta" placeholder="e.g. 5 or -2.5" class="border rounded px-2 py-1 w-full" required>
        <input type="text" name="note" placeholder="reason (required)" class="border rounded px-2 py-1 w-full" required>
        <button class="bg-slate-200 px-3 py-1.5 rounded hover:bg-slate-300 w-full">Adjust wallet</button>
      </form>
    </div>
  </aside>

  <section class="lg:col-span-2 space-y-6">
    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="font-semibold mb-3">Recent orders</h2>
      <table class="min-w-full text-sm">
        <thead class="text-slate-500 text-left"><tr><th class="py-1">Code</th><th class="py-1">Status</th><th class="py-1 text-right">Total</th><th class="py-1">Created</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          {% for o in orders %}
          <tr>
            <td class="py-1"><a class="font-mono text-xs text-slate-700 hover:underline" href="/orders/{{ o.id }}">{{ o.orderCode }}</a></td>
            <td class="py-1">{{ ui.status_badge(o.status) }}</td>
            <td class="py-1 text-right">{{ o.totalAmount | money }}</td>
            <td class="py-1 text-slate-500">{{ o.createdAt | localdt }}</td>
          </tr>
          {% else %}
          <tr><td colspan="4" class="py-4 text-center text-slate-400">No orders.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="font-semibold mb-3">Wallet ledger</h2>
      <p class="text-xs text-slate-400 mb-2">Manual top-ups / deductions made from the admin. Automated credits (refunds) appear under <a class="underline" href="/payments">Payments</a>.</p>
      <table class="min-w-full text-sm">
        <thead class="text-slate-500 text-left"><tr><th class="py-1">When</th><th class="py-1 text-right">Delta</th><th class="py-1">Reason</th><th class="py-1">Admin</th></tr></thead>
        <tbody class="divide-y divide-slate-100">
          {% for e in ledger %}
          <tr>
            <td class="py-1 text-slate-500">{{ e.createdAt | localdt }}</td>
            <td class="py-1 text-right font-mono {% if e.delta[0] == '-' %}text-red-600{% else %}text-green-700{% endif %}">{{ e.delta }}</td>
            <td class="py-1">{{ e.note or '—' }}</td>
            <td class="py-1 text-slate-500 font-mono text-xs">{{ e.adminId or '—' }}</td>
          </tr>
          {% else %}
          <tr><td colspan="4" class="py-4 text-center text-slate-400">No manual wallet moves.</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="bg-white rounded-lg shadow p-5">
      <h2 class="font-semibold mb-3">Support tickets</h2>
      <ul class="divide-y divide-slate-100 text-sm">
        {% for t in tickets %}
        <li class="py-2 flex items-center justify-between">
          <a class="text-slate-700 hover:underline" href="/support/{{ t.id }}">#{{ t.id }} · {{ t.message.substring(0, 60) }}</a>
          {{ ui.status_badge(t.status) }}
        </li>
        {% else %}
        <li class="py-4 text-center text-slate-400">No tickets.</li>
        {% endfor %}
      </ul>
    </div>
  </section>
</div>
{% endblock %}
