{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% import "_shop.njk" as shop %}

{% block title %}{{ t('web.account_orders', lang) }} — {{ shop_name }}{% endblock %}

{% block content %}
<h1 class="page-title mb-6">{{ t('web.account_orders', lang) }}</h1>

<div class="card overflow-x-auto">
  <table class="data-table">
    <thead>
      <tr>
        <th>{{ t('web.order_code', lang) }}</th>
        <th>{{ t('web.order_items', lang) }}</th>
        <th>{{ t('web.order_total', lang) }}</th>
        <th>{{ t('web.order_status', lang) }}</th>
        <th>{{ t('web.order_date', lang) }}</th>
      </tr>
    </thead>
    <tbody>
      {% for o in orders %}
      <tr>
        <td><a href="/account/orders/{{ o.code }}" class="link font-mono text-xs">{{ o.code }}</a></td>
        <td class="max-w-[16rem] truncate">{{ o.items }}</td>
        <td>{{ shop.price(o.total, fx, "text-sm") }}</td>
        <td>{{ ui.status_badge(o.status) }}</td>
        <td class="text-ink-soft text-xs">{{ o.created_at | localdt }}</td>
      </tr>
      {% else %}
      {{ ui.empty_row(5, t('web.no_orders', lang)) }}
      {% endfor %}
    </tbody>
  </table>
</div>
{% endblock %}
