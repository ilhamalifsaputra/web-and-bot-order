// Single Prisma schema shared by all services (order-bot, web-admin, notifier).
// Introspected from the existing production SQLite DB, then remapped to clean
// PascalCase models / camelCase fields. Every @map / @@map preserves the exact
// table & column names so the data layout stays byte-for-byte identical to the
// SQLAlchemy schema. Enums stay String for compatibility (migrate.md §5.3).
// DO NOT change column names/types — that would break the shared DB.

generator client {
  provider = "prisma-client-js"
  // No binaryTargets: the deploy runs `prisma generate` (postinstall) ON the
  // target Linux host, so "native" already produces the correct Linux query
  // engine there. Hardcoding Linux targets here would force every dev/CI machine
  // to download extra engine binaries on each generate.
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_PRISMA")
}

model User {
  id                Int       @id @default(autoincrement())
  telegramId        BigInt?   @unique(map: "ix_users_telegram_id") @map("telegram_id")
  username          String?
  fullName          String?   @map("full_name")
  /// Web-store login handle (3-32 chars [a-z0-9_], stored lowercase).
  /// Distinct from `username` (= Telegram username, bot-owned).
  loginUsername     String?   @unique(map: "ix_users_login_username") @map("login_username")
  email             String?   @unique(map: "ix_users_email")
  passwordHash      String?   @map("password_hash")
  role              String    @default("CUSTOMER")
  language          String    @default("EN")
  walletBalance     Decimal   @default(0) @map("wallet_balance")
  /// USDT credit balance (IDR balance is `walletBalance`). Spent only on USDT
  /// orders — no cross-currency conversion (dual-credit-balance design §A).
  walletBalanceUsdt Decimal   @default(0) @map("wallet_balance_usdt")
  referralCode      String    @unique(map: "ix_users_referral_code") @map("referral_code")
  referredById      Int?      @map("referred_by_id")
  banned            Boolean   @default(false)
  bannedReason      String?   @map("banned_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  lastSeenAt        DateTime? @map("last_seen_at")

  referredBy User?  @relation("UserReferral", fields: [referredById], references: [id], onUpdate: NoAction)
  referees   User[] @relation("UserReferral")

  orders               Order[]
  cartItems            CartItem[]
  reviews              Review[]
  restockSubscriptions RestockSubscription[]
  auditLogs            AuditLog[]
  ticketMessages       TicketMessage[]
  walletTransactions   WalletTransaction[]
  passwordResetTokens  PasswordResetToken[]
  referralsAsReferee   Referral?             @relation("ReferralReferee")
  referralsAsReferrer  Referral[]            @relation("ReferralReferrer")
  ticketsAsUser        SupportTicket[]       @relation("TicketUser")
  ticketsAsAdmin       SupportTicket[]       @relation("TicketAdmin")

  @@map("users")
}

/// Append-only per-user money timeline. One row per applied wallet movement,
/// written by `adjustWallet` so NOTHING that touches a balance is missed:
/// manual admin top-ups, underpaid refunds, referral payouts, order
/// payments/refunds. `balanceAfter` is the running balance at the time.
model WalletTransaction {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  delta        Decimal // signed: +credit / −debit (the amount actually applied)
  balanceAfter Decimal  @map("balance_after")
  /// Currency of this ledger row's balance/delta. Existing rows default to IDR
  /// (the system was IDR-base); USDT rows track the USDT credit balance.
  currency     String   @default("IDR")
  reason       String // machine code: admin_adjust | underpaid_refund | referral | order_payment | order_refund | adjust
  note         String?
  adminId      Int?     @map("admin_id") // acting admin (null = system/customer)
  orderId      Int?     @map("order_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "ix_wallet_transactions_user_id")
  @@map("wallet_transactions")
}

/// Forgot-password tokens for the storefront. Only the SHA-256 hex of the
/// token is stored; rows are single-use (used_at) and expire after 1 hour.
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  tokenHash String    @unique(map: "ix_password_reset_tokens_hash") @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "ix_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique(map: "sqlite_autoindex_categories_1")
  /// URL-safe handle (storefront `/c/:slug`). Backfilled from name at the
  /// catalog-rename migration; UNIQUE + NOT NULL.
  slug        String  @unique(map: "ix_categories_slug")
  emoji       String?
  description String?
  /// Web-facing category image URL (admin-set, storefront only).
  image       String?
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  products Product[]

  @@map("categories")
}

/// Mid-tier of the catalog (Category → **Product** → Denomination). The
/// customer-facing item (e.g. "CapCut Pro"); carries image/description/nav only.
/// NO price, NO stock — those live on each child Denomination (the sellable SKU).
/// Physically the old `product_groups` table, renamed to `products`.
model Product {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  name        String
  /// URL-safe handle (storefront `/p/:slug`). UNIQUE + NOT NULL.
  slug        String   @unique(map: "ix_products_slug")
  emoji       String?
  description String?
  /// Web-facing product photo URL (admin-set, storefront only). Telegram
  /// imageFileId can't be used as an <img src>; when this is null the
  /// storefront falls back to its curated Unsplash map (plan.md §8).
  webImageUrl String?  @map("web_image_url")
  imageFileId String?  @map("image_file_id")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  category      Category       @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  denominations Denomination[]

  @@index([categoryId], map: "ix_products_category_id")
  @@map("products")
}

/// Leaf of the catalog — the sellable SKU (e.g. "1 Month"). Price, cost, stock
/// and auto-delivery all live here. Physically the old `products` table, renamed
/// to `denominations`; ids are preserved so every dependent `product_id` FK
/// (stock_items, order_items, cart_items, bulk_pricing, reviews,
/// restock_subscriptions) keeps pointing at the same rows.
model Denomination {
  id                 Int      @id @default(autoincrement())
  productId          Int      @map("product_id")
  name               String
  /// URL-safe handle. UNIQUE + NOT NULL.
  slug               String   @unique(map: "ix_denominations_slug")
  description        String?
  imageFileId        String?  @map("image_file_id")
  /// Web-facing photo URL (admin-set, storefront only); null → curated fallback.
  webImageUrl        String?  @map("web_image_url")
  type               String
  durationLabel      String   @map("duration_label")
  price              Decimal
  /// Unit cost for margin reporting. Null = unknown / not tracked.
  costPrice          Decimal? @map("cost_price")
  resellerPrice      Decimal? @map("reseller_price")
  /// Source key for auto-fulfilment (e.g. provider/handler id). Null = manual.
  autoDeliverySource String?  @map("auto_delivery_source")
  warrantyDays       Int      @default(30) @map("warranty_days")
  sortOrder          Int      @default(0) @map("sort_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")

  product              Product               @relation(fields: [productId], references: [id], onUpdate: NoAction)
  stockItems           StockItem[]
  orderItems           OrderItem[]
  cartItems            CartItem[]
  reviews              Review[]
  restockSubscriptions RestockSubscription[]
  bulkPricing          BulkPricing?

  @@index([productId], map: "ix_denominations_product_id")
  @@map("denominations")
}

model StockItem {
  id          Int       @id @default(autoincrement())
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId   Int       @map("product_id")
  credentials String
  status      String    @default("AVAILABLE")
  orderId     Int?      @map("order_id")
  addedAt     DateTime  @default(now()) @map("added_at")
  reservedAt  DateTime? @map("reserved_at")
  soldAt      DateTime? @map("sold_at")
  note        String?

  // Relation field kept as `product` for source-compat; it resolves to a
  // Denomination (the SKU). Renamed to `denomination` in Phase 5 cleanup.
  product    Denomination @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order      Order?       @relation(fields: [orderId], references: [id], onUpdate: NoAction)
  orderItems OrderItem[]

  @@index([status], map: "ix_stock_items_status")
  @@index([productId], map: "ix_stock_items_product_id")
  @@index([productId, status], map: "ix_stock_product_status")
  @@map("stock_items")
}

model Order {
  id                 Int       @id @default(autoincrement())
  orderCode          String    @unique(map: "ix_orders_order_code") @map("order_code")
  userId             Int       @map("user_id")
  subtotalAmount     Decimal   @map("subtotal_amount")
  discountAmount     Decimal   @default(0) @map("discount_amount")
  uniqueCents        Decimal   @default(0) @map("unique_cents")
  totalAmount        Decimal   @map("total_amount")
  voucherId          Int?      @map("voucher_id")
  walletUsed         Decimal   @default(0) @map("wallet_used")
  bulkDiscountAmount Decimal   @default(0) @map("bulk_discount_amount")
  status             String    @default("PENDING_PAYMENT")
  /// Transaction currency, set when the buyer picks a payment method
  /// (plan.md §15): "IDR" (TokoPay) or "USDT" (Binance). Catalog prices are
  /// central IDR; rows created before this column existed are USDT-era
  /// snapshots (see scripts/convert-prices-to-idr.ts).
  currency           String    @default("IDR")
  /// Rupiah-per-USDT snapshot taken when currency=USDT, so later rate edits
  /// never change what historical orders were charged.
  fxRate             Decimal?  @map("fx_rate")
  paymentMethod      String    @default("BINANCE_PAY") @map("payment_method")
  paymentRef         String?   @unique(map: "ix_orders_payment_ref") @map("payment_ref")
  paymentMsgChatId   BigInt?   @map("payment_msg_chat_id")
  paymentMsgId       Int?      @map("payment_msg_id")
  paymentProofFileId String?   @map("payment_proof_file_id")
  binanceTxid        String?   @map("binance_txid")
  bybitTxid          String?   @map("bybit_txid")
  adminNote          String?   @map("admin_note")
  rejectionReason    String?   @map("rejection_reason")
  createdAt          DateTime  @default(now()) @map("created_at")
  expiresAt          DateTime? @map("expires_at")
  paidAt             DateTime? @map("paid_at")
  deliveredAt        DateTime? @map("delivered_at")

  user               User                 @relation(fields: [userId], references: [id], onUpdate: NoAction)
  voucher            Voucher?             @relation(fields: [voucherId], references: [id], onUpdate: NoAction)
  items              OrderItem[]
  stockItems         StockItem[]
  reviews            Review[]
  referrals          Referral[]
  notificationOutbox NotificationOutbox[]

  @@index([userId], map: "ix_orders_user_id")
  @@index([status], map: "ix_orders_status")
  @@index([binanceTxid], map: "ix_orders_binance_txid")
  @@index([bybitTxid], map: "ix_orders_bybit_txid")
  @@index([status, createdAt], map: "ix_orders_status_created")
  @@map("orders")
}

model OrderItem {
  id                   Int     @id @default(autoincrement())
  orderId              Int     @map("order_id")
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId            Int     @map("product_id")
  stockItemId          Int?    @map("stock_item_id")
  quantity             Int     @default(1)
  unitPrice            Decimal @map("unit_price")
  warrantyDaysSnapshot Int     @map("warranty_days_snapshot")

  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // `product` resolves to a Denomination (SKU); renamed in Phase 5 cleanup.
  product   Denomination @relation(fields: [productId], references: [id], onUpdate: NoAction)
  stockItem StockItem?   @relation(fields: [stockItemId], references: [id], onUpdate: NoAction)

  @@index([orderId], map: "ix_order_items_order_id")
  @@map("order_items")
}

model Voucher {
  id          Int       @id @default(autoincrement())
  code        String    @unique(map: "ix_vouchers_code")
  type        String
  value       Decimal
  usageLimit  Int?      @map("usage_limit")
  usedCount   Int       @default(0) @map("used_count")
  minPurchase Decimal   @default(0) @map("min_purchase")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  orders Order[]

  @@map("vouchers")
}

model Review {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId Int      @map("product_id")
  orderId   Int      @map("order_id")
  rating    Int
  comment   String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // `product` resolves to a Denomination (SKU); renamed in Phase 5 cleanup.
  product Denomination @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, orderId], map: "sqlite_autoindex_reviews_1")
  @@index([productId], map: "ix_reviews_product_id")
  @@map("reviews")
}

model Referral {
  id         Int      @id @default(autoincrement())
  referrerId Int      @map("referrer_id")
  refereeId  Int      @unique(map: "sqlite_autoindex_referrals_1") @map("referee_id")
  orderId    Int      @map("order_id")
  commission Decimal
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  referee  User  @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  referrer User  @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([referrerId], map: "ix_referrals_referrer_id")
  @@map("referrals")
}

model SupportTicket {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  message      String
  photoFileIds String?   @map("photo_file_ids")
  status       String    @default("OPEN")
  adminReply   String?   @map("admin_reply")
  adminId      Int?      @map("admin_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  repliedAt    DateTime? @map("replied_at")

  user     User            @relation("TicketUser", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  admin    User?           @relation("TicketAdmin", fields: [adminId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages TicketMessage[]

  @@index([userId], map: "ix_support_tickets_user_id")
  @@map("support_tickets")
}

model TicketMessage {
  id           Int      @id @default(autoincrement())
  ticketId     Int      @map("ticket_id")
  senderType   String   @map("sender_type")
  senderId     Int?     @map("sender_id")
  content      String
  photoFileIds String?  @map("photo_file_ids")
  createdAt    DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sender User?         @relation(fields: [senderId], references: [id], onUpdate: NoAction)

  @@index([ticketId], map: "ix_ticket_messages_ticket_id")
  @@map("ticket_messages")
}

model RestockSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // `product` resolves to a Denomination (SKU); renamed in Phase 5 cleanup.
  product Denomination @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, productId], map: "sqlite_autoindex_restock_subscriptions_1")
  @@map("restock_subscriptions")
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId Int      @map("product_id")
  quantity  Int      @default(1)
  addedAt   DateTime @default(now()) @map("added_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // `product` resolves to a Denomination (SKU); renamed in Phase 5 cleanup.
  product Denomination @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, productId], map: "sqlite_autoindex_cart_items_1")
  @@index([userId], map: "ix_cart_items_user_id")
  @@map("cart_items")
}

model BulkPricing {
  id              Int      @id @default(autoincrement())
  /// Holds a denomination id (column kept as `product_id` to avoid a rename).
  productId       Int      @unique(map: "ix_bulk_pricing_product_id") @map("product_id")
  minQuantity     Int      @map("min_quantity")
  discountPercent Decimal  @map("discount_percent")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  // `product` resolves to a Denomination (SKU); renamed in Phase 5 cleanup.
  product Denomination @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("bulk_pricing")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  adminId    Int?     @map("admin_id")
  action     String
  targetType String?  @map("target_type")
  targetId   Int?     @map("target_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")

  admin User? @relation(fields: [adminId], references: [id], onUpdate: NoAction)

  @@index([createdAt], map: "ix_audit_logs_created_at")
  @@map("audit_logs")
}

model NotificationOutbox {
  id          Int       @id @default(autoincrement())
  event       String
  payloadJson String    @map("payload_json")
  orderId     Int?      @map("order_id")
  status      String    @default("PENDING")
  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  sentAt      DateTime? @map("sent_at")

  order Order? @relation(fields: [orderId], references: [id], onUpdate: NoAction)

  @@index([status, createdAt], map: "ix_notif_status_created")
  @@index([orderId], map: "ix_notification_outbox_order_id")
  @@index([status], map: "ix_notification_outbox_status")
  @@index([createdAt], map: "ix_notification_outbox_created_at")
  @@map("notification_outbox")
}

/// Idempotency ledger for Binance Internal Transfer auto-confirmation.
/// Every Binance transaction the poller inspects is recorded here exactly once;
/// the UNIQUE binance_tx_id is what prevents double-processing / double-delivery
/// (SQLite has no row locking, so the insert-first-on-unique pattern is the
/// concurrency guard — see payments/binanceInternal.ts).
/// Broadcast queue — the web ENQUEUES here; the order-bot drains and sends
/// (the web never calls Telegram). One row = one broadcast to a segment.
model Broadcast {
  id          Int       @id @default(autoincrement())
  message     String
  segment     String // ALL | RESELLERS | RECENT_BUYERS
  status      String    @default("PENDING") // PENDING | SENDING | SENT | CANCELLED
  scheduledAt DateTime? @map("scheduled_at") // null = send asap
  createdById Int?      @map("created_by_id") // acting web admin (user id)
  totalCount  Int       @default(0) @map("total_count") // recipients at enqueue (display)
  sentCount   Int       @default(0) @map("sent_count")
  failedCount Int       @default(0) @map("failed_count")
  createdAt   DateTime  @default(now()) @map("created_at")
  sentAt      DateTime? @map("sent_at")

  @@index([status], map: "ix_broadcasts_status")
  @@map("broadcasts")
}

model ProcessedBinanceTx {
  id          Int      @id @default(autoincrement())
  binanceTxId String   @unique(map: "ix_processed_binance_tx_txid") @map("binance_tx_id")
  orderId     Int?     @map("order_id")
  amount      Decimal?
  // matched | underpaid | unmatched
  outcome     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderId], map: "ix_processed_binance_tx_order_id")
  @@map("processed_binance_tx")
}

/// Idempotency ledger for Bybit USDT-BSC deposits — same insert-first-on-unique
/// pattern as ProcessedBinanceTx. The on-chain txID (a 0x… hash) is claimed
/// exactly once, so repeated poll cycles can never double-deliver. BEP20 carries
/// no memo, so there is no underpaid auto-path (an amount that matches no order
/// is simply "unmatched"); outcome is matched | unmatched | delivery_failed.
model ProcessedBybitTx {
  id        Int      @id @default(autoincrement())
  bybitTxId String   @unique(map: "ix_processed_bybit_tx_txid") @map("bybit_tx_id")
  orderId   Int?     @map("order_id")
  amount    Decimal?
  outcome   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId], map: "ix_processed_bybit_tx_order_id")
  @@map("processed_bybit_tx")
}

/// Idempotency ledger for TokoPay webhook callbacks (the IDR payment path) —
/// same insert-first-on-unique pattern as ProcessedBinanceTx: a callback's
/// reference id is claimed exactly once, so repeated callbacks can never
/// double-deliver an order (plan.md §15.5).
model ProcessedTokopayTx {
  id        Int      @id @default(autoincrement())
  trxId     String   @unique(map: "ix_processed_tokopay_tx_trxid") @map("trx_id")
  orderId   Int?     @map("order_id")
  amount    Decimal?
  // matched | unmatched | delivery_failed
  outcome   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId], map: "ix_processed_tokopay_tx_order_id")
  @@map("processed_tokopay_tx")
}

/// Idempotency ledger for PayDisini (QRIS/e-wallet, IDR) webhook callbacks —
/// same insert-first-on-unique pattern as ProcessedTokopayTx.
model ProcessedPaydisiniTx {
  id        Int      @id @default(autoincrement())
  trxId     String   @unique(map: "ix_processed_paydisini_tx_trxid") @map("trx_id")
  orderId   Int?     @map("order_id")
  amount    Decimal?
  // matched | unmatched | delivery_failed | stale
  outcome   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId], map: "ix_processed_paydisini_tx_order_id")
  @@map("processed_paydisini_tx")
}

/// Idempotency ledger for NOWPayments (USDT crypto invoice) IPN callbacks —
/// same insert-first-on-unique pattern. trxId stores NOWPayments' payment_id.
model ProcessedNowpaymentsTx {
  id        Int      @id @default(autoincrement())
  trxId     String   @unique(map: "ix_processed_nowpayments_tx_trxid") @map("trx_id")
  orderId   Int?     @map("order_id")
  amount    Decimal?
  // matched | unmatched | delivery_failed | stale
  outcome   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId], map: "ix_processed_nowpayments_tx_order_id")
