{% extends "base.njk" %}
{% import "_macros.njk" as ui %}
{% block title %}Payments · Stock Admin{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-2">Binance Internal Transfer</h1>
<p class="text-sm text-slate-500 mb-6">UID-based auto-confirm ledger &amp; manual levers.</p>

{{ ui.flash(msg, kind) }}

{% if not enabled %}
<div class="rounded-md px-4 py-3 mb-6 text-sm bg-slate-100 text-slate-600 border border-slate-200">
  Binance Internal Transfer is <b>disabled</b> (missing UID / API credentials). The poller is a no-op;
  the ledger below shows historical rows only.
</div>
{% endif %}

{# ---- Poller health + outcome summary ---- #}
<section class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow p-4 col-span-2">
    <div class="text-xs uppercase tracking-wide text-slate-500">Poller health</div>
    <div class="text-sm mt-2">
      Last run:
      <span class="font-medium" title="{{ tzname }}">{{ health.lastRun | localdt('yyyy-LL-dd HH:mm:ss') if health.lastRun else 'never' }}</span>
    </div>
    <div class="text-xs text-slate-500 mt-1">
      {{ health.lastTxCount if health.lastTxCount is not none else '—' }} tx last cycle
      {% if health.backoffUntil %}· <span class="text-amber-600">backoff until {{ health.backoffUntil | localdt('HH:mm:ss') }}</span>{% endif %}
    </div>
  </div>
  {% set cards = [['matched','Matched','text-green-600'], ['underpaid','Underpaid','text-amber-600'], ['unmatched','Unmatched','text-blue-600'], ['delivery_failed','Failed','text-red-600']] %}
  {% for c in cards %}
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-xs uppercase tracking-wide text-slate-500">{{ c[1] }}</div>
    <div class="text-2xl font-semibold mt-2 {% if counts[c[0]] %}{{ c[2] }}{% endif %}">{{ counts[c[0]] or 0 }}</div>
  </div>
  {% endfor %}
</section>

{# ---- UNDERPAID resolution ---- #}
<section class="bg-white rounded-lg shadow p-5 mb-8">
  <h2 class="font-semibold mb-3">Underpaid orders <span class="text-slate-400 font-normal">({{ underpaid|length }})</span></h2>
  {% if underpaid|length == 0 %}
  <p class="text-sm text-slate-400">No underpaid orders awaiting resolution.</p>
  {% else %}
  <div class="overflow-x-auto">
    <table class="min-w-full text-sm">
      <thead class="bg-slate-100 text-slate-600 text-left">
        <tr>
          <th class="px-3 py-2">Order</th><th class="px-3 py-2">Buyer</th>
          <th class="px-3 py-2">Expected</th><th class="px-3 py-2">Note</th>
          <th class="px-3 py-2 text-right">Resolve</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {% for o in underpaid %}
        <tr class="align-top">
          <td class="px-3 py-2"><a class="font-mono hover:underline" href="/orders/{{ o.id }}">{{ o.orderCode }}</a></td>
          <td class="px-3 py-2 text-slate-500">{{ o.user.username or o.user.fullName or o.user.id }}</td>
          <td class="px-3 py-2">{{ o.totalAmount | money }} {{ currency }}</td>
          <td class="px-3 py-2 text-slate-500 break-all max-w-xs">{{ o.adminNote or '—' }}</td>
          <td class="px-3 py-2">
            <div class="flex gap-2 justify-end">
              <form method="post" action="/payments/order/{{ o.id }}/deliver">
                {{ ui.csrf_field(admin) }}
                <button class="px-2 py-1 rounded bg-green-600 text-white text-xs hover:bg-green-700"
                        onclick="return confirm('Deliver {{ o.orderCode }} despite short payment?')">Deliver</button>
              </form>
              <form method="post" action="/payments/order/{{ o.id }}/refund">
                {{ ui.csrf_field(admin) }}
                <button class="px-2 py-1 rounded bg-slate-700 text-white text-xs hover:bg-slate-800"
                        onclick="return confirm('Refund the received amount to {{ o.orderCode }}\'s wallet and mark REFUNDED?')">Refund</button>
              </form>
              <form method="post" action="/payments/order/{{ o.id }}/cancel">
                {{ ui.csrf_field(admin) }}
                <button class="px-2 py-1 rounded bg-red-600 text-white text-xs hover:bg-red-700"
                        onclick="return confirm('Cancel {{ o.orderCode }} (no refund)?')">Cancel</button>
              </form>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</section>

{# ---- Manual match of an unmatched transfer ---- #}
<section class="bg-white rounded-lg shadow p-5 mb-8">
  <h2 class="font-semibold mb-1">Manual match</h2>
  <p class="text-xs text-slate-500 mb-3">Attach an <b>unmatched</b> transfer (buyer forgot the note) to a pending order, then deliver.</p>
  <form method="post" action="/payments/match" class="flex flex-wrap gap-3 items-end text-sm">
    {{ ui.csrf_field(admin) }}
    <div>
      <label class="block text-xs text-slate-500 mb-1">Transfer id</label>
      <input name="binance_tx_id" required class="border rounded px-2 py-1 font-mono w-56" placeholder="binance_tx_id">
    </div>
    <div>
      <label class="block text-xs text-slate-500 mb-1">Order code</label>
      <input name="order_code" required list="pending-internal" class="border rounded px-2 py-1 font-mono w-40" placeholder="ABC123">
      <datalist id="pending-internal">
        {% for o in pending_internal %}<option value="{{ o.orderCode }}">{{ o.totalAmount }} {{ currency }}</option>{% endfor %}
      </datalist>
    </div>
    <button class="bg-slate-900 text-white px-4 py-1.5 rounded hover:bg-slate-700">Match &amp; deliver</button>
  </form>
  {% if pending_internal|length %}
  <p class="text-xs text-slate-400 mt-2">{{ pending_internal|length }} pending internal-transfer order(s) available to match.</p>
  {% endif %}
</section>

{# ---- Ledger ---- #}
<div class="flex items-center justify-between mb-3">
  <h2 class="font-semibold">Transfer ledger</h2>
  <form method="get" action="/payments" class="flex gap-2 items-center text-sm">
    <select name="outcome" class="border rounded px-2 py-1" onchange="this.form.submit()">
      <option value="">All outcomes</option>
      {% for o in outcomes %}<option value="{{ o }}" {% if f.outcome == o %}selected{% endif %}>{{ o | replace('_',' ') }}</option>{% endfor %}
    </select>
    <noscript><button class="bg-slate-900 text-white px-3 py-1 rounded">Filter</button></noscript>
  </form>
</div>

<div class="bg-white rounded-lg shadow overflow-x-auto">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-100 text-slate-600 text-left">
      <tr>
        <th class="px-4 py-2">When</th><th class="px-4 py-2">Tx id</th><th class="px-4 py-2">Outcome</th>
        <th class="px-4 py-2">Amount</th><th class="px-4 py-2">Order</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {% for r in ledger %}
      <tr class="hover:bg-slate-50">
        <td class="px-4 py-2 text-slate-500 whitespace-nowrap" title="{{ tzname }}">{{ r.createdAt | localdt('yyyy-LL-dd HH:mm:ss') }}</td>
        <td class="px-4 py-2 font-mono text-xs break-all max-w-xs">{{ r.binanceTxId }}</td>
        <td class="px-4 py-2">{{ ui.status_badge(r.outcome) }}</td>
        <td class="px-4 py-2">{{ r.amount | money }}{% if r.amount is not none %} {{ currency }}{% endif %}</td>
        <td class="px-4 py-2">
          {% if r.order %}<a class="font-mono hover:underline" href="/orders/{{ r.order.id }}">{{ r.order.orderCode }}</a>
          {% else %}<span class="text-slate-400">—</span>{% endif %}
        </td>
      </tr>
      {% else %}
      <tr><td colspan="5" class="px-4 py-6 text-center text-slate-400">No ledger rows match.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>

<div class="flex items-center justify-between mt-4 text-sm text-slate-500">
  <span>{{ total }} row(s) · page {{ page }}</span>
  <span class="flex gap-3">
    {% set qbase = '/payments?outcome=' + f.outcome %}
    {% if page > 1 %}<a class="hover:underline" href="{{ qbase }}&page={{ page - 1 }}">← Prev</a>{% endif %}
    {% if has_next %}<a class="hover:underline" href="{{ qbase }}&page={{ page + 1 }}">Next →</a>{% endif %}
  </span>
</div>
{% endblock %}
